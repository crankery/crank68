#pragma once

#include <cstdint>

enum addr_mode : uint8_t
{
    inh, /* inherent */
    rel, /* relative */
    imb, /* immediate (byte) */
    imw, /* immediate (word) */
    dir, /* direct address */
    ext, /* extended address */
    idx  /* x + byte offset */
};

enum class op_names : uint8_t;

struct OpInfo
{
    const char *op_name_s;
    op_names op_name;
    addr_mode addr_mode;
    uint8_t cycles;
    bool valid;
};

extern const OpInfo m6800_op_table[256];

{{defs_h}}
