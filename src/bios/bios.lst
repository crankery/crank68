F00:0001       ; bios.asm
F00:0002       ;
F00:0003       ; simple framework BIOS for a homebrew 6800 system
F00:0004       ;
F00:0005       ; memory map:
F00:0006       ;   $0000-$dfff   ram
F00:0007       ;   $e000-$e0ff   i/o
F00:0008       ;   $e100-$ffff   rom
F00:0009       ;
F00:0010       ; calling convention:
F00:0011       ;
F00:0012       ;   jsr bios_entry
F00:0013       ;   fcb bios_cmd_xxx
F00:0014       ;   ...inline args if needed...
F00:0015       ;
F00:0016       ; examples:
F00:0017       ;
F00:0018       ;   jsr bios_entry
F00:0019       ;   fcb bios_cmd_putc
F00:0020       ;   fcb 'a'
F00:0021       ;
F00:0022       ;   jsr bios_entry
F00:0023       ;   fcb bios_cmd_puts
F00:0024       ;   fcb 'h','e','l','l','o',13,10,0
F00:0025       ;
F00:0026       ; dispatcher behavior:
F00:0027       ;   - briefly masks irq
F00:0028       ;   - pulls caller return address
F00:0029       ;   - reads command / inline args from caller stream
F00:0030       ;   - computes corrected return address
F00:0031       ;   - pushes corrected return address back
F00:0032       ;   - restores prior irq mask state
F00:0033       ;   - performs service
F00:0034       ;   - rts back to caller after inline data
F00:0035       ;
F00:0036       ; notes:
F00:0037       ;   - assumes nmi is unused
F00:0038       ;   - assumes irq handlers are conventional and well-behaved
F00:0039       ;   - many routines are placeholders
F00:0040       
F00:0041       ; ------------------------------------------------------------
F00:0042       ; hardware definitions
F00:0043       ; ------------------------------------------------------------
F00:0044       
F00:0045           org $e000
F00:0046       
F00:0047       latch_reg       equ $e000
F00:0048       
F00:0049       ; adjust these for your actual acia map
F00:0050       acia0_data      equ $e010
F00:0051       acia0_status    equ $e011
F00:0052       acia0_cmd       equ $e012
F00:0053       acia0_ctrl      equ $e013
F00:0054       
F00:0055       acia_tdre_mask  equ $02
F00:0056       acia_rdrf_mask  equ $01
F00:0057       
F00:0058       rom_base        equ $e100
F00:0059       
F00:0060       ; ------------------------------------------------------------
F00:0061       ; zero page / low ram workspace
F00:0062       ; ------------------------------------------------------------
F00:0063       
F00:0064       bios_ptr        equ $0000    ; 16-bit pointer into inline parameter stream
F00:0065       bios_tmp        equ $0002    ; 16-bit scratch
F00:0066       bios_saved_cc   equ $0004    ; saved cc on entry
F00:0067       bios_saved_a    equ $0005    ; scratch
F00:0068       bios_saved_b    equ $0006    ; scratch
F00:0069       bios_saved_x    equ $0007    ; 16-bit scratch
F00:0070       
F00:0071       ; optional user-visible vectors / jump table in ram
F00:0072       vec_conout      equ $0010
F00:0073       vec_conin       equ $0012
F00:0074       vec_puts        equ $0014
F00:0075       vec_crlf        equ $0016
F00:0076       vec_warmstart   equ $0018
F00:0077       
F00:0078       ; ------------------------------------------------------------
F00:0079       ; bios command numbers
F00:0080       ; ------------------------------------------------------------
F00:0081       
F00:0082       cmd_putc       equ $01
F00:0083       cmd_puts       equ $02
F00:0084       cmd_crlf       equ $03
F00:0085       cmd_getc       equ $04
F00:0086       cmd_ws         equ $05
F00:0087       
F00:0088       ; ------------------------------------------------------------
F00:0089       ; rom starts here
F00:0090       ; ------------------------------------------------------------
F00:0091       
F00:0092       ; ------------------------------------------------------------
F00:0093       ; rom identification / version
F00:0094       ; ------------------------------------------------------------
F00:0095       
F00:0096       ; bios_id:
F00:0097       ;         fcb 'd','h','6','8','0','0'
F00:0098       
F00:0099       ; bios_version:
F00:0100       ;         fcb 0
F00:0101       ;         fcb 1
F00:0102       
F00:0103       ; ------------------------------------------------------------
F00:0104       ; cold reset entry
F00:0105       ; ------------------------------------------------------------
F00:0106       
F00:0107               org $e100
F00:0108       
F00:0109       reset:
F00:0110       ; establish a simple initial stack
F00:0111       ; adjust later if you prefer high ram
F00:0112               lds #$00ff
               S02:FFFFFFFFFFFFE100:  8E 00 FF
F00:0113       
F00:0114       ; clear condition codes
F00:0115               clra
               S02:FFFFFFFFFFFFE103:  4F
F00:0116               tap
               S02:FFFFFFFFFFFFE104:  06
F00:0117       
F00:0118       ; initialize latch / bank register to known state
F00:0119               staa latch_reg
               S02:FFFFFFFFFFFFE105:  B7 E0 00
F00:0120       
F00:0121       ; install optional ram vectors
F00:0122       ;        jsr init_vectors
F00:0123       
F00:0124       ; initialize console / serial hardware
F00:0125               jsr acia0_init
               S02:FFFFFFFFFFFFE108:  BD E1 9B
F00:0126       
F00:0127       ; simple banner using inline-dispatch interface
F00:0128               jsr bios_main
               S02:FFFFFFFFFFFFE10B:  BD E1 22
F00:0129               byte cmd_puts
               S02:FFFFFFFFFFFFE10E:  02
F00:0130               byte 'h','e','l','l','o',' ','w','o','r','l','d',13,10,0
               S02:FFFFFFFFFFFFE10F:  68
               S02:FFFFFFFFFFFFE110:  65
               S02:FFFFFFFFFFFFE111:  6C
               S02:FFFFFFFFFFFFE112:  6C
               S02:FFFFFFFFFFFFE113:  6F
               S02:FFFFFFFFFFFFE114:  20
               S02:FFFFFFFFFFFFE115:  77
               S02:FFFFFFFFFFFFE116:  6F
               S02:FFFFFFFFFFFFE117:  72
               S02:FFFFFFFFFFFFE118:  6C
               S02:FFFFFFFFFFFFE119:  64
               S02:FFFFFFFFFFFFE11A:  0D
               S02:FFFFFFFFFFFFE11B:  0A
               S02:FFFFFFFFFFFFE11C:  00
F00:0131       
F00:0132       ; hand off to monitor / shell / idle loop
F00:0133               jsr warmstart
               S02:FFFFFFFFFFFFE11D:  BD E1 99
F00:0134       
F00:0135       halt:
F00:0136               bra halt
               S02:FFFFFFFFFFFFE120:  20 FE
F00:0137       
F00:0138       ; ------------------------------------------------------------
F00:0139       ; bios dispatcher
F00:0140       ; ------------------------------------------------------------
F00:0141       
F00:0142       bios_main:
F00:0143       ; preserve caller interrupt state
F00:0144               tpa
               S02:FFFFFFFFFFFFE122:  07
F00:0145               staa bios_saved_cc
               S02:FFFFFFFFFFFFE123:  97 04
F00:0146       
F00:0147       ; mask irq before stack surgery
F00:0148               sei
               S02:FFFFFFFFFFFFE125:  0F
F00:0149       
F00:0150       ; pull caller return address into bios_ptr
F00:0151       ; on 6800, low byte is on top of stack for rts return
F00:0152               pula
               S02:FFFFFFFFFFFFE126:  32
F00:0153               pulb
               S02:FFFFFFFFFFFFE127:  33
F00:0154       
F00:0155       ; save pointer = address of first inline byte
F00:0156               staa bios_ptr+1
               S02:FFFFFFFFFFFFE128:  97 01
F00:0157               stab bios_ptr
               S02:FFFFFFFFFFFFE12A:  D7 00
F00:0158       
F00:0159       ; read command byte
F00:0160               ldx bios_ptr
               S02:FFFFFFFFFFFFE12C:  DE 00
F00:0161               ldaa 0,x
               S02:FFFFFFFFFFFFE12E:  A6 00
F00:0162               inx
               S02:FFFFFFFFFFFFE130:  08
F00:0163               stx bios_ptr
               S02:FFFFFFFFFFFFE131:  DF 00
F00:0164       
F00:0165       ; dispatch on command in a
F00:0166               cmpa #cmd_putc
               S02:FFFFFFFFFFFFE133:  81 01
F00:0167               beq bios_putc
               S02:FFFFFFFFFFFFE135:  27 19
F00:0168       
F00:0169               cmpa #cmd_puts
               S02:FFFFFFFFFFFFE137:  81 02
F00:0170               beq bios_puts
               S02:FFFFFFFFFFFFE139:  27 21
F00:0171       
F00:0172               cmpa #cmd_crlf
               S02:FFFFFFFFFFFFE13B:  81 03
F00:0173               beq bios_crlf
               S02:FFFFFFFFFFFFE13D:  27 2E
F00:0174       
F00:0175               cmpa #cmd_getc
               S02:FFFFFFFFFFFFE13F:  81 04
F00:0176               beq bios_getc
               S02:FFFFFFFFFFFFE141:  27 33
F00:0177       
F00:0178               cmpa #cmd_ws
               S02:FFFFFFFFFFFFE143:  81 05
F00:0179               bne bios_unknown
               S02:FFFFFFFFFFFFE145:  26 03
F00:0180               jmp bios_ws
               S02:FFFFFFFFFFFFE147:  7E E1 7F
F00:0181       
F00:0182       ; unknown command: skip just the command byte
F00:0183       ; and return after it
F00:0184       bios_unknown:
F00:0185               ldx bios_ptr
               S02:FFFFFFFFFFFFE14A:  DE 00
F00:0186               jsr bios_rts
               S02:FFFFFFFFFFFFE14C:  BD E1 87
F00:0187               rts
               S02:FFFFFFFFFFFFE14F:  39
F00:0188       
F00:0189       ; ------------------------------------------------------------
F00:0190       ; command handlers
F00:0191       ; each one must leave X pointing to the first byte
F00:0192       ; AFTER its inline arguments before calling
F00:0193       ; bios_rts
F00:0194       ; ------------------------------------------------------------
F00:0195       
F00:0196       bios_putc:
F00:0197       ; inline format:
F00:0198       ;   fcb bios_cmd_putc
F00:0199       ;   fcb char
F00:0200       
F00:0201               ldx bios_ptr
               S02:FFFFFFFFFFFFE150:  DE 00
F00:0202               ldaa 0,x
               S02:FFFFFFFFFFFFE152:  A6 00
F00:0203               inx
               S02:FFFFFFFFFFFFE154:  08
F00:0204       
F00:0205       ; fix return address and restore irq state
F00:0206               jsr bios_rts
               S02:FFFFFFFFFFFFE155:  BD E1 87
F00:0207       
F00:0208       ; output character in A
F00:0209               jsr conout_impl
               S02:FFFFFFFFFFFFE158:  BD E1 9C
F00:0210               rts
               S02:FFFFFFFFFFFFE15B:  39
F00:0211       
F00:0212       bios_puts:
F00:0213       ; inline format:
F00:0214       ;   fcb bios_cmd_puts
F00:0215       ;   fcb 'h','e','l','l','o',0
F00:0216       ;
F00:0217       ; on entry bios_ptr points to first char
F00:0218       
F00:0219               ldx bios_ptr
               S02:FFFFFFFFFFFFE15C:  DE 00
F00:0220               stx bios_tmp
               S02:FFFFFFFFFFFFE15E:  DF 02
F00:0221       
F00:0222       bios_puts_scan:
F00:0223               ldaa 0,x
               S02:FFFFFFFFFFFFE160:  A6 00
F00:0224               inx
               S02:FFFFFFFFFFFFE162:  08
F00:0225               beq lputs_scanned
               S02:FFFFFFFFFFFFE163:  27 02
F00:0226               bra bios_puts_scan
               S02:FFFFFFFFFFFFE165:  20 F9
F00:0227       
F00:0228       ; X now points just past terminating zero
F00:0229       ; print from saved starting pointer
F00:0230       
F00:0231       lputs_scanned:
F00:0232               ldx bios_tmp
               S02:FFFFFFFFFFFFE167:  DE 02
F00:0233               jsr puts_x_impl
               S02:FFFFFFFFFFFFE169:  BD E1 B2
F00:0234               rts
               S02:FFFFFFFFFFFFE16C:  39
F00:0235       
F00:0236       bios_crlf:
F00:0237       ; inline format:
F00:0238       ;   fcb bios_cmd_crlf
F00:0239       ;   no args
F00:0240       
F00:0241               ldx bios_ptr
               S02:FFFFFFFFFFFFE16D:  DE 00
F00:0242               jsr bios_rts
               S02:FFFFFFFFFFFFE16F:  BD E1 87
F00:0243               jsr crlf_impl
               S02:FFFFFFFFFFFFE172:  BD E1 BD
F00:0244               rts
               S02:FFFFFFFFFFFFE175:  39
F00:0245       
F00:0246       bios_getc:
F00:0247       ; inline format:
F00:0248       ;   fcb bios_cmd_getc
F00:0249       ;   no inline args
F00:0250       ;
F00:0251       ; return value in A
F00:0252       
F00:0253               ldx bios_ptr
               S02:FFFFFFFFFFFFE176:  DE 00
F00:0254               jsr bios_rts
               S02:FFFFFFFFFFFFE178:  BD E1 87
F00:0255               jsr conin_impl
               S02:FFFFFFFFFFFFE17B:  BD E1 A7
F00:0256               rts
               S02:FFFFFFFFFFFFE17E:  39
F00:0257       
F00:0258       bios_ws:
F00:0259       ; inline format:
F00:0260       ;   fcb bios_cmd_warmstart
F00:0261       ;   no args
F00:0262       
F00:0263               ldx bios_ptr
               S02:FFFFFFFFFFFFE17F:  DE 00
F00:0264               jsr bios_rts
               S02:FFFFFFFFFFFFE181:  BD E1 87
F00:0265               jmp warmstart
               S02:FFFFFFFFFFFFE184:  7E E1 99
F00:0266       
F00:0267       ; ------------------------------------------------------------
F00:0268       ; helper: fix caller return address and restore irq mask state
F00:0269       ;
F00:0270       ; entry:
F00:0271       ;   X = address to resume at after rts
F00:0272       ;   bios_saved_cc contains caller's original cc
F00:0273       ;
F00:0274       ; exit:
F00:0275       ;   corrected return address pushed for rts
F00:0276       ;   irq mask restored to original state
F00:0277       ; ------------------------------------------------------------
F00:0278       
F00:0279       bios_rts:
F00:0280       ; push corrected return address for rts
F00:0281       ; rts expects low then high on stack after pops,
F00:0282       ; so match normal 6800 convention here
F00:0283       
F00:0284       ; fill this in however you like if you want a helper
F00:0285       ; implementation without a TFR instruction, since 6800
F00:0286       ; does not have TFR.
F00:0287       ;
F00:0288       ; easiest is just:
F00:0289       ;   stx bios_tmp
F00:0290       ;   ldaa bios_tmp+1
F00:0291       ;   ldab bios_tmp
F00:0292       ;
F00:0293               stx bios_tmp
               S02:FFFFFFFFFFFFE187:  DF 02
F00:0294               ldaa bios_tmp+1
               S02:FFFFFFFFFFFFE189:  96 03
F00:0295               ldab bios_tmp
               S02:FFFFFFFFFFFFE18B:  D6 02
F00:0296               pshb
               S02:FFFFFFFFFFFFE18D:  37
F00:0297               psha
               S02:FFFFFFFFFFFFE18E:  36
F00:0298       
F00:0299       ; restore original interrupt mask state
F00:0300       ; simplest safe method: inspect saved cc and either
F00:0301       ; leave irq masked or unmask it
F00:0302               ldaa bios_saved_cc
               S02:FFFFFFFFFFFFE18F:  96 04
F00:0303               anda #$10            ; isolate I bit
               S02:FFFFFFFFFFFFE191:  84 10
F00:0304               bne bios_sei
               S02:FFFFFFFFFFFFE193:  26 02
F00:0305       
F00:0306       bios_cli:
F00:0307               cli
               S02:FFFFFFFFFFFFE195:  0E
F00:0308               rts
               S02:FFFFFFFFFFFFE196:  39
F00:0309       
F00:0310       bios_sei:
F00:0311               sei
               S02:FFFFFFFFFFFFE197:  0F
F00:0312               rts
               S02:FFFFFFFFFFFFE198:  39
F00:0313       
F00:0314       ; ------------------------------------------------------------
F00:0315       ; initialization helpers
F00:0316       ; ------------------------------------------------------------
F00:0317       
F00:0318       ; init_vectors:
F00:0319       ;         ldx #bios_rom_putc
F00:0320       ;         stx vec_conout
F00:0321       
F00:0322       ;         ldx #bios_rom_getc
F00:0323       ;         stx vec_conin
F00:0324       
F00:0325       ;         ldx #bios_rom_puts_x
F00:0326       ;         stx vec_puts
F00:0327       
F00:0328       ;         ldx #bios_rom_crlf
F00:0329       ;         stx vec_crlf
F00:0330       
F00:0331       ;         ldx #bios_rom_warmstart
F00:0332       ;         stx vec_warmstart
F00:0333       ;         rts
F00:0334       
F00:0335       ; ------------------------------------------------------------
F00:0336       ; warm start / monitor entry
F00:0337       ; ------------------------------------------------------------
F00:0338       
F00:0339       warmstart:
F00:0340       ; placeholder
F00:0341       ; replace this with monitor entry, shell, scheduler, etc.
F00:0342       warmstart_loop:
F00:0343               bra warmstart_loop
               S02:FFFFFFFFFFFFE199:  20 FE
F00:0344       
F00:0345       ; ------------------------------------------------------------
F00:0346       ; console / acia support
F00:0347       ; ------------------------------------------------------------
F00:0348       
F00:0349       acia0_init:
F00:0350       ; placeholder
F00:0351       ;
F00:0352       ; fill in for your actual acia and clock
F00:0353       ; example tasks:
F00:0354       ;   - master reset
F00:0355       ;   - set divider
F00:0356       ;   - set 8n1
F00:0357       ;   - enable tx/rx
F00:0358               rts
               S02:FFFFFFFFFFFFE19B:  39
F00:0359       
F00:0360       conout_impl:
F00:0361       ; entry: A = character to send
F00:0362       
F00:0363       conout_wait:
F00:0364       ; placeholder status poll
F00:0365       ; if you want fake-emulator output via $e000 instead,
F00:0366       ; you could simply:
F00:0367       ;   staa latch_reg
F00:0368       ;   rts
F00:0369       ;
F00:0370               ldab acia0_status
               S02:FFFFFFFFFFFFE19C:  F6 E0 11
F00:0371               andb #acia_tdre_mask
               S02:FFFFFFFFFFFFE19F:  C4 02
F00:0372               beq conout_wait
               S02:FFFFFFFFFFFFE1A1:  27 F9
F00:0373       
F00:0374               staa acia0_data
               S02:FFFFFFFFFFFFE1A3:  B7 E0 10
F00:0375               rts
               S02:FFFFFFFFFFFFE1A6:  39
F00:0376       
F00:0377       conin_impl:
F00:0378       ; return received character in A
F00:0379       conin_wait:
F00:0380               ldab acia0_status
               S02:FFFFFFFFFFFFE1A7:  F6 E0 11
F00:0381               andb #acia_rdrf_mask
               S02:FFFFFFFFFFFFE1AA:  C4 01
F00:0382               beq conin_wait
               S02:FFFFFFFFFFFFE1AC:  27 F9
F00:0383       
F00:0384               ldaa acia0_data
               S02:FFFFFFFFFFFFE1AE:  B6 E0 10
F00:0385               rts
               S02:FFFFFFFFFFFFE1B1:  39
F00:0386       
F00:0387       puts_x_impl:
F00:0388       ; entry: X points to null-terminated string
F00:0389       puts_x_loop:
F00:0390               ldaa 0,x
               S02:FFFFFFFFFFFFE1B2:  A6 00
F00:0391               beq puts_x_done
               S02:FFFFFFFFFFFFE1B4:  27 06
F00:0392               jsr conout_impl
               S02:FFFFFFFFFFFFE1B6:  BD E1 9C
F00:0393               inx
               S02:FFFFFFFFFFFFE1B9:  08
F00:0394               bra puts_x_loop
               S02:FFFFFFFFFFFFE1BA:  20 F6
F00:0395       
F00:0396       puts_x_done:
F00:0397               rts
               S02:FFFFFFFFFFFFE1BC:  39
F00:0398       
F00:0399       crlf_impl:
F00:0400               ldaa #13
               S02:FFFFFFFFFFFFE1BD:  86 0D
F00:0401               jsr conout_impl
               S02:FFFFFFFFFFFFE1BF:  BD E1 9C
F00:0402               ldaa #10
               S02:FFFFFFFFFFFFE1C2:  86 0A
F00:0403               jsr conout_impl
               S02:FFFFFFFFFFFFE1C4:  BD E1 9C
F00:0404               rts
               S02:FFFFFFFFFFFFE1C7:  39
F00:0405       
F00:0406       ; ------------------------------------------------------------
F00:0407       ; interrupt handlers
F00:0408       ; ------------------------------------------------------------
F00:0409       
F00:0410       irq_handler:
F00:0411       ; placeholder irq service
F00:0412               rti
               S02:FFFFFFFFFFFFE1C8:  3B
F00:0413       
