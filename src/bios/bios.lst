F00:0420               rti
               S02:FFFFFFFFFFFFE1CA:  3B
F00:0421       
F00:0422       ; ------------------------------------------------------------
F00:0423       ; vectors
F00:0424       ; 6800 fixed vectors:
F00:0425       ;   $fff8 irq
F00:0426       ;   $fffa swi
F00:0427       ;   $fffc nmi
F00:0428       ;   $fffe reset
F00:0429       ; ------------------------------------------------------------
F00:0430       
F00:0431               org $fff8
F00:0432               fdb irq_handler
               S03:FFFFFFFFFFFFFFF8:  E1 C8
F00:0433               fdb swi_handler
               S03:FFFFFFFFFFFFFFFA:  E1 C9
F00:0434               fdb nmi_handler
               S03:FFFFFFFFFFFFFFFC:  E1 CA
F00:0435               fdb reset
               S03:FFFFFFFFFFFFFFFE:  E1 00


