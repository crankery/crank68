               S01:FFFFFFFFFFFFFA25:  8D E1
F00:0426       *                      XHI,XLOW HOLD ADDRESS
F00:0427              LDAA   #$FF     FLAG FOR PUTTING IN BREAKS
               S01:FFFFFFFFFFFFFA27:  86 FF
F00:0428              BSR    BRKSUB   GO PUT IN BREAKS
               S01:FFFFFFFFFFFFFA29:  8D 3F
F00:0429              TSX
               S01:FFFFFFFFFFFFFA2B:  30
F00:0430              LDAA   XHI      SAVE PCH ON STACK
               S01:FFFFFFFFFFFFFA2C:  B6 A0 7C
F00:0431              STAA   5,X
               S01:FFFFFFFFFFFFFA2F:  A7 05
