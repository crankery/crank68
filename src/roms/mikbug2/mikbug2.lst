               S01:FFFFFFFFFFFFFF09:  B6 A0 9C
F00:1454              BSR    BYTOV1
               S01:FFFFFFFFFFFFFF0C:  8D EA
F00:1455              CLR    L        DO ENTIRE PAGE
               S01:FFFFFFFFFFFFFF0E:  7F A0 9E
F00:1456              LDX    H        POINT AT THE DATA
               S01:FFFFFFFFFFFFFF11:  FE A0 9C
F00:1457       DUMP1  LDAA   0,X
               S01:FFFFFFFFFFFFFF14:  A6 00
F00:1458              BSR    BYTOV1   SEND DATA
               S01:FFFFFFFFFFFFFF16:  8D E0
F00:1459              INX
               S01:FFFFFFFFFFFFFF18:  08
F00:1460              INC    L        BYTE CTR
               S01:FFFFFFFFFFFFFF19:  7C A0 9E
F00:1461              BNE    DUMP1
               S01:FFFFFFFFFFFFFF1C:  26 F6
F00:1462              BSR    SENCRC
               S01:FFFFFFFFFFFFFF1E:  8D 07
F00:1463              LDAA   #'D'      PRINT D FOR EACH PAGE DUMPED
               S01:FFFFFFFFFFFFFF20:  86 44
F00:1464              BSR    TTYO1
               S01:FFFFFFFFFFFFFF22:  8D 54
F00:1465              CLRA
               S01:FFFFFFFFFFFFFF24:  4F
F00:1466              BRA    BYTOV1   EXTRA BITS
               S01:FFFFFFFFFFFFFF25:  20 D1
F00:1467       *
F00:1468       * SENCRC SENDS THE CRC REGISTERS TO TAPE
F00:1469       *
F00:1470       *
F00:1471       *     RAM:  R, S (FREED AFTER THIS); L (SCRATCH)
F00:1472       *     REGS:  ACCA, ACCB (DESTROYED)
F00:1473       *
F00:1474       SENCRC LDAA   S
               S01:FFFFFFFFFFFFFF27:  B6 A0 A4
F00:1475              STAA   L        TEMPORARY CRC(L) STORAGE
               S01:FFFFFFFFFFFFFF2A:  B7 A0 9E
F00:1476              LDAA   R
               S01:FFFFFFFFFFFFFF2D:  B6 A0 A2
F00:1477              BSR    BYTOV1   SEND CRC(H)
               S01:FFFFFFFFFFFFFF30:  8D C6
F00:1478              LDAA   L
               S01:FFFFFFFFFFFFFF32:  B6 A0 9E
F00:1479              BRA    BYTOV1   SEND CRC(L)
               S01:FFFFFFFFFFFFFF35:  20 C1
F00:1480       *
F00:1481       * MASTERDUMP SENDS A COMPLETE FILE TO TAPE:
F00:1482       *     HEADERECORE, DUMPAGERECORDS (1-256), TRAILERECORD
F00:1483       *
F00:1484       *     RAM: STARTP, STOPPG (UNMODIFIED)
F00:1485       *          H, L (TEMP)
F00:1486       *     REGS: NEW EVERYTHING
