F00:1254              STAB   V        STORE PAGE COUNT
               S01:FFFFFFFFFFFFFE22:  F7 A0 A6
F00:1255       G2     RTS
               S01:FFFFFFFFFFFFFE25:  39
F00:1256       *
F00:1257       * STARTFIND LOOKS FOR THE 16-BIT START SEQUENCE 89AF
F00:1258       *     RETURNS WITH THE NEXT BYTE, THE RECORD TYPE,
F00:1259       *     IN Q AND ACCB.
F00:1260       *
F00:1261       *     RAM:  Q, R, S, TOTCNT (PERM), H (SCRATCH)
F00:1262       *     REGS:  ACCA, ACCB (SCRATCH ONLY)
F00:1263       *     EXIT:  FALLS INTO LOADBYTE, WHICH
F00:1264       *            FALLS INTO LOADBIT, WHICH
F00:1265       *            FALLS INTO CRC
F00:1266       *     ESCAPE:  ESC IN COMMAND PORT GETS OUT
F00:1267       *                (TEST DONE IN CRC)
F00:1268       *
F00:1269       STARTF CLR    H        ACCUMULATES 16 BITS
               S01:FFFFFFFFFFFFFE26:  7F A0 9C
F00:1270              CLR    Q
               S01:FFFFFFFFFFFFFE29:  7F A0 A0
F00:1271       STA1   ASL    Q        SHIFT THE 16-BIT REGISTER
               S01:FFFFFFFFFFFFFE2C:  78 A0 A0
F00:1272              ROL    H
               S01:FFFFFFFFFFFFFE2F:  79 A0 9C
F00:1273              BSR    LOADB1
               S01:FFFFFFFFFFFFFE32:  8D 24
F00:1274              BEQ    G2       OUT IFF ESCAPED
               S01:FFFFFFFFFFFFFE34:  27 EF
F00:1275              LDAA   H
               S01:FFFFFFFFFFFFFE36:  B6 A0 9C
F00:1276              LDAB   Q
               S01:FFFFFFFFFFFFFE39:  F6 A0 A0
F00:1277              CMPA   #$89     START SEQUENCE
               S01:FFFFFFFFFFFFFE3C:  81 89
F00:1278              BNE    STA1
               S01:FFFFFFFFFFFFFE3E:  26 EC
F00:1279              CMPB   #$AF
               S01:FFFFFFFFFFFFFE40:  C1 AF
F00:1280              BNE    STA1
               S01:FFFFFFFFFFFFFE42:  26 E8
F00:1281       STA2   CLR    R        CLEAR THE CRC REGISTER
               S01:FFFFFFFFFFFFFE44:  7F A0 A2
F00:1282              CLR    S
               S01:FFFFFFFFFFFFFE47:  7F A0 A4
F00:1283       * FALL INTO LOADBYTE TO RETURN A BYTE
F00:1284       *
F00:1285       * LOADBYTE RECOVERS OF DATA IN Q AND ACCB, AND DOES CRC
F00:1286       *
F00:1287       *     RAM:  Q, R, S, TOTCNT (PERM)
F00:1288       *     REGS:  ACCA, ACCB (SCRATCH ONLY)
F00:1289       *     EXIT:  FALLS INTO LOADBIT, WHICH
F00:1290       *            FALLS INTO CRC
F00:1291       *
F00:1292       LOADBY LDAB   #$02     SET STOP
               S01:FFFFFFFFFFFFFE4A:  C6 02
F00:1293              STAB   Q
               S01:FFFFFFFFFFFFFE4C:  F7 A0 A0
F00:1294       LOAD1  BSR    LOADB1
               S01:FFFFFFFFFFFFFE4F:  8D 07
F00:1295              BEQ    G2       OUT IFF ESCAPE
               S01:FFFFFFFFFFFFFE51:  27 D2
F00:1296              ASL    Q        STOP INTO CARRY?
               S01:FFFFFFFFFFFFFE53:  78 A0 A0
F00:1297              BCC    LOAD1    BRANCH IF NO
               S01:FFFFFFFFFFFFFE56:  24 F7
F00:1298       * FALL INTO LOADBIT FOR LAST BIT
F00:1299       *
F00:1300       * LOADBIT RECOVERS ONE BIT OF DATA IN Q AND ACCB,
F00:1301       *     AND DOES CRC IN R AND S
F00:1302       *
F00:1303       *     RAM:  Q, R, S, TOTCNT (PERM)
F00:1304       *     REGS:  ACCA, ACCB (SCRATCH ONLY)
F00:1305       *     EXIT:  BRANCHES OR FALLS INTO CRC ROUTINE
F00:1306       *            DATA BIT GOES INTO Q LSB
F00:1307       *
F00:1308       LOADB1 CLRB
               S01:FFFFFFFFFFFFFE58:  5F
F00:1309       LOADB6 DECB
               S01:FFFFFFFFFFFFFE59:  5A
F00:1310              BEQ    LOADB5
               S01:FFFFFFFFFFFFFE5A:  27 1F
F00:1311              BSR    TAIN1V   GET TAPE DATA IN CARRY
               S01:FFFFFFFFFFFFFE5C:  8D 43
F00:1312              BCS    LOADB6   WAIT FOR LOW
               S01:FFFFFFFFFFFFFE5E:  25 F9
F00:1313       LOADB2 DECB
               S01:FFFFFFFFFFFFFE60:  5A
F00:1314              BEQ    LOADB5
               S01:FFFFFFFFFFFFFE61:  27 18
F00:1315              BSR    TAIN1V   WAIT FOR HIGH
               S01:FFFFFFFFFFFFFE63:  8D 3C
F00:1316              BCC    LOADB2   )  (FRONT OF SYNC EL)
               S01:FFFFFFFFFFFFFE65:  24 F9
F00:1317              LDAB   TOTCNT   3.5 ELS DELAY
               S01:FFFFFFFFFFFFFE67:  F6 A0 92
F00:1318       LOADB3 DECB
               S01:FFFFFFFFFFFFFE6A:  5A
F00:1319              BEQ    LOADB5
               S01:FFFFFFFFFFFFFE6B:  27 0E
F00:1320              BSR    TAIN1V   )  WAIT FOR LOW
               S01:FFFFFFFFFFFFFE6D:  8D 32
F00:1321              BCS    LOADB3   )  (END OF SYNC EL)
               S01:FFFFFFFFFFFFFE6F:  25 F9
F00:1322       LOADB4 DECB
               S01:FFFFFFFFFFFFFE71:  5A
F00:1323              BEQ    LOADB5   DONE YET?
               S01:FFFFFFFFFFFFFE72:  27 07
F00:1324              BSR    TAIN1V
               S01:FFFFFFFFFFFFFE74:  8D 2B
F00:1325              BCC    LOADB4
               S01:FFFFFFFFFFFFFE76:  24 F9
F00:1326              INC    Q        STORE A '1' BIT
               S01:FFFFFFFFFFFFFE78:  7C A0 A0
F00:1327       LOADB5 LDAA   Q        GET DATA FOR CRC
               S01:FFFFFFFFFFFFFE7B:  B6 A0 A0
F00:1328       * FALL INTO CRC1
F00:1329       *
F00:1330       *  CRC ENTERS A BIT INTO CRC REGISTERS R AND S
F00:1331       *     USES CRC POLYNOMIAL:  X16 + X15 + X2 + X0
F00:1332       *
F00:1333       *     ENTRY:  ACCA HOLDS NEW BIT
F00:1334       *     RAM:  R, S (PERM)
F00:1335       *     REGS:  ACCA, ACCB (SCRATCH)
F00:1336       *     EXIT:  ACCB = Q, Z = 1 IFF ESC
F00:1337       *
F00:1338       CRC1   RORA            LSB INTO CARRY
               S01:FFFFFFFFFFFFFE7E:  46
F00:1339              RORA            CARRY INTO MSB
               S01:FFFFFFFFFFFFFE7F:  46
F00:1340       CRC2   ANDA   #$80     MASK MSB (DATA BIT)
               S01:FFFFFFFFFFFFFE80:  84 80
F00:1341              EORA   R        ENTER DATA BIT
               S01:FFFFFFFFFFFFFE82:  B8 A0 A2
F00:1342              LDAB   S
               S01:FFFFFFFFFFFFFE85:  F6 A0 A4
F00:1343              ASLB            SHIFT 16 BITS LEFT
               S01:FFFFFFFFFFFFFE88:  58
F00:1344              ROLA
               S01:FFFFFFFFFFFFFE89:  49
F00:1345              BCC    CRC3     IF B16 HIGH. . .
               S01:FFFFFFFFFFFFFE8A:  24 04
F00:1346              EORA   #$80     ENTER CRC POLYNOMIAL
               S01:FFFFFFFFFFFFFE8C:  88 80
F00:1347              EORB   #$05
               S01:FFFFFFFFFFFFFE8E:  C8 05
F00:1348       CRC3   STAA   R
               S01:FFFFFFFFFFFFFE90:  B7 A0 A2
F00:1349              STAB   S
               S01:FFFFFFFFFFFFFE93:  F7 A0 A4
F00:1350              LDAB   Q
               S01:FFFFFFFFFFFFFE96:  F6 A0 A0
F00:1351              JSR    TTYIN1   CHECK FOR ESCAPE
               S01:FFFFFFFFFFFFFE99:  BD FF 75
F00:1352              ANDA   #$7F     MASK PARITY
               S01:FFFFFFFFFFFFFE9C:  84 7F
F00:1353              CMPA   #ESC
               S01:FFFFFFFFFFFFFE9E:  81 1B
F00:1354              RTS
               S01:FFFFFFFFFFFFFEA0:  39
F00:1355       TAIN1V JMP    TAIN1
               S01:FFFFFFFFFFFFFEA1:  7E FF 69
F00:1356       *
F00:1357       * BYTEOUT SENDS BYTE IN ACCA TO TAPE
F00:1358       *
F00:1359       *     RAM:  R, S (CHANGED IN CRC)
F00:1360       *     REGS:  ACCA, ACCB (DESTROYED)
F00:1361       *     EXIT:  ACCA = 0, ACCB UNDEFINED
F00:1362       *
F00:1363       *     ACCA = DATA BYTE (SHIFTED)
F00:1364       *     ACCB = RECORDING PATTERN (ONE BIT)
F00:1365       *
F00:1366       BYTEOU PSHA            SAVE THE DATA BYTE
               S01:FFFFFFFFFFFFFEA4:  36
F00:1367              BSR    CRC2     ) DO THE CRC FIRST
               S01:FFFFFFFFFFFFFEA5:  8D D9
F00:1368              PULA            RECOVER THE DATA BYTE
               S01:FFFFFFFFFFFFFEA7:  32
F00:1369              SEC             SET STOP
               S01:FFFFFFFFFFFFFEA8:  0D
F00:1370              ROLA            DATA BIT INTO CARRY
               S01:FFFFFFFFFFFFFEA9:  49
F00:1371              BRA    BY2
               S01:FFFFFFFFFFFFFEAA:  20 06
F00:1372       BY1    PULA            RECOVER FROM DONE TEST
               S01:FFFFFFFFFFFFFEAC:  32
F00:1373              PSHA            SAVE SHIFTING BYTE
               S01:FFFFFFFFFFFFFEAD:  36
F00:1374              BSR    CRC2
               S01:FFFFFFFFFFFFFEAE:  8D D0
F00:1375              PULA            RECOVER SHIFTING BYTE
               S01:FFFFFFFFFFFFFEB0:  32
F00:1376              ASLA            DATA BIT INTO CARRY
               S01:FFFFFFFFFFFFFEB1:  48
F00:1377       BY2    LDAB   #$0A     RECORDING PATTERN
               S01:FFFFFFFFFFFFFEB2:  C6 0A
F00:1378       BY3    JSR    TAOU1    SEND ACCB TO TAPE
               S01:FFFFFFFFFFFFFEB4:  BD FF 6C
F00:1379              PSHB            SAVE PATTERN
               S01:FFFFFFFFFFFFFEB7:  37
F00:1380              LDAB   PATDEL   ELEMENT DELAY
               S01:FFFFFFFFFFFFFEB8:  F6 A0 94
F00:1381       BY4    DECB
               S01:FFFFFFFFFFFFFEBB:  5A
F00:1382              BNE    BY4      BRANCH IF ELEMENT NOT DONE
               S01:FFFFFFFFFFFFFEBC:  26 FD
F00:1383              PULB            RECOVER PATTERN
               S01:FFFFFFFFFFFFFEBE:  33
F00:1384              ROLB            NEXT ELEMENT (DATA FROM CARRY)
               S01:FFFFFFFFFFFFFEBF:  59
F00:1385              BCC    BY3      BRANCH IF PATTERN NOT DONE
               S01:FFFFFFFFFFFFFEC0:  24 F2
F00:1386              PSHA            SAVE DATA BYTE BEFORE TEST
               S01:FFFFFFFFFFFFFEC2:  36
F00:1387              ASLA            TEST ACCA
               S01:FFFFFFFFFFFFFEC3:  48
F00:1388              BNE    BY1      BRANCH IF BYTE NOT DONE
               S01:FFFFFFFFFFFFFEC4:  26 E6
F00:1389       BY5    INS             RESTORE STACK
               S01:FFFFFFFFFFFFFEC6:  31
F00:1390              RTS
               S01:FFFFFFFFFFFFFEC7:  39
F00:1391       *
F00:1392       * PREAMBLE SENDS OUT ALC BITS, AND THE START SEQUENCE,
F00:1393       *     THEN INITS THE CRC REGISTERS
F00:1394       *
F00:1395       *     RAM:  R, S (CHANGED)
F00:1396       *     REGS:  ACCA, ACCB (DESTROYED)
F00:1397       *     EXIT:  ACCA = 0, ACCB UNDEFINED
F00:1398       *
F00:1399       PREAMB BSR    BYTOV1   ALC BITS
               S01:FFFFFFFFFFFFFEC8:  8D 2E
F00:1400              BSR    BYTOV1
               S01:FFFFFFFFFFFFFECA:  8D 2C
F00:1401              LDAA   #$89     START SEQUENCE (H)
               S01:FFFFFFFFFFFFFECC:  86 89
F00:1402              BSR    BYTOV1
               S01:FFFFFFFFFFFFFECE:  8D 28
F00:1403              LDAA   #$AF     START SEQUENCE (L)
               S01:FFFFFFFFFFFFFED0:  86 AF
F00:1404              BSR    BYTOV1
               S01:FFFFFFFFFFFFFED2:  8D 24
F00:1405              CLR    R        ) CLEAR THE CRC REGISTERS
               S01:FFFFFFFFFFFFFED4:  7F A0 A2
F00:1406              CLR    S        )
               S01:FFFFFFFFFFFFFED7:  7F A0 A4
F00:1407              RTS
               S01:FFFFFFFFFFFFFEDA:  39
F00:1408       *
F00:1409       * HEADERECORD SENDS ALC BITS, THE START SEQUENCE,
F00:1410       *     HEADRECORD-TYPE, FILE ID, AND THE NUMBER OF
F00:1411       *     PAGES TO BE DUMPED
F00:1412       *
F00:1413       *     RAM:  FIDH, FIDL (UNMODIFIED)
F00:1414       *           R, S (CHANGED)
F00:1415       *     REGS:  ACCA, ACCB (DESTROYED)
F00:1416       *     EXIT:  ACCA = 0, ACCB UNDEFINED
F00:1417       *
F00:1418       HEADER BSR    BYTOV1   ALC BITS
               S01:FFFFFFFFFFFFFEDB:  8D 1B
F00:1419              BSR    BYTOV1
               S01:FFFFFFFFFFFFFEDD:  8D 19
F00:1420              BSR    PREAMB   START A RECORD
               S01:FFFFFFFFFFFFFEDF:  8D E7
F00:1421              LDAA   #$08     HEADERTYPE
               S01:FFFFFFFFFFFFFEE1:  86 08
F00:1422              BSR    BYTOV1
               S01:FFFFFFFFFFFFFEE3:  8D 13
F00:1423              LDAA   FIDH     FILE ID(H)
               S01:FFFFFFFFFFFFFEE5:  B6 A0 8A
F00:1424              BSR    BYTOV1
               S01:FFFFFFFFFFFFFEE8:  8D 0E
F00:1425              LDAA   FIDL     FILE ID(L)
               S01:FFFFFFFFFFFFFEEA:  B6 A0 8C
F00:1426              BSR    BYTOV1
               S01:FFFFFFFFFFFFFEED:  8D 09
F00:1427              LDAA   STOPPG   STOPAGE
               S01:FFFFFFFFFFFFFEEF:  B6 A0 90
F00:1428              SUBA   STARTP   STARTPAGE
               S01:FFFFFFFFFFFFFEF2:  B0 A0 8E
F00:1429              INCA
               S01:FFFFFFFFFFFFFEF5:  4C
F00:1430              BSR    BYTOV1   SEND # PAGES
               S01:FFFFFFFFFFFFFEF6:  8D 00
F00:1431       BYTOV1 JMP    BYTEOV   EXTRA BITS
               S01:FFFFFFFFFFFFFEF8:  7E FF 72
F00:1432       *
F00:1433       * TRAILERECORD SENDS A TRAILERECORD TO TAPE
F00:1434       *
F00:1435       *     RAM:  R, S (PERM)
F00:1436       *     REGS:  ACCA, ABBC (DESTROYED)
F00:1437       *
F00:1438       TRAILR  BSR   PREAMB   START A RECORD
               S01:FFFFFFFFFFFFFEFB:  8D CB
F00:1439               LDAA  #$20     TRAILERECORD TYPE
               S01:FFFFFFFFFFFFFEFD:  86 20
F00:1440               BSR   BYTOV1
               S01:FFFFFFFFFFFFFEFF:  8D F7
F00:1441               BRA   BYTOV1   EXTRA BITS
               S01:FFFFFFFFFFFFFF01:  20 F5
F00:1442       *
F00:1443       * DUMPAGERECORD SENDS THE START SEQUENCE, DUMPAGE-TYPE,
F00:1444       *     PAGE NUMBER, 2048 BITS DATA, AND THE CRC CHARACTERS
F00:1445       *
F00:1446       *     RAM:  H, R, S (PERM); L (SCRATCH)
F00:1447       *     REGS:  ACCA, ACCB (DESTROYED), NEW IX
F00:1448       *     EXIT:  ACCA = 0
F00:1449       *
F00:1450       DUMPAG BSR    PREAMB   START A RECORD
               S01:FFFFFFFFFFFFFF03:  8D C3
