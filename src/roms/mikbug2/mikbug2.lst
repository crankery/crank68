               S01:FFFFFFFFFFFFFA31:  B6 A0 7E
F00:0433              STAA   6,X
               S01:FFFFFFFFFFFFFA34:  A7 06
F00:0434              RTI             GO TO USER PRG
               S01:FFFFFFFFFFFFFA36:  3B
F00:0435       *
F00:0436       * SINGLE INSTRUCTION TRACE REQUESTED
F00:0437       *
F00:0438       NEXT   LDX    #1       # INSTRUCTIONS TO TRACE
               S01:FFFFFFFFFFFFFA37:  CE 00 01
F00:0439       TRACE2 CLR    BRKTRC   CLEAR FLAG INDICATING TRACE
               S01:FFFFFFFFFFFFFA3A:  7F A0 86
F00:0440       *                      IS DUE TO BREAK
F00:0441       TRACE3 STX    NTRACE   SAVE # INST'S TO TRACE
               S01:FFFFFFFFFFFFFA3D:  FF A0 34
F00:0442       *                            IS DUE TO BREAK
