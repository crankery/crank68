                        	   823: ; 
                        	   824: ; 
                        	   825: ; break interrupt handler 
                        	   826: ; 
                        	   827: brkinh:
02:E4A0 BDE3E2          	   828:             jsr print                   ; stop and show regs to user
02:E4A3 7EE2BA          	   829: ctrl:       jmp contrl                  ; return to control loop
                        	   830: ; 
                        	   831: ; trace interrupt handler 
                        	   832: ; p-counter has been decremented to point at swi 
                        	   833: ; trcins holds op code replaced by swi 
                        	   834: ; x hold address where trace swi is 
                        	   835: ; 
02:E4A6 B60319          	   836: trcinh:     ldaa trcins                 ; get op code of traced instr
02:E4A9 A700            	   837:             staa 0,x                    ; restore to user's code
                        	   838: ; 
02:E4AB 7D0343          	   839:             tst brktrc                  ; is processing to be
                        	   840: ; immediately continued? 
02:E4AE 270F            	   841:             beq nbktrc                  ; branch if not
                        	   842: ; 
                        	   843: ; processing is to 'CONTINUE' 
                        	   844: ; 
02:E4B0 7F0343          	   845:             clr brktrc                  ; reset continue flag
02:E4B3 86FF            	   846:             ldaa #0xff                  ; flag to set breaks in code
02:E4B5 BDE36A          	   847:             jsr brksub                  ; put breaks in
02:E4B8 7F0317          	   848:             clr trcadr                  ; no more trace, so clear address
02:E4BB 7F0318          	   849:             clr trcadr+1
02:E4BE 3B              	   850:             rti                         ; continue
                        	   851: ; 
                        	   852: ; trace is due to n or t trace commands 
                        	   853: ; 
02:E4BF BDE3E2          	   854: nbktrc:     jsr print                   ; print stack
02:E4C2 FE031A          	   855:             ldx ntrace                  ; get # instructions to trace
02:E4C5 09              	   856:             dex                         ; decrement count
02:E4C6 FF031A          	   857:             stx ntrace                  ; and restore
02:E4C9 27D8            	   858:             beq ctrl                    ; branch if all traces done
                        	   859: ; 
                        	   860: ; trace not done - trace next instruction 
                        	   861: ; 
02:E4CB B60319          	   862: contrc:     ldaa trcins                 ; get current instruction
02:E4CE B7030E          	   863:             staa brins                  ; save in case it's a branch
02:E4D1 8D70            	   864:             bsr opcbyt                  ; go get # bytes"type
02:E4D3 4D              	   865:             tsta                        ; check for branch
02:E4D4 2A35            	   866:             bpl ckobra                  ; check for other than branch
                        	   867: ; 
                        	   868: ; relative branch type instruction 
                        	   869: ; determine where to put swi 
                        	   870: ; s- holds pointer to user stack after swi 
02:E4D6 32              	   871:             pula                        ; get condition code
02:E4D7 34              	   872:             des                         ; update stack pointer after pull
02:E4D8 8A10            	   873:             oraa #0b00010000            ; make int's inhibited
02:E4DA 06              	   874:             tap                         ; restore user's c. code reg
02:E4DB 7E030E          	   875:             jmp brins                   ; go see how relative branch
                        	   876: ; fares 
                        	   877: ; 
                        	   878: ; branch was nogo - put swi at next instruction 
                        	   879: ; 
02:E4DE 8602            	   880: brnogo:     ldaa #2                     ; a = # bytes after current instr
02:E4E0 2029            	   881:             bra ckobra                  ; go put swi appropriately
                        	   882: ; 
                        	   883: ; branch was go, put swi at address being 
                        	   884: ; jumped to 
                        	   885: ; 
02:E4E2 FE0317          	   886: brgo:       ldx trcadr                  ; x : = trace address
02:E4E5 A601            	   887:             ldaa 1,x                    ; get branch offset
02:E4E7 08              	   888:             inx                         ; offset is relative to
02:E4E8 08              	   889:             inx                         ; instr following branch
02:E4E9 2B12            	   890:             bmi brgodc                  ; branch if offset negative
02:E4EB 8D16            	   891: brg1:       bsr incx_                   ; increment x by amount in
                        	   892: ; a reg 
02:E4ED FF0317          	   893: brg2:       stx trcadr                  ; save address of next
                        	   894: ; instr to stop on 
02:E4F0 A600            	   895:             ldaa 0,x                    ; get instruction to be replaced
02:E4F2 B70319          	   896:             staa trcins                 ; save
02:E4F5 863F            	   897:             ldaa #swiop                 ; get swi op code
02:E4F7 A700            	   898:             staa 0,x                    ; replace instr with swi
02:E4F9 BE0308          	   899:             lds sp                      ; get original stack pointer
02:E4FC 3B              	   900:             rti                         ; trace another instr
                        	   901: ; 
                        	   902: ; x needs to be decremented (offset negative) 
                        	   903: ; 
02:E4FD 09              	   904: brgodc:     dex                         ; decrement address
02:E4FE 4C              	   905:             inca                        ; increment counter
02:E4FF 26FC            	   906:             bne brgodc                  ; if counter not 0, branch
02:E501 20EA            	   907:             bra brg2                    ; if done, go return to user prog
                        	   908: ; 
                        	   909: ; subroutine to increment x by contents of a 
                        	   910: ; 
02:E503 4D              	   911: incx_:      tsta                        ; is a = 0?
02:E504 2704            	   912:             beq incxr                   ; if so, inc done
02:E506 08              	   913: inxlp:      inx                         ; else increment x
02:E507 4A              	   914:             deca                        ; decrement count
02:E508 26FC            	   915:             bne inxlp                   ; if count not yet 0, loop
02:E50A 39              	   916: incxr:      rts                         ; return from this subroutine
                        	   917: ; 
                        	   918: ; instruction to be traced is not a branch 
                        	   919: ; 
02:E50B FE0317          	   920: ckobra:     ldx trcadr                  ; x : = trace address
02:E50E E600            	   921:             ldab 0,x                    ; get instr to be traced
02:E510 C16E            	   922:             cmpb #0x6e                  ; is it a jump, indexed?
02:E512 271A            	   923:             beq jmpidx                  ; yes, go simulate jump idxed
02:E514 C17E            	   924:             cmpb #0x7e                  ; jump, extended?
02:E516 271D            	   925:             beq jmpext
02:E518 C1AD            	   926:             cmpb #0xad                  ; jsr, indexed?
02:E51A 2712            	   927:             beq jmpidx                  ; (jump idxed is same as
                        	   928: ; transfer of control) 
02:E51C C1BD            	   929:             cmpb #0xbd                  ; jsr, extended?
02:E51E 2715            	   930:             beq jmpext
02:E520 C13B            	   931:             cmpb #0x3b                  ; rti?
02:E522 2715            	   932:             beq rtisim
02:E524 C139            	   933:             cmpb #0x39                  ; rts?
02:E526 2716            	   934:             beq rtssim
02:E528 C18D            	   935:             cmpb #0x8d                  ; bsr?
02:E52A 27B6            	   936:             beq brgo                    ; (branch processing)
                        	   937: ; 
                        	   938: ; not a branch, jump. rti, rts 
                        	   939: ; a register holds # bytes in instruction 
                        	   940: ; 
02:E52C 20BD            	   941:             bra brg1                    ; put in new swi and
                        	   942: ; trace next instruction 
                        	   943: ; 
                        	   944: ; jump, jsr indexed simulation 
                        	   945: ; 
02:E52E A601            	   946: jmpidx:     ldaa 1,x                    ; a : = address offset
02:E530 30              	   947:             tsx
02:E531 EE03            	   948:             ldx 3,x                     ; get targets x reg
02:E533 20B6            	   949:             bra brg1                    ; update x, trace next instr
                        	   950: ; 
                        	   951: ; jump, jsr extended 
                        	   952: ; 
02:E535 EE01            	   953: jmpext:     ldx 1,x                     ; get address to be jumped to
02:E537 20B4            	   954:             bra brg2                    ; go trace next instr.
                        	   955: ; 
                        	   956: ; rti encountered 
                        	   957: ; 
02:E539 30              	   958: rtisim:     tsx
02:E53A EE0C            	   959:             ldx 12,x                    ; get p-counter from stack
02:E53C 20AF            	   960:             bra brg2                    ; go trace next instr.
                        	   961: ; 
                        	   962: ; rts encountered 
                        	   963: ; 
02:E53E 30              	   964: rtssim:     tsx
02:E53F EE07            	   965:             ldx 7,x                     ; get return p-reg from stack
02:E541 20AA            	   966:             bra brg2                    ; go trace next instr
                        	   967: ; 
                        	   968: ; 
                        	   969: ; opbcyt 
                        	   970: ; 
                        	   971: ; this routine determines the # of bytes in an instruction 
                        	   972: ; given its op code. 
                        	   973: ; 
                        	   974: ; input: a holds the op code 
                        	   975: ; 
                        	   976: ; output: x holds the index of table element 
                        	   977: ; b not restored 
                        	   978: ; a holds # bytes in instruction 
                        	   979: ; except for branches in which case is negative 
                        	   980: ; 
                        	   981: ; 
                        	   982: ; 
                        	   983: opcbyt:
02:E543 16              	   984:             tab                         ; b:= op code
02:E544 44              	   985:             lsra
02:E545 44              	   986:             lsra
02:E546 44              	   987:             lsra                        ; put 4 upper bits of op code in
02:E547 44              	   988:             lsra                        ; lower 4 bits of a
                        	   989: ; 
02:E548 CEE561          	   990:             ldx #opbttb                 ; x:= address of table
02:E54B 8DB6            	   991:             bsr incx_                   ; increment x to point to correct
                        	   992: ; 
02:E54D A600            	   993:             ldaa 0,x                    ; get table entry
02:E54F 260F            	   994:             bne opbtrt                  ; if not 0 then no further
                        	   995: ; processing needed 
                        	   996: ; 
                        	   997: ; if top 4 bits = 8 or c, then there are two classes 
                        	   998: ; of instructions: 2 byte instructions and 
                        	   999: ; ce, 8c and 8e which are 3 byte instructions 
                        	  1000: ; 
02:E551 8602            	  1001:             ldaa #2                     ; # bytes in most of 8# instructions
02:E553 C18C            	  1002:             cmpb #0x8c                  ; 3 byte instruction?
02:E555 2708            	  1003:             beq opbt3                   ; yes, update a
02:E557 C1CE            	  1004:             cmpb #0xce                  ; 3 byte instr?
02:E559 2704            	  1005:             beq opbt3                   ; yes, update a
02:E55B C18E            	  1006:             cmpb #0x8e                  ; 3 byte instruction?
02:E55D 2601            	  1007:             bne opbtrt                  ; no, return
                        	  1008: ; 
02:E55F 4C              	  1009: opbt3:      inca                        ; # bytes in instruction:=3
                        	  1010: ; 
02:E560 39              	  1011: opbtrt:     rts                         ; return to caller
                        	  1012: ; 
                        	  1013: ; op code to number of bytes conversion table 
                        	  1014: ; 
                        	  1015: ; # bytes top 4 bits of opcode 
                        	  1016: ; ------- -------------------- 
                        	  1017: ; 
                        	  1018: opbttb:
02:E561 01              	  1019:             .byte 1                     ; 0
02:E562 01              	  1020:             .byte 1                     ; 1
02:E563 82              	  1021:             .byte 2+0b10000000          ; 2 ( minus=> branches )
02:E564 01              	  1022:             .byte 1                     ; 3
02:E565 01              	  1023:             .byte 1                     ; 4
02:E566 01              	  1024:             .byte 1                     ; 5
02:E567 02              	  1025:             .byte 2                     ; 6
02:E568 03              	  1026:             .byte 3                     ; 7
02:E569 00              	  1027:             .byte 0                     ; 8 # bytes=2 except 8c,8e
02:E56A 02              	  1028:             .byte 2                     ; 9
02:E56B 02              	  1029:             .byte 2                     ; a
02:E56C 03              	  1030:             .byte 3                     ; b
02:E56D 00              	  1031:             .byte 0                     ; c # bytes = 2 except ce
02:E56E 02              	  1032:             .byte 2                     ; d
02:E56F 02              	  1033:             .byte 2                     ; e
02:E570 03              	  1034:             .byte 3                     ; f
