02:E843 847F            	  1579:             anda #0x7f
02:E845 811B            	  1580:             cmpa #esc
02:E847 2708            	  1581:             beq mast3
02:E849 F60349          	  1582:             ldab stoppg                 ; get stopage
02:E84C F10350          	  1583:             cmpb h                      ; present page
02:E84F 26EA            	  1584:             bne mast1                   ; branch if not done
02:E851 8D9F            	  1585: mast3:      bsr trailr                  ; send trailerecord
02:E853 39              	  1586: mast2:      rts
