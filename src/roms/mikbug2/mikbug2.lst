F00:1194       *
F00:1195       * DUMPR BRINGS IN A DUMPAGE RECORD
F00:1196       *
F00:1197       *     RAM:  H, L (SCRATCH)
F00:1198       *     REGS: ACCA, ACCB (SCRATCH); IX (PERM)
F00:1199       *     EXIT: FALLS INTO CRCK
F00:1200       *
F00:1201       DUMPR  BSR    LDV      GET PAGE NUMBER
               S01:FFFFFFFFFFFFFDCD:  8D 2E
F00:1202              STAB   H        )
               S01:FFFFFFFFFFFFFDCF:  F7 A0 9C
F00:1203              CLR    L        ) LOAD IX!
               S01:FFFFFFFFFFFFFDD2:  7F A0 9E
F00:1204              LDX    H        )
               S01:FFFFFFFFFFFFFDD5:  FE A0 9C
F00:1205       DUM1   BSR    LDV
               S01:FFFFFFFFFFFFFDD8:  8D 23
F00:1206              BEQ    G2       OUT IFF ESCAPE
               S01:FFFFFFFFFFFFFDDA:  27 49
F00:1207              JSR    CL       CHECK, OR LOAD
               S01:FFFFFFFFFFFFFDDC:  BD A0 96
F00:1208              INX             STORAGE PTR
               S01:FFFFFFFFFFFFFDDF:  08
F00:1209              INC    L        BYTE COUNT
               S01:FFFFFFFFFFFFFDE0:  7C A0 9E
F00:1210              BNE    DUM1
               S01:FFFFFFFFFFFFFDE3:  26 F3
F00:1211              DEC    V        PAGE COUNT
               S01:FFFFFFFFFFFFFDE5:  7A A0 A6
F00:1212       * FALL INTO CRCK
F00:1213       *
F00:1214       * CRCK SHECKS THE CRC AND PRINT A CHAR
F00:1215       *
F00:1216       *     RAM:  Q, R, S, TOTCNT (FROM LOADBYTE)
F00:1217       *     REGS:  ACCA (SCRATCH, ACCB (FROM LOADBYTE)
F00:1218       *
F00:1219       CRCK   BSR    LDV      ) INPUT CRC CHARS
               S01:FFFFFFFFFFFFFDE8:  8D 13
F00:1220              BSR    LDV      )
               S01:FFFFFFFFFFFFFDEA:  8D 11
F00:1221              LDAA   R        CHECK CRC REGISTERS
               S01:FFFFFFFFFFFFFDEC:  B6 A0 A2
F00:1222              ORAA   S
               S01:FFFFFFFFFFFFFDEF:  BA A0 A4
F00:1223              BNE    CRCK1
               S01:FFFFFFFFFFFFFDF2:  26 04
F00:1224              LDAA   #'G'      PRINT G FOR GOOD CRC
               S01:FFFFFFFFFFFFFDF4:  86 47
F00:1225              BRA    CRCK2
               S01:FFFFFFFFFFFFFDF6:  20 02
F00:1226       CRCK1  LDAA   #'B'      PRINT B FOR BAD CRC
               S01:FFFFFFFFFFFFFDF8:  86 42
F00:1227       CRCK2  JMP    TTYO1    PRINT IT!
               S01:FFFFFFFFFFFFFDFA:  7E FF 78
