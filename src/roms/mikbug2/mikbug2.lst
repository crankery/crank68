02:E7F8 20F5            	  1530:             bra bytov1                  ; extra bits
                        	  1531: ; 
                        	  1532: ; dumpagerecord sends the start sequence, dumpage-type, 
                        	  1533: ; page number, 2048 bits data, and the crc characters 
                        	  1534: ; 
                        	  1535: ; ram: h, r, s (perm); l (scratch) 
                        	  1536: ; regs: acca, accb (destroyed), new ix 
                        	  1537: ; exit: acca = 0 
                        	  1538: ; 
02:E7FA 8DC3            	  1539: dumpag:     bsr preamb                  ; start a record
