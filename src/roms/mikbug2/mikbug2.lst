02:E3B3 20DD            	   659:             bra bkcon2                  ; continue loop
                        	   660: ; 
                        	   661: ; breaks are not in and address is non-zero. 
                        	   662: ; if function = -1 then swi's are to be put in. 
                        	   663: ; a holds function number, s holds address 
                        	   664: ; 
02:E3B5 4D              	   665: nobrin:     tsta                        ; is function = -1
02:E3B6 2ACD            	   666:             bpl bkcon1                  ; no, continue
                        	   667: ; 
02:E3B8 34              	   668:             des                         ; make address point to 1 less
02:E3B9 32              	   669:             pula                        ; get user instruction
02:E3BA A710            	   670:             staa 2*nbrbpt,x             ; save
02:E3BC 863F            	   671:             ldaa #swiop                 ; get swi op code
02:E3BE 36              	   672:             psha                        ; replace user instruction
02:E3BF 20D1            	   673:             bra bkcon2                  ; continue loop
                        	   674: ; 
                        	   675: ; function=0 brk addr not = 0, user's instr 
                        	   676: ; is in (not swi). 
                        	   677: ; if address = xhi,xlo then set address = 0 
02:E3C1 A600            	   678: fndrpl:     ldaa 0,x                    ; get top byte of address
02:E3C3 B1033E          	   679:             cmpa xhi                    ; do top bytes compare
02:E3C6 26CA            	   680:             bne bkcon2                  ; no,continue loop
02:E3C8 E601            	   681:             ldab 1,x                    ; get low byte of addr
02:E3CA F1033F          	   682:             cmpb xlow                   ; same for low bytes
02:E3CD 26C3            	   683:             bne bkcon2
                        	   684: ; 
02:E3CF 6F00            	   685: clrbrk:     clr 0,x                     ; clear out break
02:E3D1 6F01            	   686:             clr 1,x                     ; address field
02:E3D3 20BD            	   687:             bra bkcon2                  ; continue loop
                        	   688: ; 
