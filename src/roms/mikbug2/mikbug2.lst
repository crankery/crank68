                        	  1045: ; 
                        	  1046: ; 
                        	  1047: ; maximal software implementation of the 
                        	  1048: ; ritter-zettner standards 
                        	  1049: ; 
                        	  1050: ; copyright (c) 1977 motorola inc. and t. f. ritter 
                        	  1051: ; 
                        	  1052: ; commands for exortape 
                        	  1053: ; c l d s : 
                        	  1054: ; c - check tape 
                        	  1055: ; l - load from tape to memory 
                        	  1056: ; d - dump from memory to tape 
                        	  1057: ; s - set baud rate 
                        	  1058: ; 
                        	  1059: ; speed : 
                        	  1060: ; enter 04 08 12 16 20 
                        	  1061: ; 
                        	  1062: ; file id : 
                        	  1063: ; enter four hex characters 
                        	  1064: ; 
                        	  1065: ; startstop pages: 
                        	  1066: ; enter starting page, two hex characters 
                        	  1067: ; enter stoppage, two hex characters 
                        	  1068: ; 
                        	  1069: ; 
                        	  1070: ; 
                        	  1071: ; file specifications 
                        	  1072: ; alc := undefined bit; automatic level control 
                        	  1073: ; post := undefined bit; missing pulse protect 
                        	  1074: ; start sequence := 89afh 
                        	  1075: ; crc := cyclic redundency check bit; x16+x15+x2+x0 
                        	  1076: ; headerecord := (32 alc) (start sequence) (08h) 
                        	  1077: ; (16 file id) (8 # of good pages) (8 post) 
                        	  1078: ; trailerecord := (16 alc) (start sequence) 
                        	  1079: ; (20h) (8 # of bad pages) (8 post) 
                        	  1080: ; dumpagerecord := (16 alc) (start sequence) (10h) 
                        	  1081: ; (8 page #) (2048 data) (16 crc) (8 post) 
                        	  1082: ; charecord := (32 alc) (start sequence) (40h) 
                        	  1083: ; (8 length) (1-256 chars) (16 crc) (8 post) 
                        	  1084: ; otherecord := neither header nor trailer record 
                        	  1085: ; subfile := (headerecord) (0-n otherecords) 
                        	  1086: ; file := (1-n subfiles) (trailerecord) 
                        	  1087: ; 
                        	  1088: ; 
                        	  1089: ; data specifications 
                        	  1090: ; synchronous data; no start or stop bits 
                        	  1091: ; msb sent first (correct order on scope) 
                        	  1092: ; voice messages may be present between files 
                        	  1093: ; 
                        	  1094: ; 
                        	  1095: ; audio modulation specifications 
                        	  1096: ; double-frequency return-to-bias modulation 
                        	  1097: ; logic one = five element pattern: 0 1 0 1 0 
                        	  1098: ; logic zero = five element pattern 0 1 0 0 0 
                        	  1099: ; local el cheapo (realistic ctr-34) does 1200 baud 
                        	  1100: ; (data rate equals 1650 baud 2-stop async) 
                        	  1101: ; 0 erros in 2.6 million bits recovered 
                        	  1102: ; from memorex mrx2 
                        	  1103: ; 
                        	  1104: ; 
                        	  1105: ; audio hardware specifications 
                        	  1106: ; output from pia b2 through 11:1 voltage divider 
                        	  1107: ; (4.7k, 470) into mike jack 
                        	  1108: ; input from spkr jack, through dc-restoring 
                        	  1109: ; circuit and schmidtt trigger 
                        	  1110: ; (mc14583 preferred) into pia b0 
                        	  1111: ; recovered pulse phase matters, so use switch to 
                        	  1112: ; select phase -- both available from mc14583 
                        	  1113: ; 
                        	  1114: ;baud rates: 400 800 1200 1600 2000 
                        	  1115: ;equiv async: 550 1100 1650 2200 2750 
                        	  1116: ;element (usec): 500 250 167 125 100 
                        	  1117: ;totcnt: 35 1b 12 0d 0b 
                        	  1118: ;patdel: 50 26 18 11 0d 
                        	  1119: ; 
                        	  1120: ;system storage 
                        	  1121:             .equ ttycon, 0x8008         ; acia control
                        	  1122:             .equ tty, 0x8009            ; tty acia
                        	  1123:             .equ tp, 0x8004             ; tape port
                        	  1124:             .equ tacon, 0x8005          ; tape control
                        	  1125:             .equ esc, 0x1b              ; escape char
                        	  1126: ; 
                        	  1127: ; 
                        	  1128: ; 
                        	  1129: ; 
                        	  1130: ; 
                        	  1131:             .equ eot, 4
                        	  1132: ; 
                        	  1133: ; 
                        	  1134: ; messages 
                        	  1135: ; 
                        	  1136: ; 
