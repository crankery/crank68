02:E5D0 20
02:E5D1 04              	  1140:             .byte eot
02:E5D2 46494C452049443A	  1141: msg3:       .byte "FILE ID: "
02:E5DA 20
02:E5DB 04              	  1142:             .byte eot
02:E5DC 535441525453544F	  1143: msg4:       .byte "STARTSTOP PAGES: "
02:E5E4 502050414745533A
02:E5EC 20
02:E5ED 04              	  1144:             .byte eot
02:E5EE 53504545443A20  	  1145: msg5:       .byte "SPEED: "
