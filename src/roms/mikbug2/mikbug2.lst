               S01:FFFFFFFFFFFFFB5C:  33
F00:0685              LDX    TW
               S01:FFFFFFFFFFFFFB5D:  FE A0 80
F00:0686              DEX
               S01:FFFFFFFFFFFFFB60:  09
F00:0687              CPX    ENDA
               S01:FFFFFFFFFFFFFB61:  BC A0 08
F00:0688              BNE    PUN11
               S01:FFFFFFFFFFFFFB64:  26 B3
