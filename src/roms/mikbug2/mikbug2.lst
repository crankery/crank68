               S01:FFFFFFFFFFFFFC10:  C1 6E
F00:0834              BEQ    JMPIDX   YES, GO SIMULATE JUMP IDXED
               S01:FFFFFFFFFFFFFC12:  27 1A
F00:0835              CMPB   #$7E     JUMP, EXTENDED?
               S01:FFFFFFFFFFFFFC14:  C1 7E
F00:0836              BEQ    JMPEXT
               S01:FFFFFFFFFFFFFC16:  27 1D
F00:0837              CMPB   #$AD     JSR,  INDEXED?
               S01:FFFFFFFFFFFFFC18:  C1 AD
F00:0838              BEQ    JMPIDX   (JUMP IDXED IS SAME AS
               S01:FFFFFFFFFFFFFC1A:  27 12
F00:0839       *                       TRANSFER OF CONTROL)
F00:0840              CMPB   #$BD     JSR, EXTENDED?
               S01:FFFFFFFFFFFFFC1C:  C1 BD
F00:0841              BEQ    JMPEXT
               S01:FFFFFFFFFFFFFC1E:  27 15
F00:0842              CMPB   #$3B     RTI?
               S01:FFFFFFFFFFFFFC20:  C1 3B
F00:0843              BEQ    RTISIM
