02:E68F B7034D          	  1245: c12:        staa cl                     ; (store b indexed)
02:E692 7F034E          	  1246:             clr cll                     ; nop"zero displacement
02:E695 8639            	  1247:             ldaa #0x39                  ; insert rts
02:E697 B7034F          	  1248:             staa clll
                        	  1249: ; fall into getload 
                        	  1250: ; 
                        	  1251: ; getload searches for the desired file, 
                        	  1252: ; then loads it into ram 
                        	  1253: ; 
                        	  1254: ; ram: q, r, s, h, l (scratch) 
                        	  1255: ; totcnt, fidh, fidl (perm) 
                        	  1256: ; 
02:E69A BDE872          	  1257: getloa:     jsr lsetup                  ; set up pia
02:E69D 8D5E            	  1258:             bsr getfil                  ; search for correct file
02:E69F 2722            	  1259:             beq get4                    ; out iff escaped
02:E6A1 8D54            	  1260: get2:       bsr startv                  ; get the next record-type
02:E6A3 271E            	  1261:             beq get4                    ; out if escape
02:E6A5 C120            	  1262:             cmpb #0x20                  ; trailerecord?
02:E6A7 270A            	  1263:             beq get1
02:E6A9 C110            	  1264:             cmpb #0x10                  ; dumpagerecord?
02:E6AB 26F4            	  1265:             bne get2
02:E6AD 8D15            	  1266:             bsr dumpr                   ; bring it in!
02:E6AF 2712            	  1267:             beq get4                    ; out iff escape
02:E6B1 20EE            	  1268:             bra get2
02:E6B3 7D0356          	  1269: get1:       tst v                       ; check page count
02:E6B6 270B            	  1270:             beq get4
02:E6B8 2B04            	  1271:             bmi get3
02:E6BA 862D            	  1272:             ldaa #'-'                   ;  '-'  for missing page(s)
02:E6BC 2002            	  1273:             bra get5
02:E6BE 862B            	  1274: get3:       ldaa #'+'                   ;  '+'  for extra page(s)
02:E6C0 BDE175          	  1275: get5:       jsr outch                   ; print it!
02:E6C3 39              	  1276: get4:       rts                         ; return
                        	  1277: ; 
                        	  1278: ; dumpr brings in a dumpage record 
                        	  1279: ; 
                        	  1280: ; ram: h, l (scratch) 
                        	  1281: ; regs: acca, accb (scratch); ix (perm) 
                        	  1282: ; exit: falls into crck 
                        	  1283: ; 
02:E6C4 8D2E            	  1284: dumpr:      bsr ldv                     ; get page number
02:E6C6 F70350          	  1285:             stab h                      ; )
02:E6C9 7F0351          	  1286:             clr l                       ; ) load ix!
02:E6CC FE0350          	  1287:             ldx h                       ; )
02:E6CF 8D23            	  1288: dum1:       bsr ldv
02:E6D1 2749            	  1289:             beq g2                      ; out iff escape
02:E6D3 BD034D          	  1290:             jsr cl                      ; check, or load
02:E6D6 08              	  1291:             inx                         ; storage ptr
02:E6D7 7C0351          	  1292:             inc l                       ; byte count
02:E6DA 26F3            	  1293:             bne dum1
02:E6DC 7A0356          	  1294:             dec v                       ; page count
                        	  1295: ; fall into crck 
                        	  1296: ; 
                        	  1297: ; crck shecks the crc and print a char 
                        	  1298: ; 
                        	  1299: ; ram: q, r, s, totcnt (from loadbyte) 
                        	  1300: ; regs: acca (scratch, accb (from loadbyte) 
                        	  1301: ; 
02:E6DF 8D13            	  1302: crck:       bsr ldv                     ; ) input crc chars
02:E6E1 8D11            	  1303:             bsr ldv                     ; )
02:E6E3 B60354          	  1304:             ldaa r                      ; check crc registers
02:E6E6 BA0355          	  1305:             oraa s
02:E6E9 2604            	  1306:             bne crck1
02:E6EB 8647            	  1307:             ldaa #'G'                   ;  print g for good crc
02:E6ED 2002            	  1308:             bra crck2
02:E6EF 8642            	  1309: crck1:      ldaa #'B'                   ;  print b for bad crc
02:E6F1 7EE86F          	  1310: crck2:      jmp ttyo1                   ; print it!
02:E6F4 7EE866          	  1311: ldv:        jmp loadbv                  ; get a tape byte in accb
02:E6F7 2024            	  1312: startv:     bra startf
                        	  1313: ; 
                        	  1314: ; getfile looks for: 
                        	  1315: ; 1) a start sequence 
                        	  1316: ; 2) a headerecord type 
                        	  1317: ; 3) a file id match with fidh, fidl 
                        	  1318: ; and returns when found, or escaped 
                        	  1319: ; 
                        	  1320: ; regs: acca, accb (scratch only) 
                        	  1321: ; 
02:E6F9 8658            	  1322: g1:         ldaa #'X'                   ;  indicate wrong file found
02:E6FB 8DF4            	  1323:             bsr crck2                   ; send char to tty
02:E6FD 8D1E            	  1324: getfil:     bsr startf
02:E6FF 271B            	  1325:             beq g2                      ; out iff escape
02:E701 C108            	  1326:             cmpb #0x08                  ; headerecord-type?
02:E703 26F8            	  1327:             bne getfil                  ; branch if not
02:E705 8DED            	  1328:             bsr ldv                     ; get byte in accb
02:E707 F10346          	  1329:             cmpb fidh                   ; good file id(h)?
02:E70A 26ED            	  1330:             bne g1
02:E70C 8DE6            	  1331:             bsr ldv
02:E70E F10347          	  1332:             cmpb fidl                   ; good file id(l)?
02:E711 26E6            	  1333:             bne g1
02:E713 8648            	  1334:             ldaa #'H'                   ;  indicate header found
02:E715 8DDA            	  1335:             bsr crck2
02:E717 8DDB            	  1336:             bsr ldv
02:E719 F70356          	  1337:             stab v                      ; store page count
02:E71C 39              	  1338: g2:         rts
                        	  1339: ; 
                        	  1340: ; startfind looks for the 16-bit start sequence 89af 
                        	  1341: ; returns with the next byte, the record type, 
                        	  1342: ; in q and accb. 
                        	  1343: ; 
                        	  1344: ; ram: q, r, s, totcnt (perm), h (scratch) 
                        	  1345: ; regs: acca, accb (scratch only) 
                        	  1346: ; exit: falls into loadbyte, which 
                        	  1347: ; falls into loadbit, which 
                        	  1348: ; falls into crc 
                        	  1349: ; escape: esc in command port gets out 
                        	  1350: ; (test done in crc) 
                        	  1351: ; 
02:E71D 7F0350          	  1352: startf:     clr h                       ; accumulates 16 bits
02:E720 7F0352          	  1353:             clr q
02:E723 780352          	  1354: sta1:       asl q                       ; shift the 16-bit register
02:E726 790350          	  1355:             rol h
02:E729 8D24            	  1356:             bsr loadb1
02:E72B 27EF            	  1357:             beq g2                      ; out iff escaped
02:E72D B60350          	  1358:             ldaa h
02:E730 F60352          	  1359:             ldab q
02:E733 8189            	  1360:             cmpa #0x89                  ; start sequence
02:E735 26EC            	  1361:             bne sta1
02:E737 C1AF            	  1362:             cmpb #0xaf
02:E739 26E8            	  1363:             bne sta1
02:E73B 7F0354          	  1364: sta2:       clr r                       ; clear the crc register
02:E73E 7F0355          	  1365:             clr s
                        	  1366: ; fall into loadbyte to return a byte 
                        	  1367: ; 
                        	  1368: ; loadbyte recovers of data in q and accb, and does crc 
                        	  1369: ; 
                        	  1370: ; ram: q, r, s, totcnt (perm) 
                        	  1371: ; regs: acca, accb (scratch only) 
                        	  1372: ; exit: falls into loadbit, which 
                        	  1373: ; falls into crc 
                        	  1374: ; 
02:E741 C602            	  1375: loadby:     ldab #0x02                  ; set stop
02:E743 F70352          	  1376:             stab q
02:E746 8D07            	  1377: load1:      bsr loadb1
02:E748 27D2            	  1378:             beq g2                      ; out iff escape
02:E74A 780352          	  1379:             asl q                       ; stop into carry?
02:E74D 24F7            	  1380:             bcc load1                   ; branch if no
                        	  1381: ; fall into loadbit for last bit 
                        	  1382: ; 
                        	  1383: ; loadbit recovers one bit of data in q and accb, 
                        	  1384: ; and does crc in r and s 
                        	  1385: ; 
                        	  1386: ; ram: q, r, s, totcnt (perm) 
                        	  1387: ; regs: acca, accb (scratch only) 
                        	  1388: ; exit: branches or falls into crc routine 
                        	  1389: ; data bit goes into q lsb 
                        	  1390: ; 
02:E74F 5F              	  1391: loadb1:     clrb
02:E750 5A              	  1392: loadb6:     decb
02:E751 271F            	  1393:             beq loadb5
02:E753 8D43            	  1394:             bsr tain1v                  ; get tape data in carry
02:E755 25F9            	  1395:             bcs loadb6                  ; wait for low
02:E757 5A              	  1396: loadb2:     decb
02:E758 2718            	  1397:             beq loadb5
02:E75A 8D3C            	  1398:             bsr tain1v                  ; wait for high
02:E75C 24F9            	  1399:             bcc loadb2                  ; ) (front of sync el)
02:E75E F6034A          	  1400:             ldab totcnt                 ; 3.5 els delay
02:E761 5A              	  1401: loadb3:     decb
02:E762 270E            	  1402:             beq loadb5
02:E764 8D32            	  1403:             bsr tain1v                  ; ) wait for low
02:E766 25F9            	  1404:             bcs loadb3                  ; ) (end of sync el)
02:E768 5A              	  1405: loadb4:     decb
02:E769 2707            	  1406:             beq loadb5                  ; done yet?
02:E76B 8D2B            	  1407:             bsr tain1v
02:E76D 24F9            	  1408:             bcc loadb4
02:E76F 7C0352          	  1409:             inc q                       ; store a '1'  bit
02:E772 B60352          	  1410: loadb5:     ldaa q                      ; get data for crc
                        	  1411: ; fall into crc1 
                        	  1412: ; 
                        	  1413: ; crc enters a bit into crc registers r and s 
                        	  1414: ; uses crc polynomial: x16 + x15 + x2 + x0 
                        	  1415: ; 
                        	  1416: ; entry: acca holds new bit 
                        	  1417: ; ram: r, s (perm) 
                        	  1418: ; regs: acca, accb (scratch) 
                        	  1419: ; exit: accb = q, z = 1 iff esc 
                        	  1420: ; 
02:E775 46              	  1421: crc1:       rora                        ; lsb into carry
02:E776 46              	  1422:             rora                        ; carry into msb
02:E777 8480            	  1423: crc2:       anda #0x80                  ; mask msb (data bit)
02:E779 B80354          	  1424:             eora r                      ; enter data bit
02:E77C F60355          	  1425:             ldab s
02:E77F 58              	  1426:             aslb                        ; shift 16 bits left
02:E780 49              	  1427:             rola
02:E781 2404            	  1428:             bcc crc3                    ; if b16 high. . .
02:E783 8880            	  1429:             eora #0x80                  ; enter crc polynomial
02:E785 C805            	  1430:             eorb #0x05
02:E787 B70354          	  1431: crc3:       staa r
02:E78A F70355          	  1432:             stab s
02:E78D F60352          	  1433:             ldab q
02:E790 BDE86C          	  1434:             jsr ttyin1                  ; check for escape
02:E793 847F            	  1435:             anda #0x7f                  ; mask parity
02:E795 811B            	  1436:             cmpa #esc
02:E797 39              	  1437:             rts
02:E798 7EE860          	  1438: tain1v:     jmp tain1
                        	  1439: ; 
                        	  1440: ; byteout sends byte in acca to tape 
                        	  1441: ; 
                        	  1442: ; ram: r, s (changed in crc) 
                        	  1443: ; regs: acca, accb (destroyed) 
                        	  1444: ; exit: acca = 0, accb undefined 
                        	  1445: ; 
                        	  1446: ; acca = data byte (shifted) 
                        	  1447: ; accb = recording pattern (one bit) 
                        	  1448: ; 
02:E79B 36              	  1449: byteou:     psha                        ; save the data byte
02:E79C 8DD9            	  1450:             bsr crc2                    ; ) do the crc first
02:E79E 32              	  1451:             pula                        ; recover the data byte
02:E79F 0D              	  1452:             sec                         ; set stop
02:E7A0 49              	  1453:             rola                        ; data bit into carry
02:E7A1 2006            	  1454:             bra by2
02:E7A3 32              	  1455: by1:        pula                        ; recover from done test
02:E7A4 36              	  1456:             psha                        ; save shifting byte
02:E7A5 8DD0            	  1457:             bsr crc2
02:E7A7 32              	  1458:             pula                        ; recover shifting byte
02:E7A8 48              	  1459:             asla                        ; data bit into carry
02:E7A9 C60A            	  1460: by2:        ldab #0x0a                  ; recording pattern
02:E7AB BDE863          	  1461: by3:        jsr taou1                   ; send accb to tape
02:E7AE 37              	  1462:             pshb                        ; save pattern
02:E7AF F6034C          	  1463:             ldab patdel                 ; element delay
02:E7B2 5A              	  1464: by4:        decb
02:E7B3 26FD            	  1465:             bne by4                     ; branch if element not done
02:E7B5 33              	  1466:             pulb                        ; recover pattern
02:E7B6 59              	  1467:             rolb                        ; next element (data from carry)
02:E7B7 24F2            	  1468:             bcc by3                     ; branch if pattern not done
02:E7B9 36              	  1469:             psha                        ; save data byte before test
02:E7BA 48              	  1470:             asla                        ; test acca
02:E7BB 26E6            	  1471:             bne by1                     ; branch if byte not done
02:E7BD 31              	  1472: by5:        ins                         ; restore stack
02:E7BE 39              	  1473:             rts
                        	  1474: ; 
                        	  1475: ; preamble sends out alc bits, and the start sequence, 
                        	  1476: ; then inits the crc registers 
                        	  1477: ; 
                        	  1478: ; ram: r, s (changed) 
                        	  1479: ; regs: acca, accb (destroyed) 
                        	  1480: ; exit: acca = 0, accb undefined 
                        	  1481: ; 
02:E7BF 8D2E            	  1482: preamb:     bsr bytov1                  ; alc bits
02:E7C1 8D2C            	  1483:             bsr bytov1
02:E7C3 8689            	  1484:             ldaa #0x89                  ; start sequence (h)
02:E7C5 8D28            	  1485:             bsr bytov1
02:E7C7 86AF            	  1486:             ldaa #0xaf                  ; start sequence (l)
02:E7C9 8D24            	  1487:             bsr bytov1
02:E7CB 7F0354          	  1488:             clr r                       ; ) clear the crc registers
02:E7CE 7F0355          	  1489:             clr s                       ; )
02:E7D1 39              	  1490:             rts
                        	  1491: ; 
                        	  1492: ; headerecord sends alc bits, the start sequence, 
                        	  1493: ; headrecord-type, file id, and the number of 
                        	  1494: ; pages to be dumped 
                        	  1495: ; 
                        	  1496: ; ram: fidh, fidl (unmodified) 
                        	  1497: ; r, s (changed) 
                        	  1498: ; regs: acca, accb (destroyed) 
                        	  1499: ; exit: acca = 0, accb undefined 
                        	  1500: ; 
02:E7D2 8D1B            	  1501: header:     bsr bytov1                  ; alc bits
02:E7D4 8D19            	  1502:             bsr bytov1
02:E7D6 8DE7            	  1503:             bsr preamb                  ; start a record
02:E7D8 8608            	  1504:             ldaa #0x08                  ; headertype
02:E7DA 8D13            	  1505:             bsr bytov1
02:E7DC B60346          	  1506:             ldaa fidh                   ; file id(h)
02:E7DF 8D0E            	  1507:             bsr bytov1
02:E7E1 B60347          	  1508:             ldaa fidl                   ; file id(l)
02:E7E4 8D09            	  1509:             bsr bytov1
02:E7E6 B60349          	  1510:             ldaa stoppg                 ; stopage
02:E7E9 B00348          	  1511:             suba startp                 ; startpage
02:E7EC 4C              	  1512:             inca
02:E7ED 8D00            	  1513:             bsr bytov1                  ; send # pages
02:E7EF 7EE869          	  1514: bytov1:     jmp byteov                  ; extra bits
                        	  1515: ; 
                        	  1516: ; trailerecord sends a trailerecord to tape 
                        	  1517: ; 
                        	  1518: ; ram: r, s (perm) 
                        	  1519: ; regs: acca, abbc (destroyed) 
                        	  1520: ; 
02:E7F2 8DCB            	  1521: trailr:     bsr preamb                  ; start a record
02:E7F4 8620            	  1522:             ldaa #0x20                  ; trailerecord type
02:E7F6 8DF7            	  1523:             bsr bytov1
02:E7F8 20F5            	  1524:             bra bytov1                  ; extra bits
                        	  1525: ; 
                        	  1526: ; dumpagerecord sends the start sequence, dumpage-type, 
                        	  1527: ; page number, 2048 bits data, and the crc characters 
                        	  1528: ; 
                        	  1529: ; ram: h, r, s (perm); l (scratch) 
                        	  1530: ; regs: acca, accb (destroyed), new ix 
                        	  1531: ; exit: acca = 0 
                        	  1532: ; 
02:E7FA 8DC3            	  1533: dumpag:     bsr preamb                  ; start a record
02:E7FC 8610            	  1534:             ldaa #0x10                  ; dumpage type
02:E7FE 8DEF            	  1535:             bsr bytov1
