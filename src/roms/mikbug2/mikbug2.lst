F00:0962       *
F00:0963       *
F00:0964       * MAXIMAL SOFTWARE IMPLEMENTATION OF THE
F00:0965       *    RITTER-ZETTNER STANDARDS
F00:0966       *
F00:0967       * COPYRIGHT (C) 1977 MOTOROLA INC. AND T. F. RITTER
F00:0968       *
F00:0969       *      COMMANDS FOR EXORTAPE
F00:0970       * C L D S :
F00:0971       * C - CHECK TAPE
F00:0972       * L - LOAD FROM TAPE TO MEMORY
F00:0973       * D - DUMP FROM MEMORY TO TAPE
F00:0974       * S - SET BAUD RATE
F00:0975       *
F00:0976       * SPEED :
F00:0977       * ENTER 04 08 12 16 20
F00:0978       *
F00:0979       * FILE ID :
F00:0980       * ENTER FOUR HEX CHARACTERS
F00:0981       *
F00:0982       * STARTSTOP PAGES:
F00:0983       * ENTER STARTING PAGE, TWO HEX CHARACTERS
F00:0984       * ENTER STOPPAGE, TWO HEX CHARACTERS
F00:0985       *
F00:0986       *
F00:0987       *
F00:0988       *         FILE SPECIFICATIONS
F00:0989       * ALC := UNDEFINED BIT; AUTOMATIC LEVEL CONTROL
F00:0990       * POST := UNDEFINED BIT; MISSING PULSE PROTECT
F00:0991       * START SEQUENCE := 89AFH
F00:0992       * CRC := CYCLIC REDUNDENCY CHECK BIT; X16+X15+X2+X0
F00:0993       * HEADERECORD := (32 ALC) (START SEQUENCE) (08H)
F00:0994       *    (16 FILE ID) (8 # OF GOOD PAGES) (8 POST)
F00:0995       * TRAILERECORD := (16 ALC) (START SEQUENCE)
F00:0996       *    (20H) (8 # OF BAD PAGES) (8 POST)
F00:0997       * DUMPAGERECORD := (16 ALC) (START SEQUENCE) (10H)
F00:0998       *    (8 PAGE #) (2048 DATA) (16 CRC) (8 POST)
F00:0999       * CHARECORD := (32 ALC) (START SEQUENCE) (40H)
F00:1000       *    (8 LENGTH) (1-256 CHARS) (16 CRC) (8 POST)
F00:1001       * OTHERECORD := NEITHER HEADER NOR TRAILER RECORD
F00:1002       * SUBFILE := (HEADERECORD) (0-N OTHERECORDS)
F00:1003       * FILE := (1-N SUBFILES) (TRAILERECORD)
F00:1004       *
F00:1005       *
F00:1006       *         DATA SPECIFICATIONS
F00:1007       * SYNCHRONOUS DATA; NO START OR STOP BITS
F00:1008       * MSB SENT FIRST (CORRECT ORDER ON SCOPE)
F00:1009       * VOICE MESSAGES MAY BE PRESENT BETWEEN FILES
F00:1010       *
F00:1011       *
F00:1012       *         AUDIO MODULATION SPECIFICATIONS
F00:1013       * DOUBLE-FREQUENCY RETURN-TO-BIAS MODULATION
F00:1014       * LOGIC ONE = FIVE ELEMENT PATTERN: 0 1 0 1 0
F00:1015       * LOGIC ZERO = FIVE ELEMENT PATTERN 0 1 0 0 0
F00:1016       * LOCAL EL CHEAPO (REALISTIC CTR-34) DOES 1200 BAUD
F00:1017       *    (DATA RATE EQUALS 1650 BAUD 2-STOP ASYNC)
F00:1018       * 0 ERROS IN 2.6 MILLION BITS RECOVERED
F00:1019       * FROM MEMOREX MRX2
F00:1020       *
F00:1021       *
F00:1022       *         AUDIO HARDWARE SPECIFICATIONS
F00:1023       * OUTPUT FROM PIA B2 THROUGH 11:1 VOLTAGE DIVIDER
F00:1024       *    (4.7K, 470) INTO MIKE JACK
F00:1025       * INPUT FROM SPKR JACK, THROUGH DC-RESTORING
F00:1026       *    CIRCUIT AND SCHMIDTT TRIGGER
F00:1027       *    (MC14583 PREFERRED) INTO PIA B0
F00:1028       *  RECOVERED PULSE PHASE MATTERS, SO USE SWITCH TO
F00:1029       *     SELECT PHASE -- BOTH AVAILABLE FROM MC14583
F00:1030       *
F00:1031       *BAUD RATES:        400     800    1200    1600    2000
F00:1032       *EQUIV ASYNC:       550    1100    1650    2200    2750
F00:1033       *ELEMENT (USEC):    500     250     167     125     100
F00:1034       *TOTCNT:             35      1B      12      0D      0B    
F00:1035       *PATDEL:             50      26      18      11      0D
F00:1036       *
F00:1037       *SYSTEM STORAGE
F00:1038       TTYCON EQU    $8008    ACIA CONTROL
F00:1039       TTY    EQU    $8009    TTY ACIA
F00:1040       TP     EQU    $8004    TAPE PORT
F00:1041       TACON  EQU    $8005    TAPE CONTROL
F00:1042       ESC    EQU    $1B      ESCAPE CHAR
F00:1043       *
F00:1044       *
F00:1045       *
F00:1046       *
F00:1047       *
F00:1048       EOT    EQU    4
