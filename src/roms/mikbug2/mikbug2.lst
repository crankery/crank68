                        	    18: 
                        	    19:     .equ RAM_PTR, 0x0300
                        	    20: 
                        	    21:     .macro  ALLOC name, size
                        	    22:     .equ \name, RAM_PTR
                        	    23:     .equ RAM_PTR, RAM_PTR + \size
                        	    24:     .endm
                        	    25: 
                        	    26:     .equ nbrbpt, 8              ; # of breakpoints supported
