                        	   102: ; 
                        	   103: ; l load 
                        	   104: ; m memory change 
                        	   105: ; p print/punch dump 
                        	   106: ; r display contents of target stack 
                        	   107: ; cc b a x p s 
                        	   108: ; s 1,set speed for 10 cps 
                        	   109: ; 3,set speed for 30 cps 
                        	   110: ; b print out all breakpoints 
                        	   111: ; c continue execution from current location 
                        	   112: ; n next instruction 
                        	   113: ; t trace 'N' instructions 
                        	   114: ; g go to location 'N' 
                        	   115: ; d delete all breakpoints 
                        	   116: ; u reset breakpoint with address 'N' 
                        	   117: ; v set a breakpoint with address 'N' 
                        	   118: ; e exortape cassette interface 
                        	   119: ; 
                        	   120:             .equ swiop, 0x3f            ; swi op code
                        	   121: 
                        	   122:             .org 0xe000 ; slot 0
                        	   123: 
                        	   124:             .org 0xe010 ; slot 1
01:E010 00              	   125: acias:      .space 0x01
01:E011 00              	   126: aciad:      .space 0x01
                        	   127: 
                        	   128:             .org 0xe100
                        	   129: baseorg:    
                        	   130: 
