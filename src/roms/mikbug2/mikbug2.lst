02:E7C5 8D28            	  1491:             bsr bytov1
02:E7C7 86AF            	  1492:             ldaa #0xaf                  ; start sequence (l)
02:E7C9 8D24            	  1493:             bsr bytov1
02:E7CB 7F0351          	  1494:             clr r                       ; ) clear the crc registers
02:E7CE 7F0352          	  1495:             clr s                       ; )
02:E7D1 39              	  1496:             rts
