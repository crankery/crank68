               S01:FFFFFFFFFFFFFA5C:  BD F8 9E
F00:0467              LDX    #MCL3    PRINT HEADER
               S01:FFFFFFFFFFFFFA5F:  CE FC 98
F00:0468              JSR    PDATA1
               S01:FFFFFFFFFFFFFA62:  BD F8 7E
F00:0469       PSTAK  BSR    PRINT    PRINT STACK
               S01:FFFFFFFFFFFFFA65:  8D 7B
F00:0470       CNTRL2 JMP    CONTRL   RETURN TO COMMAND LEVEL
               S01:FFFFFFFFFFFFFA67:  7E F9 BA
F00:0471       **********
F00:0472       *
F00:0473       * BRKSUB
F00:0474       *
F00:0475       *
F00:0476       * THIS ROUTINE DOES A NUMBER OF OPERATIONS HAVING
F00:0477       * TO DO WITH BREAKPOINTS.
F00:0478       *
F00:0479       * THE A REGISTER DETERMINES FUNCTION PERFORMED:
F00:0480       *
F00:0481       * A = -1 => BREAKS ARE PUT INTO USER'S CODE
F00:0482       * A =  0 => THE BREAKPOINT WHOSE ADDRESS IS IN
F00:0483       *           XHI, XLO IS PURGED;
F00:0484       *           ALL BREAKPOINTS ARE TEMPORARILY REMOVED
F00:0485       * A =  1 => ALL BREAKPOINTS ARE PURGED
F00:0486       * A =  2 => ALL BREAKPOINTS ARE PRINTED OUT
F00:0487       *           ALL BREAKPOINTS ARE TEMPORARILY REMOVED
F00:0488       * A =  3 => ALL BREAKPOINTS ARE TEMPORARILY REMOVED
F00:0489       * A =  4 => THE BREAK ADDRESS IN XHI, XLO IS
F00:0490       *           PUT INTO THE FIRST ZERO BREAKPOINT
F00:0491       *           POSITION; ALL BREAKS ARE TEMPORARILY REMOVED
F00:0492       *
F00:0493       **********
F00:0494       *
F00:0495       BRKSUB EQU    *
F00:0496              STS    SSAVE    SAVE S SO WE CAN USE
               S01:FFFFFFFFFFFFFA6A:  BF A0 80
F00:0497              STAA   ASAVE    A HOLDS THE FUNCTION #
               S01:FFFFFFFFFFFFFA6D:  B7 A0 78
F00:0498       *
F00:0499              LDX    #BRKADR  INIT X FOR LOOP THROUGH BREAKS
               S01:FFFFFFFFFFFFFA70:  CE A0 38
F00:0500       *
F00:0501       * START OF LOOP THROUGH BREAK ADDRESSES
F00:0502       *
F00:0503       BRKLP  LDAA   ASAVE    GET FUNCTION #
               S01:FFFFFFFFFFFFFA73:  B6 A0 78
F00:0504              LDS    0,X      S:=NEXT ADDRESS IN BRRKPT LIST
               S01:FFFFFFFFFFFFFA76:  AE 00
F00:0505              BEQ    LN       IF 0, THEN NOT A VALID BREAK
               S01:FFFFFFFFFFFFFA78:  27 2D
F00:0506       *
F00:0507              TST    BRKSIN   ARE BREAKS IN USER'S CODE?
               S01:FFFFFFFFFFFFFA7A:  7D A0 84
F00:0508              BEQ    NOBRIN   BRANCH, IF NOT
               S01:FFFFFFFFFFFFFA7D:  27 36
F00:0509       *
F00:0510       * BREAKS ARE IN USER'S CODE
F00:0511       *
F00:0512              TSTA            SHOULD BREAKS BE IN?
               S01:FFFFFFFFFFFFFA7F:  4D
F00:0513              BMI    BKDONE   YES, RETURN TO CALLER
               S01:FFFFFFFFFFFFFA80:  2B 21
F00:0514       *
F00:0515       * BREAKS ARE TO BE TAKEN OUT OF USER'S
F00:0516       * CODE TEMPORARILY
F00:0517       *
F00:0518       BRK2   LDAA   2*NBRBPT,X GET INSTR. BELONG-
               S01:FFFFFFFFFFFFFA82:  A6 10
F00:0519       *                            ING IN USER CODE
F00:0520              PSHA            PUT IT THERE
               S01:FFFFFFFFFFFFFA84:  36
F00:0521       *
F00:0522       * OTHER LOOP ACTIONS TO BE PERFORMED EACH TIME THROUGH
F00:0523       * LOOP WHEN BREAK ADDRESS NOT EQUAL TO 0.
F00:0524       *
F00:0525       BKCON1 LDAA   ASAVE    WHAT FUNCTION IS TO BE DONE
               S01:FFFFFFFFFFFFFA85:  B6 A0 78
F00:0526              BEQ    FNDRPL   SEE IF BREAKPOINT NEEDS TO
               S01:FFFFFFFFFFFFFA88:  27 37
F00:0527       *                            BE REPLACED
F00:0528              CMPA   #1       IS BREAK ADDRESS TO BE RESET?
               S01:FFFFFFFFFFFFFA8A:  81 01
F00:0529              BEQ    CLRBRK   YES, SET BRKADR TO 0
               S01:FFFFFFFFFFFFFA8C:  27 41
F00:0530       *
F00:0531              CMPA   #2       IS BRK ADDR TO BE PRINTED?
               S01:FFFFFFFFFFFFFA8E:  81 02
F00:0532              BEQ    PRNTBK   YES, GO PRINT ADDRESS
               S01:FFFFFFFFFFFFFA90:  27 49
F00:0533       *
F00:0534       * UPDATE LOOP INDEX AND LOOP IF APPROPRIATE
F00:0535       *
F00:0536       BKCON2 INX             MAKE X POINT TO
               S01:FFFFFFFFFFFFFA92:  08
F00:0537              INX             NEXT BREAK ADDRESS
               S01:FFFFFFFFFFFFFA93:  08
F00:0538       BKCON3 CPX    #BRKINS  ANY MORE BREAKS?
               S01:FFFFFFFFFFFFFA94:  8C A0 58
F00:0539              BNE    BRKLP    YES,LOOP
               S01:FFFFFFFFFFFFFA97:  26 DA
F00:0540       *
F00:0541       * WRAP-UP PROCESSING AND EXIT
F00:0542       *
F00:0543              CLRA            A = BREAKS IN FLAG
               S01:FFFFFFFFFFFFFA99:  4F
F00:0544              TST    ASAVE    IS FUNCTION = -1?
               S01:FFFFFFFFFFFFFA9A:  7D A0 78
F00:0545              BPL    BKPUT    NO, SO BRKSIN = 0
               S01:FFFFFFFFFFFFFA9D:  2A 01
F00:0546              INCA            FCTN = -1 => BRKSIN:=1
               S01:FFFFFFFFFFFFFA9F:  4C
F00:0547       BKPUT  STAA   BRKSIN   STORE APPROPRIATE FLAG
               S01:FFFFFFFFFFFFFAA0:  B7 A0 84
F00:0548       *
F00:0549       * RESTORE S-REG AND RETURN TO CALLER
F00:0550       *
F00:0551       BKDONE LDS    SSAVE    RESTORE USER S-REG
               S01:FFFFFFFFFFFFFAA3:  BE A0 80
F00:0552              RTS             RETURN
               S01:FFFFFFFFFFFFFAA6:  39
F00:0553       *
F00:0554       *
F00:0555       * MISCELLANEOUS ROUTINES FOR BRKSUB
F00:0556       *
F00:0557       * BREAKPOINT ADDRESS = 0 - IF FUNCTION = 4 THEN
F00:0558       * PUT BREAKPOINT ADDRESS IN CURRENT POSITION
F00:0559       * A HOLDS THE FUNCTION #, X HOLDS BREAKPOINT INDEX
F00:0560       *
F00:0561       LN     CMPA   #4       IS FUNCTION = 4
               S01:FFFFFFFFFFFFFAA7:  81 04
F00:0562              BNE    BKCON2   IF NOT, THEN CONTINUE LOOP
               S01:FFFFFFFFFFFFFAA9:  26 E7
F00:0563       *
F00:0564              LDS    XHI      GET NEW BREAK ADDRESS
               S01:FFFFFFFFFFFFFAAB:  BE A0 7C
F00:0565              STS    0,X      PUT IN CURRENT POSITION
               S01:FFFFFFFFFFFFFAAE:  AF 00
F00:0566       *
F00:0567              DEC    ASAVE    DO NOT PLACE ADDRESS MORE
               S01:FFFFFFFFFFFFFAB0:  7A A0 78
F00:0568       *                      THAN ONCE-CONT TO
F00:0569       *                      TAKE OUT BREAKPOINTS
F00:0570              BRA    BKCON2   CONTINUE LOOP
               S01:FFFFFFFFFFFFFAB3:  20 DD
F00:0571       *
F00:0572       * BREAKS ARE NOT IN AND ADDRESS IS NON-ZERO.
F00:0573       * IF FUNCTION = -1 THEN SWI'S ARE TO BE PUT IN.
F00:0574       * A HOLDS FUNCTION NUMBER, S HOLDS ADDRESS
F00:0575       *
F00:0576       NOBRIN TSTA            IS FUNCTION = -1
               S01:FFFFFFFFFFFFFAB5:  4D
F00:0577              BPL    BKCON1   NO, CONTINUE
               S01:FFFFFFFFFFFFFAB6:  2A CD
F00:0578       *
F00:0579              DES             MAKE ADDRESS POINT TO 1 LESS
               S01:FFFFFFFFFFFFFAB8:  34
F00:0580              PULA            GET USER INSTRUCTION
               S01:FFFFFFFFFFFFFAB9:  32
F00:0581              STAA   2*NBRBPT,X SAVE
               S01:FFFFFFFFFFFFFABA:  A7 10
F00:0582              LDAA   #SWI     GET SWI OP CODE
               S01:FFFFFFFFFFFFFABC:  86 3F
F00:0583              PSHA            REPLACE USER INSTRUCTION
               S01:FFFFFFFFFFFFFABE:  36
F00:0584              BRA    BKCON2   CONTINUE LOOP
               S01:FFFFFFFFFFFFFABF:  20 D1
F00:0585       *
F00:0586       * FUNCTION=0 BRK ADDR NOT = 0, USER'S INSTR
F00:0587       * IS IN (NOT SWI).
F00:0588       * IF ADDRESS = XHI,XLO THEN SET ADDRESS = 0
F00:0589       FNDRPL LDAA   0,X      GET TOP BYTE OF ADDRESS
               S01:FFFFFFFFFFFFFAC1:  A6 00
F00:0590              CMPA   XHI      DO TOP BYTES COMPARE
               S01:FFFFFFFFFFFFFAC3:  B1 A0 7C
F00:0591              BNE    BKCON2   NO,CONTINUE LOOP
               S01:FFFFFFFFFFFFFAC6:  26 CA
F00:0592              LDAB   1,X      GET LOW BYTE OF ADDR
               S01:FFFFFFFFFFFFFAC8:  E6 01
F00:0593              CMPB   XLOW     SAME FOR LOW BYTES
               S01:FFFFFFFFFFFFFACA:  F1 A0 7E
F00:0594              BNE    BKCON2
               S01:FFFFFFFFFFFFFACD:  26 C3
F00:0595       *
F00:0596       CLRBRK CLR    0,X      CLEAR OUT BREAK
               S01:FFFFFFFFFFFFFACF:  6F 00
F00:0597              CLR    1,X      ADDRESS FIELD
               S01:FFFFFFFFFFFFFAD1:  6F 01
F00:0598              BRA    BKCON2   CONTINUE LOOP
               S01:FFFFFFFFFFFFFAD3:  20 BD
F00:0599       *
F00:0600       *
F00:0601       OT2HS  JMP    OUT2HS
               S01:FFFFFFFFFFFFFAD5:  7E F8 CA
F00:0602       OT4HS  JMP    OUT4HS
               S01:FFFFFFFFFFFFFAD8:  7E F8 C8
F00:0603       *
F00:0604       *
F00:0605       * PRINT OUT BREAK ADDRESS
F00:0606       * FUNCTION = 2, BREAK ADDRESS NOT = 0, X = ADDRESS IN
F00:0607       *
F00:0608       PRNTBK LDS    SSAVE
               S01:FFFFFFFFFFFFFADB:  BE A0 80
F00:0609              BSR    OT4HS    OUTPUT ADDRESS AND SPACE
               S01:FFFFFFFFFFFFFADE:  8D F8
F00:0610              BRA    BKCON3   OUT4HS INCREMENTS X,
               S01:FFFFFFFFFFFFFAE0:  20 B2
F00:0611       *                      SO BYPAS 2 INX'S
F00:0612       *
F00:0613       * PRINT CONTENTS OF STACK
F00:0614       *
F00:0615       PRINT  JSR    PCRLF    PRINT CR LF
               S01:FFFFFFFFFFFFFAE2:  BD F8 9E
F00:0616              LDX    SP       PRINT OUT STACK
               S01:FFFFFFFFFFFFFAE5:  FE A0 10
F00:0617              INX
               S01:FFFFFFFFFFFFFAE8:  08
F00:0618              BSR    OT2HS    CONDITION CODES
               S01:FFFFFFFFFFFFFAE9:  8D EA
F00:0619              BSR    OT2HS    ACC-B
               S01:FFFFFFFFFFFFFAEB:  8D E8
F00:0620              BSR    OT2HS    ACC-A
               S01:FFFFFFFFFFFFFAED:  8D E6
F00:0621              BSR    OT4HS    X-REG
               S01:FFFFFFFFFFFFFAEF:  8D E7
F00:0622              BSR    OT4HS    P-COUNTER
               S01:FFFFFFFFFFFFFAF1:  8D E5
F00:0623              LDX    #SP
               S01:FFFFFFFFFFFFFAF3:  CE A0 10
F00:0624              BSR    OT4HS    STACK POINTER
               S01:FFFFFFFFFFFFFAF6:  8D E0
F00:0625              RTS
               S01:FFFFFFFFFFFFFAF8:  39
