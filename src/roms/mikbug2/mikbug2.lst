                        	  1625: ; 
                        	  1626: ; 
                        	  1627: ; 
                        	  1628: ; 
                        	  1629: ; unsigned multiply ----- 
                        	  1630: ; 
                        	  1631: ; this routine multiplies the unsigned number in the 
                        	  1632: ; a register with the unsigned number in the b 
                        	  1633: ; register and puts the answers in the concatenated 
                        	  1634: ; a:b where a is the msb. the routine is 
                        	  1635: ; re-entrant and position independent as well 
                        	  1636: ; as being romable. the x register is destroyed 
                        	  1637: ; by the routine. 
                        	  1638: ; 
                        	  1639: ; during execution the stack contains: 
                        	  1640: ; 0,x = loop counter 
                        	  1641: ; 1,x = multiplier (b reg on entry) 
                        	  1642: ; 
                        	  1643: ; the algorithm used may not appear the fastest 
                        	  1644: ; on paper because it always requires 8 passes 
                        	  1645: ; the the loop but because of the fact all 
                        	  1646: ; calculations can be done in the registers it 
                        	  1647: ; is faster except for when the multiplicand 
                        	  1648: ; is very small (<10). the method is a shift and 
                        	  1649: ; add technique that begings with the ms bit 
                        	  1650: ; and works down to the ls bit. 
                        	  1651: ; 
                        	  1652: ; execution time: (29 + zeroes19 + ones26) cycles 
                        	  1653: ; where zeroes and ones are the 0'S AND 1's in 
                        	  1654: ; the a-reg on call. 
                        	  1655: ; 
                        	  1656: ; average execution time: 209 cycles 
                        	  1657: ; 
                        	  1658: ; 
                        	  1659: ; 
02:E889 37              	  1660: mul_:       pshb
02:E88A C608            	  1661:             ldab #8                     ; put counter on stack
02:E88C 37              	  1662:             pshb
02:E88D 30              	  1663:             tsx                         ; set x to point to stack
02:E88E 5F              	  1664:             clrb                        ; clear place to start answer
02:E88F 58              	  1665: ml1:        aslb                        ; shift ans 1 left and into a
02:E890 49              	  1666:             rola                        ; shift whats left of the multiplier
02:E891 2404            	  1667:             bcc ml2                     ; branch if no add needed
02:E893 EB01            	  1668:             addb 1,x                    ; add multiplier at this position
02:E895 8900            	  1669:             adca #0                     ; add carry to a if any
02:E897 6A00            	  1670: ml2:        dec 0,x                     ; done?
02:E899 26F4            	  1671:             bne ml1                     ; nope
02:E89B 31              	  1672:             ins                         ; yes,clean up the stack
02:E89C 31              	  1673:             ins
02:E89D 39              	  1674:             rts
                        	  1675: ; 
                        	  1676: ; 
                        	  1677: ; 
                        	  1678: ; signed multiply ----- 
                        	  1679: ; 
                        	  1680: ; this routine multiplies the two signed numbers in 
                        	  1681: ; the a and b registers and puts the signed 
                        	  1682: ; 16 bit answer in the concatenated a:b where 
                        	  1683: ; the a register is the msb. this routine destroys 
                        	  1684: ; the caller's x-register. 
                        	  1685: ; 
                        	  1686: ; during execution the stack contains: 
                        	  1687: ; 0,x = flag 
                        	  1688: ; 
                        	  1689: ; the routine is pure,re-entrant and position independent. 
                        	  1690: ; 
                        	  1691: ; the method use evaluates each argument and if it 
                        	  1692: ; is negative it is 2's complemented and the flag is 
                        	  1693: ; incremented. if after evaluating both arguments the 
                        	  1694: ; flag is even (0 or 2) then the answer will be positive, 
                        	  1695: ; else,the answer will need to be 2's complemented. 
                        	  1696: ; unsigned multiple routine is used to multiply the 
                        	  1697: ; corrected registers 
                        	  1698: ; 
                        	  1699: ; average executions times: 
                        	  1700: ; a-reg b-reg 
                        	  1701: ; + + 268 average 
                        	  1702: ; + - 283 average 
                        	  1703: ; - + 283 average 
                        	  1704: ; - - 286 average 
                        	  1705: ; 
                        	  1706: ; 
                        	  1707: ; 
                        	  1708: ; 
02:E89E 34              	  1709: smul:       des                         ; carve out a place on the stack f...
02:E89F 30              	  1710:             tsx                         ; get pointer to that place
02:E8A0 6F00            	  1711:             clr 0,x                     ; clear flag
02:E8A2 4D              	  1712:             tsta                        ; check multiplier
02:E8A3 2A03            	  1713:             bpl sml1                    ; positive, no comp. needed
02:E8A5 40              	  1714:             nega                        ; 2's comp. argument
02:E8A6 6C00            	  1715:             inc 0,x                     ; incr flag
02:E8A8 5D              	  1716: sml1:       tstb                        ; test other arg
02:E8A9 2A03            	  1717:             bpl sml2                    ; no comp needed
02:E8AB 50              	  1718:             negb
02:E8AC 6C00            	  1719:             inc 0,x                     ; incr flag
02:E8AE 8DD9            	  1720: sml2:       bsr mul_                    ; go do unsigned multiply
02:E8B0 30              	  1721:             tsx                         ; get back ptr to flag
02:E8B1 6600            	  1722:             ror 0,x                     ; see if flag is even or odd
02:E8B3 2404            	  1723:             bcc sml3                    ; even answer is okay 'cause its f...
02:E8B5 40              	  1724:             nega                        ; dbl precision 2's comp
02:E8B6 50              	  1725:             negb
02:E8B7 8200            	  1726:             sbca #0
02:E8B9 31              	  1727: sml3:       ins                         ; cleanup stack
02:E8BA 39              	  1728:             rts                         ; return to caller
                        	  1729: ; 
                        	  1730: ; 
                        	  1731: ; 
                        	  1732: ; postive divide ----- 
                        	  1733: ; 
                        	  1734: ; this routine divides the 16 bit positive dividend 
                        	  1735: ; in the a:b registers (a is the msb) by an 8 
                        	  1736: ; bit positive divisor pointed to by the x-register. 
                        	  1737: ; the quotient is in b on exit and the remainder 
                        	  1738: ; is in the a-register. the x-register is 
                        	  1739: ; destroyed. 
                        	  1740: ; if division by zero was attempted or the 
                        	  1741: ; quotient will not fit in 8 bits the overflow 
                        	  1742: ; bit is set on exit. also v is set if either 
                        	  1743: ; the dividend or the divisor is negative on call. 
                        	  1744: ; otherwise v is cleared. 
                        	  1745: ; 
                        	  1746: ; 
                        	  1747: ; the routing is pure,re-entrant and position independent. 
                        	  1748: ; 
                        	  1749: ; during execution the stack contains 
                        	  1750: ; 0,x = loop counter 
                        	  1751: ; 1,x = divisor 
                        	  1752: ; 2,x = dividend msb (only used for temp store) 
                        	  1753: ; 
                        	  1754: ; the method used is non restoring divide where the 
                        	  1755: ; dividend and divisor and known to be positive. this 
                        	  1756: ; method proved fastest since it can be carried out 
                        	  1757: ; essentially in the accumulators. the algorithm tries 
                        	  1758: ; to get the remainder as near zero as possible 
                        	  1759: ; and sometimes adds the divisor and sometimes 
                        	  1760: ; subtracts it depending on which side of zero the 
                        	  1761: ; partial remainder resides at any time. for more 
                        	  1762: ; info read: 'AN ALGORITHM FOR NON RESTORING DIVISION' 
                        	  1763: ; s. sanyal ; 'COMPUTER DESIGN' / may 1997. 
                        	  1764: ; 
                        	  1765: ; execution time average (no overflows): 289 cycles 
                        	  1766: ; this time is relatively independent of the 
                        	  1767: ; calling values. 
                        	  1768: ; 
                        	  1769: ; 
                        	  1770: ; 
                        	  1771: ; 
02:E8BB 36              	  1772: div:        psha                        ; save dividend msb a second
02:E8BC A600            	  1773:             ldaa 0,x                    ; fetch the divisor
02:E8BE 2B29            	  1774:             bmi divov2                  ; negative divisor is a no-no
02:E8C0 36              	  1775:             psha                        ; push it
02:E8C1 8608            	  1776:             ldaa #8                     ; push loop ctr
02:E8C3 36              	  1777:             psha
02:E8C4 30              	  1778:             tsx                         ; point x to stack
02:E8C5 A602            	  1779:             ldaa 2,x                    ; restore original dividend msb
02:E8C7 A101            	  1780:             cmpa 1,x                    ; will quotient overflow? (als d!
02:E8C9 241C            	  1781:             bcc divovf                  ; yes,go set v and exit
02:E8CB 58              	  1782: dloop:      aslb                        ; shift dividend-answer left
02:E8CC 49              	  1783:             rola
02:E8CD 2404            	  1784:             bcc dl2                     ; is dividend ms bit set?
02:E8CF AB01            	  1785:             adda 1,x                    ; yes,add divisor to msb
02:E8D1 2003            	  1786:             bra dl3
02:E8D3 A001            	  1787: dl2:        suba 1,x                    ; no,sub divisor from msb
02:E8D5 5C              	  1788:             incb                        ; set bit in result
02:E8D6 6A00            	  1789: dl3:        dec 0,x                     ; done?
02:E8D8 26F1            	  1790:             bne dloop                   ; no
02:E8DA 0D              	  1791:             sec                         ; shift a 1 in ls bit of quotient
02:E8DB 59              	  1792:             rolb                        ; case thats okay, correct latter
02:E8DC 4D              	  1793:             tsta                        ; is remainder negative?
02:E8DD 2A04            	  1794:             bpl dl4                     ; no,everything's okay
02:E8DF 5A              	  1795:             decb                        ; reset quotient ls bit
02:E8E0 AB01            	  1796:             adda 1,x                    ; add divisor to get + remainder
02:E8E2 0A              	  1797:             clv                         ; insure v is cleared
02:E8E3 31              	  1798: dl4:        ins                         ; clean up the stack
02:E8E4 31              	  1799:             ins
02:E8E5 31              	  1800:             ins
02:E8E6 39              	  1801:             rts                         ; return
                        	  1802: ; 
02:E8E7 31              	  1803: divovf:     ins                         ; clean up stack
02:E8E8 31              	  1804:             ins
02:E8E9 31              	  1805: divov2:     ins
02:E8EA 0B              	  1806:             sev                         ; set the overflow flag
02:E8EB 39              	  1807:             rts
