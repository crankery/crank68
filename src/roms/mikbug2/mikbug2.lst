02:E122 E337            	   157:             .word next
02:E124 50              	   158:             .byte "P"                   ; "P" - punch
02:E125 E402            	   159:             .word punch
02:E127 52              	   160:             .byte "R"                   ; "R" - print stack
02:E128 E35C            	   161:             .word pstak1
02:E12A 53              	   162:             .byte "S"                   ; "S" - change speed for tty
02:E12B E2FE            	   163:             .word spd
02:E12D 54              	   164:             .byte "T"                   ; "T" - trace n instructions
02:E12E E350            	   165:             .word trace
