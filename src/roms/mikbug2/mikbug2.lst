               S01:FFFFFFFFFFFFFB16:  FF A0 80
F00:0651       PUN11  LDAA   ENDA+1
               S01:FFFFFFFFFFFFFB19:  B6 A0 09
F00:0652              SUBA   TW+1
               S01:FFFFFFFFFFFFFB1C:  B0 A0 81
F00:0653              LDAB   ENDA
               S01:FFFFFFFFFFFFFB1F:  F6 A0 08
F00:0654              SBCB   TW
               S01:FFFFFFFFFFFFFB22:  F2 A0 80
F00:0655              BNE    PUN22
               S01:FFFFFFFFFFFFFB25:  26 04
F00:0656              CMPA   #16
               S01:FFFFFFFFFFFFFB27:  81 10
F00:0657              BCS    PUN23
               S01:FFFFFFFFFFFFFB29:  25 02
F00:0658       PUN22  LDAA   #15
               S01:FFFFFFFFFFFFFB2B:  86 0F
F00:0659       PUN23  ADDA   #4
               S01:FFFFFFFFFFFFFB2D:  8B 04
F00:0660              STAA   MCONT    FRAME COUNT THIS RECORD
               S01:FFFFFFFFFFFFFB2F:  B7 A0 7A
F00:0661              SUBA   #3
               S01:FFFFFFFFFFFFFB32:  80 03
