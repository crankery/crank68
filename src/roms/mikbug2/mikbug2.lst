F00:1490              LDAA   STARTP   GET STARTPAGE
               S01:FFFFFFFFFFFFFF3B:  B6 A0 8E
F00:1491              STAA   H        PRESENT PAGE
               S01:FFFFFFFFFFFFFF3E:  B7 A0 9C
F00:1492              DEC    H
               S01:FFFFFFFFFFFFFF41:  7A A0 9C
F00:1493       MAST1  INC    H
               S01:FFFFFFFFFFFFFF44:  7C A0 9C
F00:1494              BSR    DUMPAG
               S01:FFFFFFFFFFFFFF47:  8D BA
F00:1495              LDAA   TTY
               S01:FFFFFFFFFFFFFF49:  B6 80 09
F00:1496              ANDA   #$7F
               S01:FFFFFFFFFFFFFF4C:  84 7F
F00:1497              CMPA   #ESC
               S01:FFFFFFFFFFFFFF4E:  81 1B
F00:1498              BEQ    MAST3
               S01:FFFFFFFFFFFFFF50:  27 08
F00:1499              LDAB   STOPPG   GET STOPAGE
               S01:FFFFFFFFFFFFFF52:  F6 A0 90
F00:1500              CMPB   H        PRESENT PAGE
               S01:FFFFFFFFFFFFFF55:  F1 A0 9C
F00:1501              BNE    MAST1    BRANCH IF NOT DONE
               S01:FFFFFFFFFFFFFF58:  26 EA
F00:1502       MAST3  BSR    TRAILR   SEND TRAILERECORD
               S01:FFFFFFFFFFFFFF5A:  8D 9F
F00:1503       MAST2  RTS
               S01:FFFFFFFFFFFFFF5C:  39
F00:1504       SETUP  CLR    TACON    INTO DATA DIRECTION REG.
               S01:FFFFFFFFFFFFFF5D:  7F 80 05
F00:1505              LDAA   #$04     B2 AN OUTPUT, REST INPUTS
               S01:FFFFFFFFFFFFFF60:  86 04
F00:1506              STAA   TP       (ONLY B0 USED FOR INPUT)
               S01:FFFFFFFFFFFFFF62:  B7 80 04
F00:1507              STAA   TACON    BACK TO DATA REGISTER
               S01:FFFFFFFFFFFFFF65:  B7 80 05
F00:1508              RTS
               S01:FFFFFFFFFFFFFF68:  39
F00:1509       *
F00:1510       *  VECTORS- IN OTHER VERSIONS OF THIS TAPE
F00:1511       *   INTERFACE THESE VECTORS WILL BE IMPLEMENTED
F00:1512       *   IN RAM TO ALLOW THE USER ACCESS TO
F00:1513       *   THE TAPE SYSTEM.
F00:1514       *
F00:1515       TAIN1  JMP    TAIN2    TAPE IN PORT VECTOR
               S01:FFFFFFFFFFFFFF69:  7E FF 81
F00:1516       TAOU1  JMP    TAOU2    TAPE OUT PORT VECTOR
               S01:FFFFFFFFFFFFFF6C:  7E FF 8E
F00:1517       LOADBV JMP    LOADBY   TAPE BYTE IN VECTOR
               S01:FFFFFFFFFFFFFF6F:  7E FE 4A
F00:1518       BYTEOV JMP    BYTEOU   TAPE BYTE OUT VECTOR
               S01:FFFFFFFFFFFFFF72:  7E FE A4
F00:1519       TTYIN1 JMP    TTYIN2   CONTROL IN PORT VECTOR
               S01:FFFFFFFFFFFFFF75:  7E FF 86
F00:1520       TTYO1  JMP    TTYO2    CONTROL OUT PORT VECTOR
               S01:FFFFFFFFFFFFFF78:  7E FF 8A
F00:1521       LSETUP JMP    SETUP    TAPE OUT PIA INIT
               S01:FFFFFFFFFFFFFF7B:  7E FF 5D
F00:1522       DSETUP JMP    SETUP    TAPE IN PAI INIT
               S01:FFFFFFFFFFFFFF7E:  7E FF 5D
F00:1523       *
F00:1524       *
F00:1525       TAIN2  LDAA   TP       ACCA FROM TAPE
               S01:FFFFFFFFFFFFFF81:  B6 80 04
F00:1526              RORA            DATA BIT IN CARRY
               S01:FFFFFFFFFFFFFF84:  46
F00:1527              RTS
               S01:FFFFFFFFFFFFFF85:  39
F00:1528       TTYIN2 LDAA   TTY      ACCA FROM ACIA
               S01:FFFFFFFFFFFFFF86:  B6 80 09
F00:1529              RTS
               S01:FFFFFFFFFFFFFF89:  39
F00:1530       TTYO2  STAA   TTY      SEND ACCA TO ACIA
               S01:FFFFFFFFFFFFFF8A:  B7 80 09
F00:1531              RTS
               S01:FFFFFFFFFFFFFF8D:  39
F00:1532       TAOU2  STAB   TP       ACCB TO TAPE
               S01:FFFFFFFFFFFFFF8E:  F7 80 04
F00:1533              RTS
               S01:FFFFFFFFFFFFFF91:  39
