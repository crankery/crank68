02:E857 8604            	  1588:             ldaa #0x04                  ; b2 an output, rest inputs
02:E859 B78004          	  1589:             staa tp                     ; (only b0 used for input)
02:E85C B78005          	  1590:             staa tacon                  ; back to data register
