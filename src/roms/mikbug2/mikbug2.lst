                        	   802: ; 
02:E48E A600            	   803:             ldaa 0,x                    ; get instruction causing swi
02:E490 813F            	   804:             cmpa #swiop                 ; was it replaced by call to break
02:E492 260C            	   805:             bne brkinh                  ; yes, so must be a break
                        	   806: ; 
                        	   807: ; user swi-transfer through level 2 swi 
                        	   808: ; 
02:E494 30              	   809:             tsx                         ; x:=stack pointer
02:E495 6C06            	   810:             inc 6,x                     ; update low byte of p-counter
02:E497 2602            	   811:             bne incnov                  ; branch if no carry
02:E499 6C05            	   812:             inc 5,x                     ; update high byte if necessary
02:E49B FE030C          	   813: incnov:     ldx swi2                    ; x:=pointer to level 2 swi handler
02:E49E 6E00            	   814:             jmp 0,x                     ; go to level 2 handler
                        	   815: ; 
                        	   816: ; 
                        	   817: ; 
                        	   818: ; 
                        	   819: ; break interrupt handler 
                        	   820: ; 
                        	   821: brkinh:
02:E4A0 BDE3E2          	   822:             jsr print                   ; stop and show regs to user
02:E4A3 7EE2BA          	   823: ctrl:       jmp contrl                  ; return to control loop
                        	   824: ; 
                        	   825: ; trace interrupt handler 
                        	   826: ; p-counter has been decremented to point at swi 
                        	   827: ; trcins holds op code replaced by swi 
                        	   828: ; x hold address where trace swi is 
                        	   829: ; 
02:E4A6 B60319          	   830: trcinh:     ldaa trcins                 ; get op code of traced instr
02:E4A9 A700            	   831:             staa 0,x                    ; restore to user's code
                        	   832: ; 
02:E4AB 7D0343          	   833:             tst brktrc                  ; is processing to be
                        	   834: ; immediately continued? 
02:E4AE 270F            	   835:             beq nbktrc                  ; branch if not
                        	   836: ; 
                        	   837: ; processing is to 'CONTINUE' 
                        	   838: ; 
02:E4B0 7F0343          	   839:             clr brktrc                  ; reset continue flag
02:E4B3 86FF            	   840:             ldaa #0xff                  ; flag to set breaks in code
02:E4B5 BDE36A          	   841:             jsr brksub                  ; put breaks in
02:E4B8 7F0317          	   842:             clr trcadr                  ; no more trace, so clear address
02:E4BB 7F0318          	   843:             clr trcadr+1
02:E4BE 3B              	   844:             rti                         ; continue
                        	   845: ; 
                        	   846: ; trace is due to n or t trace commands 
                        	   847: ; 
02:E4BF BDE3E2          	   848: nbktrc:     jsr print                   ; print stack
02:E4C2 FE031A          	   849:             ldx ntrace                  ; get # instructions to trace
02:E4C5 09              	   850:             dex                         ; decrement count
02:E4C6 FF031A          	   851:             stx ntrace                  ; and restore
02:E4C9 27D8            	   852:             beq ctrl                    ; branch if all traces done
                        	   853: ; 
                        	   854: ; trace not done - trace next instruction 
                        	   855: ; 
02:E4CB B60319          	   856: contrc:     ldaa trcins                 ; get current instruction
02:E4CE B7030E          	   857:             staa brins                  ; save in case it's a branch
02:E4D1 8D70            	   858:             bsr opcbyt                  ; go get # bytes"type
02:E4D3 4D              	   859:             tsta                        ; check for branch
02:E4D4 2A35            	   860:             bpl ckobra                  ; check for other than branch
                        	   861: ; 
                        	   862: ; relative branch type instruction 
                        	   863: ; determine where to put swi 
                        	   864: ; s- holds pointer to user stack after swi 
02:E4D6 32              	   865:             pula                        ; get condition code
02:E4D7 34              	   866:             des                         ; update stack pointer after pull
02:E4D8 8A10            	   867:             oraa #0b00010000            ; make int's inhibited
02:E4DA 06              	   868:             tap                         ; restore user's c. code reg
02:E4DB 7E030E          	   869:             jmp brins                   ; go see how relative branch
                        	   870: ; fares 
                        	   871: ; 
                        	   872: ; branch was nogo - put swi at next instruction 
                        	   873: ; 
02:E4DE 8602            	   874: brnogo:     ldaa #2                     ; a = # bytes after current instr
02:E4E0 2029            	   875:             bra ckobra                  ; go put swi appropriately
                        	   876: ; 
                        	   877: ; branch was go, put swi at address being 
                        	   878: ; jumped to 
                        	   879: ; 
02:E4E2 FE0317          	   880: brgo:       ldx trcadr                  ; x : = trace address
02:E4E5 A601            	   881:             ldaa 1,x                    ; get branch offset
02:E4E7 08              	   882:             inx                         ; offset is relative to
02:E4E8 08              	   883:             inx                         ; instr following branch
02:E4E9 2B12            	   884:             bmi brgodc                  ; branch if offset negative
02:E4EB 8D16            	   885: brg1:       bsr incx_                   ; increment x by amount in
                        	   886: ; a reg 
02:E4ED FF0317          	   887: brg2:       stx trcadr                  ; save address of next
                        	   888: ; instr to stop on 
02:E4F0 A600            	   889:             ldaa 0,x                    ; get instruction to be replaced
02:E4F2 B70319          	   890:             staa trcins                 ; save
02:E4F5 863F            	   891:             ldaa #swiop                 ; get swi op code
02:E4F7 A700            	   892:             staa 0,x                    ; replace instr with swi
02:E4F9 BE0308          	   893:             lds sp                      ; get original stack pointer
02:E4FC 3B              	   894:             rti                         ; trace another instr
                        	   895: ; 
                        	   896: ; x needs to be decremented (offset negative) 
                        	   897: ; 
02:E4FD 09              	   898: brgodc:     dex                         ; decrement address
02:E4FE 4C              	   899:             inca                        ; increment counter
02:E4FF 26FC            	   900:             bne brgodc                  ; if counter not 0, branch
02:E501 20EA            	   901:             bra brg2                    ; if done, go return to user prog
                        	   902: ; 
                        	   903: ; subroutine to increment x by contents of a 
                        	   904: ; 
02:E503 4D              	   905: incx_:      tsta                        ; is a = 0?
02:E504 2704            	   906:             beq incxr                   ; if so, inc done
02:E506 08              	   907: inxlp:      inx                         ; else increment x
02:E507 4A              	   908:             deca                        ; decrement count
02:E508 26FC            	   909:             bne inxlp                   ; if count not yet 0, loop
02:E50A 39              	   910: incxr:      rts                         ; return from this subroutine
                        	   911: ; 
                        	   912: ; instruction to be traced is not a branch 
                        	   913: ; 
02:E50B FE0317          	   914: ckobra:     ldx trcadr                  ; x : = trace address
02:E50E E600            	   915:             ldab 0,x                    ; get instr to be traced
02:E510 C16E            	   916:             cmpb #0x6e                  ; is it a jump, indexed?
02:E512 271A            	   917:             beq jmpidx                  ; yes, go simulate jump idxed
02:E514 C17E            	   918:             cmpb #0x7e                  ; jump, extended?
02:E516 271D            	   919:             beq jmpext
02:E518 C1AD            	   920:             cmpb #0xad                  ; jsr, indexed?
02:E51A 2712            	   921:             beq jmpidx                  ; (jump idxed is same as
                        	   922: ; transfer of control) 
02:E51C C1BD            	   923:             cmpb #0xbd                  ; jsr, extended?
02:E51E 2715            	   924:             beq jmpext
02:E520 C13B            	   925:             cmpb #0x3b                  ; rti?
02:E522 2715            	   926:             beq rtisim
02:E524 C139            	   927:             cmpb #0x39                  ; rts?
02:E526 2716            	   928:             beq rtssim
02:E528 C18D            	   929:             cmpb #0x8d                  ; bsr?
02:E52A 27B6            	   930:             beq brgo                    ; (branch processing)
                        	   931: ; 
                        	   932: ; not a branch, jump. rti, rts 
                        	   933: ; a register holds # bytes in instruction 
                        	   934: ; 
02:E52C 20BD            	   935:             bra brg1                    ; put in new swi and
                        	   936: ; trace next instruction 
                        	   937: ; 
                        	   938: ; jump, jsr indexed simulation 
                        	   939: ; 
02:E52E A601            	   940: jmpidx:     ldaa 1,x                    ; a : = address offset
02:E530 30              	   941:             tsx
02:E531 EE03            	   942:             ldx 3,x                     ; get targets x reg
02:E533 20B6            	   943:             bra brg1                    ; update x, trace next instr
                        	   944: ; 
                        	   945: ; jump, jsr extended 
                        	   946: ; 
02:E535 EE01            	   947: jmpext:     ldx 1,x                     ; get address to be jumped to
02:E537 20B4            	   948:             bra brg2                    ; go trace next instr.
                        	   949: ; 
                        	   950: ; rti encountered 
                        	   951: ; 
02:E539 30              	   952: rtisim:     tsx
02:E53A EE0C            	   953:             ldx 12,x                    ; get p-counter from stack
02:E53C 20AF            	   954:             bra brg2                    ; go trace next instr.
                        	   955: ; 
                        	   956: ; rts encountered 
                        	   957: ; 
02:E53E 30              	   958: rtssim:     tsx
02:E53F EE07            	   959:             ldx 7,x                     ; get return p-reg from stack
02:E541 20AA            	   960:             bra brg2                    ; go trace next instr
                        	   961: ; 
                        	   962: ; 
                        	   963: ; opbcyt 
                        	   964: ; 
                        	   965: ; this routine determines the # of bytes in an instruction 
                        	   966: ; given its op code. 
                        	   967: ; 
                        	   968: ; input: a holds the op code 
                        	   969: ; 
                        	   970: ; output: x holds the index of table element 
                        	   971: ; b not restored 
                        	   972: ; a holds # bytes in instruction 
                        	   973: ; except for branches in which case is negative 
                        	   974: ; 
                        	   975: ; 
                        	   976: ; 
                        	   977: opcbyt:
02:E543 16              	   978:             tab                         ; b:= op code
02:E544 44              	   979:             lsra
02:E545 44              	   980:             lsra
02:E546 44              	   981:             lsra                        ; put 4 upper bits of op code in
02:E547 44              	   982:             lsra                        ; lower 4 bits of a
                        	   983: ; 
02:E548 CEE561          	   984:             ldx #opbttb                 ; x:= address of table
02:E54B 8DB6            	   985:             bsr incx_                   ; increment x to point to correct
                        	   986: ; 
02:E54D A600            	   987:             ldaa 0,x                    ; get table entry
02:E54F 260F            	   988:             bne opbtrt                  ; if not 0 then no further
                        	   989: ; processing needed 
                        	   990: ; 
                        	   991: ; if top 4 bits = 8 or c, then there are two classes 
                        	   992: ; of instructions: 2 byte instructions and 
                        	   993: ; ce, 8c and 8e which are 3 byte instructions 
                        	   994: ; 
02:E551 8602            	   995:             ldaa #2                     ; # bytes in most of 8# instructions
02:E553 C18C            	   996:             cmpb #0x8c                  ; 3 byte instruction?
02:E555 2708            	   997:             beq opbt3                   ; yes, update a
02:E557 C1CE            	   998:             cmpb #0xce                  ; 3 byte instr?
02:E559 2704            	   999:             beq opbt3                   ; yes, update a
02:E55B C18E            	  1000:             cmpb #0x8e                  ; 3 byte instruction?
02:E55D 2601            	  1001:             bne opbtrt                  ; no, return
                        	  1002: ; 
02:E55F 4C              	  1003: opbt3:      inca                        ; # bytes in instruction:=3
                        	  1004: ; 
02:E560 39              	  1005: opbtrt:     rts                         ; return to caller
                        	  1006: ; 
                        	  1007: ; op code to number of bytes conversion table 
                        	  1008: ; 
                        	  1009: ; # bytes top 4 bits of opcode 
                        	  1010: ; ------- -------------------- 
                        	  1011: ; 
                        	  1012: opbttb:
02:E561 01              	  1013:             .byte 1                     ; 0
02:E562 01              	  1014:             .byte 1                     ; 1
02:E563 82              	  1015:             .byte 2+0b10000000          ; 2 ( minus=> branches )
02:E564 01              	  1016:             .byte 1                     ; 3
02:E565 01              	  1017:             .byte 1                     ; 4
02:E566 01              	  1018:             .byte 1                     ; 5
02:E567 02              	  1019:             .byte 2                     ; 6
02:E568 03              	  1020:             .byte 3                     ; 7
02:E569 00              	  1021:             .byte 0                     ; 8 # bytes=2 except 8c,8e
02:E56A 02              	  1022:             .byte 2                     ; 9
02:E56B 02              	  1023:             .byte 2                     ; a
02:E56C 03              	  1024:             .byte 3                     ; b
02:E56D 00              	  1025:             .byte 0                     ; c # bytes = 2 except ce
02:E56E 02              	  1026:             .byte 2                     ; d
02:E56F 02              	  1027:             .byte 2                     ; e
02:E570 03              	  1028:             .byte 3                     ; f
