               S01:FFFFFFFFFFFFFA08:  7E F8 47
F00:0395       *
F00:0396       *
F00:0397       * RESET ALL BREAKPOINTS
F00:0398       *
F00:0399       DELBRK LDAA   #1       RESET BREAKS FLAG
               S01:FFFFFFFFFFFFFA0B:  86 01
F00:0400       BSRBRK BSR    BRKSUB   BREAK HANDLING SUBR.
               S01:FFFFFFFFFFFFFA0D:  8D 5B
F00:0401              BRA    CNTRL2   RETURN TO COMMAND LEVEL
               S01:FFFFFFFFFFFFFA0F:  20 56
F00:0402       *
F00:0403       * RESET 1 BREAKPOINT
F00:0404       *
F00:0405       RSTBRK BSR    BADDRJ   PUTS USER ENTERED ADDRESS
               S01:FFFFFFFFFFFFFA11:  8D F5
F00:0406       *                            INTO XHI,XLO
F00:0407              CLRA            RESET 1 BREAK FLAG
               S01:FFFFFFFFFFFFFA13:  4F
F00:0408              BRA    BSRBRK   GO RESET 1
               S01:FFFFFFFFFFFFFA14:  20 F7
F00:0409       *
F00:0410       * PRINT OUT ALL NON-ZERO BREAK ADDRESSES
