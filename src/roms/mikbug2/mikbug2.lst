02:E664 B6034D          	  1225:             ldaa t1
02:E667 8144            	  1226:             cmpa #'D'                   ;  dump mode?
02:E669 2611            	  1227:             bne tin7
02:E66B CEE5DC          	  1228:             ldx #msg4                   ; send start"stop prompt
02:E66E 8D89            	  1229:             bsr pdat1p
02:E670 BDE147          	  1230:             jsr baddr
02:E673 FF0348          	  1231:             stx startp
02:E676 BDE19E          	  1232:             jsr pcrlf
02:E679 7EE82E          	  1233:             jmp master
02:E67C 8143            	  1234: tin7:       cmpa #'C'                   ;  check mode?
02:E67E 2709            	  1235:             beq check
02:E680 814C            	  1236:             cmpa #'L'                   ;  check for load
02:E682 2709            	  1237:             beq load2
02:E684 7EE601          	  1238:             jmp err
                        	  1239: ; 
                        	  1240: ; fall into load 
02:E687 2004            	  1241: loadv:      bra load2
