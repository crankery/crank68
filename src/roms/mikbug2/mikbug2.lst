                        	   561: ; 
                        	   562: ; brksub 
                        	   563: ; 
                        	   564: ; 
                        	   565: ; this routine does a number of operations having 
                        	   566: ; to do with breakpoints. 
                        	   567: ; 
                        	   568: ; the a register determines function performed: 
                        	   569: ; 
                        	   570: ; a = -1 => breaks are put into user's code 
                        	   571: ; a = 0 => the breakpoint whose address is in 
                        	   572: ; xhi, xlo is purged; 
                        	   573: ; all breakpoints are temporarily removed 
                        	   574: ; a = 1 => all breakpoints are purged 
                        	   575: ; a = 2 => all breakpoints are printed out 
                        	   576: ; all breakpoints are temporarily removed 
                        	   577: ; a = 3 => all breakpoints are temporarily removed 
                        	   578: ; a = 4 => the break address in xhi, xlo is 
                        	   579: ; put into the first zero breakpoint 
                        	   580: ; position; all breaks are temporarily removed 
                        	   581: ; 
                        	   582: ; 
                        	   583: ; 
                        	   584: brksub:
02:E36A BF0340          	   585:             sts ssave                   ; save s so we can use
02:E36D B7033C          	   586:             staa asave                  ; a holds the function #
                        	   587: ; 
02:E370 CE031C          	   588:             ldx #brkadr                 ; init x for loop through breaks
                        	   589: ; 
                        	   590: ; start of loop through break addresses 
                        	   591: ; 
02:E373 B6033C          	   592: brklp:      ldaa asave                  ; get function #
02:E376 AE00            	   593:             lds 0,x                     ; s:=next address in brrkpt list
02:E378 272D            	   594:             beq ln                      ; if 0, then not a valid break
                        	   595: ; 
02:E37A 7D0342          	   596:             tst brksin                  ; are breaks in user's code?
02:E37D 2736            	   597:             beq nobrin                  ; branch, if not
                        	   598: ; 
                        	   599: ; breaks are in user's code 
                        	   600: ; 
02:E37F 4D              	   601:             tsta                        ; should breaks be in?
02:E380 2B21            	   602:             bmi bkdone                  ; yes, return to caller
                        	   603: ; 
                        	   604: ; breaks are to be taken out of user's 
                        	   605: ; code temporarily 
                        	   606: ; 
02:E382 A610            	   607: brk2:       ldaa 2*nbrbpt,x             ; get instr. belong-
                        	   608: ; ing in user code 
02:E384 36              	   609:             psha                        ; put it there
                        	   610: ; 
                        	   611: ; other loop actions to be performed each time through 
                        	   612: ; loop when break address not equal to 0. 
                        	   613: ; 
02:E385 B6033C          	   614: bkcon1:     ldaa asave                  ; what function is to be done
02:E388 2737            	   615:             beq fndrpl                  ; see if breakpoint needs to
                        	   616: ; be replaced 
02:E38A 8101            	   617:             cmpa #1                     ; is break address to be reset?
02:E38C 2741            	   618:             beq clrbrk                  ; yes, set brkadr to 0
                        	   619: ; 
02:E38E 8102            	   620:             cmpa #2                     ; is brk addr to be printed?
02:E390 2749            	   621:             beq prntbk                  ; yes, go print address
                        	   622: ; 
                        	   623: ; update loop index and loop if appropriate 
                        	   624: ; 
02:E392 08              	   625: bkcon2:     inx                         ; make x point to
02:E393 08              	   626:             inx                         ; next break address
02:E394 8C032C          	   627: bkcon3:     cpx #brkins                 ; any more breaks?
02:E397 26DA            	   628:             bne brklp                   ; yes,loop
                        	   629: ; 
                        	   630: ; wrap-up processing and exit 
                        	   631: ; 
02:E399 4F              	   632:             clra                        ; a = breaks in flag
02:E39A 7D033C          	   633:             tst asave                   ; is function = -1?
02:E39D 2A01            	   634:             bpl bkput                   ; no, so brksin = 0
02:E39F 4C              	   635:             inca                        ; fctn = -1 => brksin:=1
02:E3A0 B70342          	   636: bkput:      staa brksin                 ; store appropriate flag
                        	   637: ; 
                        	   638: ; restore s-reg and return to caller 
                        	   639: ; 
02:E3A3 BE0340          	   640: bkdone:     lds ssave                   ; restore user s-reg
02:E3A6 39              	   641:             rts                         ; return
                        	   642: ; 
                        	   643: ; 
                        	   644: ; miscellaneous routines for brksub 
                        	   645: ; 
                        	   646: ; breakpoint address = 0 - if function = 4 then 
                        	   647: ; put breakpoint address in current position 
                        	   648: ; a holds the function #, x holds breakpoint index 
                        	   649: ; 
02:E3A7 8104            	   650: ln:         cmpa #4                     ; is function = 4
02:E3A9 26E7            	   651:             bne bkcon2                  ; if not, then continue loop
                        	   652: ; 
02:E3AB BE033E          	   653:             lds xhi                     ; get new break address
02:E3AE AF00            	   654:             sts 0,x                     ; put in current position
                        	   655: ; 
02:E3B0 7A033C          	   656:             dec asave                   ; do not place address more
                        	   657: ; than once-cont to 
