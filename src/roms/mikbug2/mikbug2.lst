                        	  1620: ; 
                        	  1621: ; 
                        	  1622: ; 
                        	  1623: ; unsigned multiply ----- 
                        	  1624: ; 
                        	  1625: ; this routine multiplies the unsigned number in the 
                        	  1626: ; a register with the unsigned number in the b 
                        	  1627: ; register and puts the answers in the concatenated 
                        	  1628: ; a:b where a is the msb. the routine is 
                        	  1629: ; re-entrant and position independent as well 
                        	  1630: ; as being romable. the x register is destroyed 
                        	  1631: ; by the routine. 
                        	  1632: ; 
                        	  1633: ; during execution the stack contains: 
                        	  1634: ; 0,x = loop counter 
                        	  1635: ; 1,x = multiplier (b reg on entry) 
                        	  1636: ; 
                        	  1637: ; the algorithm used may not appear the fastest 
                        	  1638: ; on paper because it always requires 8 passes 
                        	  1639: ; the the loop but because of the fact all 
                        	  1640: ; calculations can be done in the registers it 
                        	  1641: ; is faster except for when the multiplicand 
                        	  1642: ; is very small (<10). the method is a shift and 
                        	  1643: ; add technique that begings with the ms bit 
                        	  1644: ; and works down to the ls bit. 
                        	  1645: ; 
                        	  1646: ; execution time: (29 + zeroes19 + ones26) cycles 
                        	  1647: ; where zeroes and ones are the 0'S AND 1's in 
                        	  1648: ; the a-reg on call. 
                        	  1649: ; 
                        	  1650: ; average execution time: 209 cycles 
                        	  1651: ; 
                        	  1652: ; 
                        	  1653: ; 
02:E889 37              	  1654: mul_:       pshb
02:E88A C608            	  1655:             ldab #8                     ; put counter on stack
02:E88C 37              	  1656:             pshb
02:E88D 30              	  1657:             tsx                         ; set x to point to stack
02:E88E 5F              	  1658:             clrb                        ; clear place to start answer
02:E88F 58              	  1659: ml1:        aslb                        ; shift ans 1 left and into a
02:E890 49              	  1660:             rola                        ; shift whats left of the multiplier
02:E891 2404            	  1661:             bcc ml2                     ; branch if no add needed
02:E893 EB01            	  1662:             addb 1,x                    ; add multiplier at this position
02:E895 8900            	  1663:             adca #0                     ; add carry to a if any
02:E897 6A00            	  1664: ml2:        dec 0,x                     ; done?
02:E899 26F4            	  1665:             bne ml1                     ; nope
02:E89B 31              	  1666:             ins                         ; yes,clean up the stack
02:E89C 31              	  1667:             ins
02:E89D 39              	  1668:             rts
                        	  1669: ; 
                        	  1670: ; 
                        	  1671: ; 
                        	  1672: ; signed multiply ----- 
                        	  1673: ; 
                        	  1674: ; this routine multiplies the two signed numbers in 
                        	  1675: ; the a and b registers and puts the signed 
                        	  1676: ; 16 bit answer in the concatenated a:b where 
                        	  1677: ; the a register is the msb. this routine destroys 
                        	  1678: ; the caller's x-register. 
                        	  1679: ; 
                        	  1680: ; during execution the stack contains: 
                        	  1681: ; 0,x = flag 
                        	  1682: ; 
                        	  1683: ; the routine is pure,re-entrant and position independent. 
                        	  1684: ; 
                        	  1685: ; the method use evaluates each argument and if it 
                        	  1686: ; is negative it is 2's complemented and the flag is 
                        	  1687: ; incremented. if after evaluating both arguments the 
                        	  1688: ; flag is even (0 or 2) then the answer will be positive, 
                        	  1689: ; else,the answer will need to be 2's complemented. 
                        	  1690: ; unsigned multiple routine is used to multiply the 
                        	  1691: ; corrected registers 
                        	  1692: ; 
                        	  1693: ; average executions times: 
                        	  1694: ; a-reg b-reg 
                        	  1695: ; + + 268 average 
                        	  1696: ; + - 283 average 
                        	  1697: ; - + 283 average 
                        	  1698: ; - - 286 average 
                        	  1699: ; 
                        	  1700: ; 
                        	  1701: ; 
                        	  1702: ; 
02:E89E 34              	  1703: smul:       des                         ; carve out a place on the stack f...
02:E89F 30              	  1704:             tsx                         ; get pointer to that place
02:E8A0 6F00            	  1705:             clr 0,x                     ; clear flag
02:E8A2 4D              	  1706:             tsta                        ; check multiplier
02:E8A3 2A03            	  1707:             bpl sml1                    ; positive, no comp. needed
02:E8A5 40              	  1708:             nega                        ; 2's comp. argument
02:E8A6 6C00            	  1709:             inc 0,x                     ; incr flag
02:E8A8 5D              	  1710: sml1:       tstb                        ; test other arg
02:E8A9 2A03            	  1711:             bpl sml2                    ; no comp needed
02:E8AB 50              	  1712:             negb
02:E8AC 6C00            	  1713:             inc 0,x                     ; incr flag
02:E8AE 8DD9            	  1714: sml2:       bsr mul_                    ; go do unsigned multiply
02:E8B0 30              	  1715:             tsx                         ; get back ptr to flag
02:E8B1 6600            	  1716:             ror 0,x                     ; see if flag is even or odd
02:E8B3 2404            	  1717:             bcc sml3                    ; even answer is okay 'cause its f...
02:E8B5 40              	  1718:             nega                        ; dbl precision 2's comp
02:E8B6 50              	  1719:             negb
02:E8B7 8200            	  1720:             sbca #0
02:E8B9 31              	  1721: sml3:       ins                         ; cleanup stack
02:E8BA 39              	  1722:             rts                         ; return to caller
                        	  1723: ; 
                        	  1724: ; 
                        	  1725: ; 
                        	  1726: ; postive divide ----- 
                        	  1727: ; 
                        	  1728: ; this routine divides the 16 bit positive dividend 
                        	  1729: ; in the a:b registers (a is the msb) by an 8 
                        	  1730: ; bit positive divisor pointed to by the x-register. 
                        	  1731: ; the quotient is in b on exit and the remainder 
                        	  1732: ; is in the a-register. the x-register is 
                        	  1733: ; destroyed. 
                        	  1734: ; if division by zero was attempted or the 
                        	  1735: ; quotient will not fit in 8 bits the overflow 
                        	  1736: ; bit is set on exit. also v is set if either 
                        	  1737: ; the dividend or the divisor is negative on call. 
                        	  1738: ; otherwise v is cleared. 
                        	  1739: ; 
                        	  1740: ; 
                        	  1741: ; the routing is pure,re-entrant and position independent. 
                        	  1742: ; 
                        	  1743: ; during execution the stack contains 
                        	  1744: ; 0,x = loop counter 
                        	  1745: ; 1,x = divisor 
                        	  1746: ; 2,x = dividend msb (only used for temp store) 
                        	  1747: ; 
                        	  1748: ; the method used is non restoring divide where the 
                        	  1749: ; dividend and divisor and known to be positive. this 
                        	  1750: ; method proved fastest since it can be carried out 
                        	  1751: ; essentially in the accumulators. the algorithm tries 
                        	  1752: ; to get the remainder as near zero as possible 
                        	  1753: ; and sometimes adds the divisor and sometimes 
                        	  1754: ; subtracts it depending on which side of zero the 
                        	  1755: ; partial remainder resides at any time. for more 
                        	  1756: ; info read: 'AN ALGORITHM FOR NON RESTORING DIVISION' 
                        	  1757: ; s. sanyal ; 'COMPUTER DESIGN' / may 1997. 
                        	  1758: ; 
                        	  1759: ; execution time average (no overflows): 289 cycles 
                        	  1760: ; this time is relatively independent of the 
                        	  1761: ; calling values. 
                        	  1762: ; 
                        	  1763: ; 
                        	  1764: ; 
                        	  1765: ; 
02:E8BB 36              	  1766: div:        psha                        ; save dividend msb a second
02:E8BC A600            	  1767:             ldaa 0,x                    ; fetch the divisor
02:E8BE 2B29            	  1768:             bmi divov2                  ; negative divisor is a no-no
02:E8C0 36              	  1769:             psha                        ; push it
02:E8C1 8608            	  1770:             ldaa #8                     ; push loop ctr
02:E8C3 36              	  1771:             psha
02:E8C4 30              	  1772:             tsx                         ; point x to stack
02:E8C5 A602            	  1773:             ldaa 2,x                    ; restore original dividend msb
02:E8C7 A101            	  1774:             cmpa 1,x                    ; will quotient overflow? (als d!
02:E8C9 241C            	  1775:             bcc divovf                  ; yes,go set v and exit
02:E8CB 58              	  1776: dloop:      aslb                        ; shift dividend-answer left
02:E8CC 49              	  1777:             rola
02:E8CD 2404            	  1778:             bcc dl2                     ; is dividend ms bit set?
02:E8CF AB01            	  1779:             adda 1,x                    ; yes,add divisor to msb
02:E8D1 2003            	  1780:             bra dl3
02:E8D3 A001            	  1781: dl2:        suba 1,x                    ; no,sub divisor from msb
02:E8D5 5C              	  1782:             incb                        ; set bit in result
02:E8D6 6A00            	  1783: dl3:        dec 0,x                     ; done?
02:E8D8 26F1            	  1784:             bne dloop                   ; no
02:E8DA 0D              	  1785:             sec                         ; shift a 1 in ls bit of quotient
02:E8DB 59              	  1786:             rolb                        ; case thats okay, correct latter
02:E8DC 4D              	  1787:             tsta                        ; is remainder negative?
02:E8DD 2A04            	  1788:             bpl dl4                     ; no,everything's okay
02:E8DF 5A              	  1789:             decb                        ; reset quotient ls bit
02:E8E0 AB01            	  1790:             adda 1,x                    ; add divisor to get + remainder
02:E8E2 0A              	  1791:             clv                         ; insure v is cleared
02:E8E3 31              	  1792: dl4:        ins                         ; clean up the stack
02:E8E4 31              	  1793:             ins
02:E8E5 31              	  1794:             ins
02:E8E6 39              	  1795:             rts                         ; return
                        	  1796: ; 
02:E8E7 31              	  1797: divovf:     ins                         ; clean up stack
02:E8E8 31              	  1798:             ins
02:E8E9 31              	  1799: divov2:     ins
02:E8EA 0B              	  1800:             sev                         ; set the overflow flag
02:E8EB 39              	  1801:             rts
