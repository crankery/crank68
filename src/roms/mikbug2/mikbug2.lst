02:E494 30              	   815:             tsx                         ; x:=stack pointer
02:E495 6C06            	   816:             inc 6,x                     ; update low byte of p-counter
02:E497 2602            	   817:             bne incnov                  ; branch if no carry
02:E499 6C05            	   818:             inc 5,x                     ; update high byte if necessary
02:E49B FE030C          	   819: incnov:     ldx swi2                    ; x:=pointer to level 2 swi handler
02:E49E 6E00            	   820:             jmp 0,x                     ; go to level 2 handler
                        	   821: ; 
