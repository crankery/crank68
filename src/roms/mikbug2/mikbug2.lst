                        	  1051: ; 
                        	  1052: ; 
                        	  1053: ; maximal software implementation of the 
                        	  1054: ; ritter-zettner standards 
                        	  1055: ; 
                        	  1056: ; copyright (c) 1977 motorola inc. and t. f. ritter 
                        	  1057: ; 
                        	  1058: ; commands for exortape 
                        	  1059: ; c l d s : 
                        	  1060: ; c - check tape 
                        	  1061: ; l - load from tape to memory 
                        	  1062: ; d - dump from memory to tape 
                        	  1063: ; s - set baud rate 
                        	  1064: ; 
                        	  1065: ; speed : 
                        	  1066: ; enter 04 08 12 16 20 
                        	  1067: ; 
                        	  1068: ; file id : 
                        	  1069: ; enter four hex characters 
                        	  1070: ; 
                        	  1071: ; startstop pages: 
                        	  1072: ; enter starting page, two hex characters 
                        	  1073: ; enter stoppage, two hex characters 
                        	  1074: ; 
                        	  1075: ; 
                        	  1076: ; 
                        	  1077: ; file specifications 
                        	  1078: ; alc := undefined bit; automatic level control 
                        	  1079: ; post := undefined bit; missing pulse protect 
                        	  1080: ; start sequence := 89afh 
                        	  1081: ; crc := cyclic redundency check bit; x16+x15+x2+x0 
                        	  1082: ; headerecord := (32 alc) (start sequence) (08h) 
                        	  1083: ; (16 file id) (8 # of good pages) (8 post) 
                        	  1084: ; trailerecord := (16 alc) (start sequence) 
                        	  1085: ; (20h) (8 # of bad pages) (8 post) 
                        	  1086: ; dumpagerecord := (16 alc) (start sequence) (10h) 
                        	  1087: ; (8 page #) (2048 data) (16 crc) (8 post) 
                        	  1088: ; charecord := (32 alc) (start sequence) (40h) 
                        	  1089: ; (8 length) (1-256 chars) (16 crc) (8 post) 
                        	  1090: ; otherecord := neither header nor trailer record 
                        	  1091: ; subfile := (headerecord) (0-n otherecords) 
                        	  1092: ; file := (1-n subfiles) (trailerecord) 
                        	  1093: ; 
                        	  1094: ; 
                        	  1095: ; data specifications 
                        	  1096: ; synchronous data; no start or stop bits 
                        	  1097: ; msb sent first (correct order on scope) 
                        	  1098: ; voice messages may be present between files 
                        	  1099: ; 
                        	  1100: ; 
                        	  1101: ; audio modulation specifications 
                        	  1102: ; double-frequency return-to-bias modulation 
                        	  1103: ; logic one = five element pattern: 0 1 0 1 0 
                        	  1104: ; logic zero = five element pattern 0 1 0 0 0 
                        	  1105: ; local el cheapo (realistic ctr-34) does 1200 baud 
                        	  1106: ; (data rate equals 1650 baud 2-stop async) 
                        	  1107: ; 0 erros in 2.6 million bits recovered 
                        	  1108: ; from memorex mrx2 
                        	  1109: ; 
                        	  1110: ; 
                        	  1111: ; audio hardware specifications 
                        	  1112: ; output from pia b2 through 11:1 voltage divider 
                        	  1113: ; (4.7k, 470) into mike jack 
                        	  1114: ; input from spkr jack, through dc-restoring 
                        	  1115: ; circuit and schmidtt trigger 
                        	  1116: ; (mc14583 preferred) into pia b0 
                        	  1117: ; recovered pulse phase matters, so use switch to 
                        	  1118: ; select phase -- both available from mc14583 
                        	  1119: ; 
                        	  1120: ;baud rates: 400 800 1200 1600 2000 
                        	  1121: ;equiv async: 550 1100 1650 2200 2750 
                        	  1122: ;element (usec): 500 250 167 125 100 
                        	  1123: ;totcnt: 35 1b 12 0d 0b 
                        	  1124: ;patdel: 50 26 18 11 0d 
                        	  1125: ; 
                        	  1126: ;system storage 
                        	  1127:             .equ ttycon, 0x8008         ; acia control
                        	  1128:             .equ tty, 0x8009            ; tty acia
                        	  1129:             .equ tp, 0x8004             ; tape port
                        	  1130:             .equ tacon, 0x8005          ; tape control
                        	  1131:             .equ esc, 0x1b              ; escape char
                        	  1132: ; 
                        	  1133: ; 
                        	  1134: ; 
                        	  1135: ; 
                        	  1136: ; 
                        	  1137:             .equ eot, 4
                        	  1138: ; 
                        	  1139: ; 
                        	  1140: ; messages 
                        	  1141: ; 
                        	  1142: ; 
