               S01:FFFFFFFFFFFFFB34:  B7 A0 78
F00:0663       *       PUNCH C/R,L/F,NULLS,S,1
F00:0664              LDX    #MTAPE1
               S01:FFFFFFFFFFFFFB37:  CE FA F9
F00:0665              JSR    PDATA1
               S01:FFFFFFFFFFFFFB3A:  BD F8 7E
F00:0666              CLRB            ZERO CHECKSUM
               S01:FFFFFFFFFFFFFB3D:  5F
F00:0667       *     PUNCH FRAME COUNT
