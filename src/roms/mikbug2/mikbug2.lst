                        	   787: ; swi-1 software interrupt level 1 processing 
                        	   788: ; 
                        	   789: swi15:
02:E476 BF0308          	   790:             sts sp                      ; save user's sp
                        	   791: ; 
02:E479 8603            	   792:             ldaa #3
02:E47B BDE36A          	   793:             jsr brksub                  ; go take out all the breaks
                        	   794: ; 
