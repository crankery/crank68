02:E7D8 8608            	  1510:             ldaa #0x08                  ; headertype
02:E7DA 8D13            	  1511:             bsr bytov1
02:E7DC B60345          	  1512:             ldaa fidh                   ; file id(h)
02:E7DF 8D0E            	  1513:             bsr bytov1
02:E7E1 B60346          	  1514:             ldaa fidl                   ; file id(l)
02:E7E4 8D09            	  1515:             bsr bytov1
