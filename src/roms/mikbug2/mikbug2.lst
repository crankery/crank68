               S01:FFFFFFFFFFFFFB7B:  BD FA 6A
F00:0705       *
F00:0706       * DECREMENT P-COUNTER
F00:0707       *
F00:0708              TSX             X:=STACK POINTER - 1
               S01:FFFFFFFFFFFFFB7E:  30
F00:0709              TST    6,X      IF LOWER BYTE = 0 => BORROW
               S01:FFFFFFFFFFFFFB7F:  6D 06
F00:0710              BNE    SWI151   BRANCH IF BORROW NOT REQ'D
               S01:FFFFFFFFFFFFFB81:  26 02
F00:0711              DEC    5,X      DECREMENT UPPER BYTE
               S01:FFFFFFFFFFFFFB83:  6A 05
F00:0712       SWI151 DEC    6,X      DECREMENT LOWER BYTE
               S01:FFFFFFFFFFFFFB85:  6A 06
F00:0713       *
