                        	   554: ; 
                        	   555: ; 
                        	   556: ; brksub 
                        	   557: ; 
                        	   558: ; 
                        	   559: ; this routine does a number of operations having 
                        	   560: ; to do with breakpoints. 
                        	   561: ; 
                        	   562: ; the a register determines function performed: 
                        	   563: ; 
                        	   564: ; a = -1 => breaks are put into user's code 
                        	   565: ; a = 0 => the breakpoint whose address is in 
                        	   566: ; xhi, xlo is purged; 
                        	   567: ; all breakpoints are temporarily removed 
                        	   568: ; a = 1 => all breakpoints are purged 
                        	   569: ; a = 2 => all breakpoints are printed out 
                        	   570: ; all breakpoints are temporarily removed 
                        	   571: ; a = 3 => all breakpoints are temporarily removed 
                        	   572: ; a = 4 => the break address in xhi, xlo is 
                        	   573: ; put into the first zero breakpoint 
                        	   574: ; position; all breaks are temporarily removed 
                        	   575: ; 
                        	   576: ; 
                        	   577: ; 
                        	   578: brksub:
02:E36A BF0340          	   579:             sts ssave                   ; save s so we can use
02:E36D B7033C          	   580:             staa asave                  ; a holds the function #
                        	   581: ; 
02:E370 CE031C          	   582:             ldx #brkadr                 ; init x for loop through breaks
                        	   583: ; 
                        	   584: ; start of loop through break addresses 
                        	   585: ; 
02:E373 B6033C          	   586: brklp:      ldaa asave                  ; get function #
02:E376 AE00            	   587:             lds 0,x                     ; s:=next address in brrkpt list
02:E378 272D            	   588:             beq ln                      ; if 0, then not a valid break
                        	   589: ; 
02:E37A 7D0342          	   590:             tst brksin                  ; are breaks in user's code?
02:E37D 2736            	   591:             beq nobrin                  ; branch, if not
                        	   592: ; 
                        	   593: ; breaks are in user's code 
                        	   594: ; 
02:E37F 4D              	   595:             tsta                        ; should breaks be in?
02:E380 2B21            	   596:             bmi bkdone                  ; yes, return to caller
                        	   597: ; 
                        	   598: ; breaks are to be taken out of user's 
                        	   599: ; code temporarily 
                        	   600: ; 
02:E382 A610            	   601: brk2:       ldaa 2*nbrbpt,x             ; get instr. belong-
                        	   602: ; ing in user code 
02:E384 36              	   603:             psha                        ; put it there
                        	   604: ; 
                        	   605: ; other loop actions to be performed each time through 
                        	   606: ; loop when break address not equal to 0. 
                        	   607: ; 
02:E385 B6033C          	   608: bkcon1:     ldaa asave                  ; what function is to be done
02:E388 2737            	   609:             beq fndrpl                  ; see if breakpoint needs to
                        	   610: ; be replaced 
02:E38A 8101            	   611:             cmpa #1                     ; is break address to be reset?
02:E38C 2741            	   612:             beq clrbrk                  ; yes, set brkadr to 0
                        	   613: ; 
02:E38E 8102            	   614:             cmpa #2                     ; is brk addr to be printed?
02:E390 2749            	   615:             beq prntbk                  ; yes, go print address
                        	   616: ; 
                        	   617: ; update loop index and loop if appropriate 
                        	   618: ; 
02:E392 08              	   619: bkcon2:     inx                         ; make x point to
02:E393 08              	   620:             inx                         ; next break address
02:E394 8C032C          	   621: bkcon3:     cpx #brkins                 ; any more breaks?
02:E397 26DA            	   622:             bne brklp                   ; yes,loop
                        	   623: ; 
                        	   624: ; wrap-up processing and exit 
                        	   625: ; 
02:E399 4F              	   626:             clra                        ; a = breaks in flag
02:E39A 7D033C          	   627:             tst asave                   ; is function = -1?
02:E39D 2A01            	   628:             bpl bkput                   ; no, so brksin = 0
02:E39F 4C              	   629:             inca                        ; fctn = -1 => brksin:=1
02:E3A0 B70342          	   630: bkput:      staa brksin                 ; store appropriate flag
                        	   631: ; 
                        	   632: ; restore s-reg and return to caller 
                        	   633: ; 
02:E3A3 BE0340          	   634: bkdone:     lds ssave                   ; restore user s-reg
02:E3A6 39              	   635:             rts                         ; return
                        	   636: ; 
                        	   637: ; 
                        	   638: ; miscellaneous routines for brksub 
                        	   639: ; 
                        	   640: ; breakpoint address = 0 - if function = 4 then 
                        	   641: ; put breakpoint address in current position 
                        	   642: ; a holds the function #, x holds breakpoint index 
                        	   643: ; 
02:E3A7 8104            	   644: ln:         cmpa #4                     ; is function = 4
02:E3A9 26E7            	   645:             bne bkcon2                  ; if not, then continue loop
                        	   646: ; 
02:E3AB BE033E          	   647:             lds xhi                     ; get new break address
02:E3AE AF00            	   648:             sts 0,x                     ; put in current position
                        	   649: ; 
02:E3B0 7A033C          	   650:             dec asave                   ; do not place address more
                        	   651: ; than once-cont to 
                        	   652: ; take out breakpoints 
02:E3B3 20DD            	   653:             bra bkcon2                  ; continue loop
                        	   654: ; 
                        	   655: ; breaks are not in and address is non-zero. 
                        	   656: ; if function = -1 then swi's are to be put in. 
                        	   657: ; a holds function number, s holds address 
                        	   658: ; 
02:E3B5 4D              	   659: nobrin:     tsta                        ; is function = -1
02:E3B6 2ACD            	   660:             bpl bkcon1                  ; no, continue
                        	   661: ; 
02:E3B8 34              	   662:             des                         ; make address point to 1 less
02:E3B9 32              	   663:             pula                        ; get user instruction
02:E3BA A710            	   664:             staa 2*nbrbpt,x             ; save
02:E3BC 863F            	   665:             ldaa #swiop                 ; get swi op code
02:E3BE 36              	   666:             psha                        ; replace user instruction
02:E3BF 20D1            	   667:             bra bkcon2                  ; continue loop
                        	   668: ; 
                        	   669: ; function=0 brk addr not = 0, user's instr 
                        	   670: ; is in (not swi). 
                        	   671: ; if address = xhi,xlo then set address = 0 
02:E3C1 A600            	   672: fndrpl:     ldaa 0,x                    ; get top byte of address
02:E3C3 B1033E          	   673:             cmpa xhi                    ; do top bytes compare
02:E3C6 26CA            	   674:             bne bkcon2                  ; no,continue loop
02:E3C8 E601            	   675:             ldab 1,x                    ; get low byte of addr
02:E3CA F1033F          	   676:             cmpb xlow                   ; same for low bytes
02:E3CD 26C3            	   677:             bne bkcon2
                        	   678: ; 
02:E3CF 6F00            	   679: clrbrk:     clr 0,x                     ; clear out break
02:E3D1 6F01            	   680:             clr 1,x                     ; address field
02:E3D3 20BD            	   681:             bra bkcon2                  ; continue loop
                        	   682: ; 
