                        	    96: ; 
                        	    97: ; l load 
                        	    98: ; m memory change 
                        	    99: ; p print/punch dump 
                        	   100: ; r display contents of target stack 
                        	   101: ; cc b a x p s 
                        	   102: ; s 1,set speed for 10 cps 
                        	   103: ; 3,set speed for 30 cps 
                        	   104: ; b print out all breakpoints 
                        	   105: ; c continue execution from current location 
                        	   106: ; n next instruction 
                        	   107: ; t trace 'N' instructions 
                        	   108: ; g go to location 'N' 
                        	   109: ; d delete all breakpoints 
                        	   110: ; u reset breakpoint with address 'N' 
                        	   111: ; v set a breakpoint with address 'N' 
                        	   112: ; e exortape cassette interface 
                        	   113: ; 
                        	   114:             .equ swiop, 0x3f            ; swi op code
                        	   115: 
                        	   116:             .org 0xe000 ; slot 0
                        	   117: 
                        	   118:             .org 0xe010 ; slot 1
01:E010 00              	   119: acias:      .space 0x01
01:E011 00              	   120: aciad:      .space 0x01
                        	   121: 
                        	   122:             .org 0xe100
                        	   123: baseorg:    
                        	   124: 
                        	   125: ; 
                        	   126: ; i/o interrupt sequence 
                        	   127: ; 
02:E100 FE0300          	   128: io:         ldx iov
02:E103 6E00            	   129:             jmp 0,x
                        	   130: ; 
                        	   131: ; nmi sequence 
                        	   132: ; 
02:E105 FE0306          	   133: powdwn:     ldx nio                     ; get nmi vector
02:E108 6E00            	   134:             jmp 0,x
                        	   135: ; 
                        	   136: ; swi interrupt sequence 
                        	   137: ; 
02:E10A FE030A          	   138: sfei:       ldx swi1
02:E10D 6E00            	   139:             jmp 0,x
