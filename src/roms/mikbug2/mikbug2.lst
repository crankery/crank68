F00:1537       *
F00:1538       *********************
F00:1539       *
F00:1540       * UNSIGNED MULTIPLY -----
F00:1541       *
F00:1542       *   THIS ROUTINE MULTIPLIES THE UNSIGNED NUMBER IN THE
F00:1543       *   A REGISTER WITH THE UNSIGNED NUMBER IN THE B
F00:1544       *   REGISTER AND PUTS THE ANSWERS IN THE CONCATENATED
F00:1545       *   A:B WHERE A IS THE MSB. THE ROUTINE IS
F00:1546       *   RE-ENTRANT AND POSITION INDEPENDENT AS WELL
F00:1547       *   AS BEING ROMABLE. THE X REGISTER IS DESTROYED
F00:1548       *   BY THE ROUTINE.
F00:1549       *
F00:1550       *   DURING EXECUTION THE STACK CONTAINS:
F00:1551       *   0,X  =  LOOP COUNTER
F00:1552       *   1,X  =  MULTIPLIER (B REG ON ENTRY)
F00:1553       *
F00:1554       *   THE ALGORITHM USED MAY NOT APPEAR THE FASTEST
F00:1555       *   ON PAPER BECAUSE IT ALWAYS REQUIRES 8 PASSES
F00:1556       *   THE THE LOOP BUT BECAUSE OF THE FACT ALL
F00:1557       *   CALCULATIONS CAN BE DONE IN THE REGISTERS IT
F00:1558       *   IS FASTER EXCEPT FOR WHEN THE MULTIPLICAND
F00:1559       *   IS VERY SMALL (<10). THE METHOD IS A SHIFT AND
F00:1560       *   ADD TECHNIQUE THAT BEGINGS WITH THE MS BIT
F00:1561       *   AND WORKS DOWN TO THE LS BIT.
F00:1562       *
F00:1563       *   EXECUTION TIME: (29 + ZEROES*19 + ONES*26) CYCLES
F00:1564       *     WHERE ZEROES AND ONES ARE THE 0'S AND 1'S IN
F00:1565       *     THE A-REG ON CALL.
F00:1566       *
F00:1567       *     AVERAGE EXECUTION TIME: 209 CYCLES
F00:1568       *
F00:1569       *********************
F00:1570       *
F00:1571       MUL    PSHB            PUT MULTIPLIER ON THE STACK
               S01:FFFFFFFFFFFFFF92:  37
F00:1572              LDAB   #8       PUT COUNTER ON STACK
               S01:FFFFFFFFFFFFFF93:  C6 08
F00:1573              PSHB
               S01:FFFFFFFFFFFFFF95:  37
F00:1574              TSX             SET X TO POINT TO STACK
               S01:FFFFFFFFFFFFFF96:  30
F00:1575              CLRB            CLEAR PLACE TO START ANSWER
               S01:FFFFFFFFFFFFFF97:  5F
F00:1576       ML1    ASLB            SHIFT ANS 1 LEFT AND INTO A
               S01:FFFFFFFFFFFFFF98:  58
F00:1577              ROLA            SHIFT WHATS LEFT OF THE MULTIPLIER
               S01:FFFFFFFFFFFFFF99:  49
F00:1578              BCC    ML2      BRANCH IF NO ADD NEEDED
               S01:FFFFFFFFFFFFFF9A:  24 04
F00:1579              ADDB   1,X      ADD MULTIPLIER AT THIS POSITION
               S01:FFFFFFFFFFFFFF9C:  EB 01
F00:1580              ADCA   #0       ADD CARRY TO A IF ANY
               S01:FFFFFFFFFFFFFF9E:  89 00
F00:1581       ML2    DEC    0,X      DONE?
               S01:FFFFFFFFFFFFFFA0:  6A 00
F00:1582              BNE    ML1      NOPE
               S01:FFFFFFFFFFFFFFA2:  26 F4
F00:1583              INS             YES,CLEAN UP THE STACK
               S01:FFFFFFFFFFFFFFA4:  31
F00:1584              INS
               S01:FFFFFFFFFFFFFFA5:  31
F00:1585              RTS
               S01:FFFFFFFFFFFFFFA6:  39
F00:1586       *
F00:1587       ***********************
F00:1588       *
F00:1589       * SIGNED MULTIPLY -----
F00:1590       *
F00:1591       *     THIS ROUTINE MULTIPLIES THE TWO SIGNED NUMBERS IN
F00:1592       *     THE A AND B REGISTERS AND PUTS THE SIGNED
F00:1593       *     16 BIT ANSWER IN THE CONCATENATED A:B WHERE
F00:1594       *     THE A REGISTER IS THE MSB. THIS ROUTINE DESTROYS
F00:1595       *     THE CALLER'S X-REGISTER.
F00:1596       *
F00:1597       *     DURING EXECUTION THE STACK CONTAINS:
F00:1598       *     0,X  =  FLAG
F00:1599       *
F00:1600       *     THE ROUTINE IS PURE,RE-ENTRANT AND POSITION INDEPENDENT.
F00:1601       *
F00:1602       *     THE METHOD USE EVALUATES EACH ARGUMENT AND IF IT
F00:1603       *     IS NEGATIVE IT IS 2'S COMPLEMENTED AND THE FLAG IS
F00:1604       *     INCREMENTED. IF AFTER EVALUATING BOTH ARGUMENTS THE
F00:1605       *     FLAG IS EVEN (0 OR 2) THEN THE ANSWER WILL BE POSITIVE,
F00:1606       *     ELSE,THE ANSWER WILL NEED TO BE 2'S COMPLEMENTED.
F00:1607       *     UNSIGNED MULTIPLE ROUTINE IS USED TO MULTIPLY THE
F00:1608       *     CORRECTED REGISTERS
F00:1609       *
F00:1610       *    AVERAGE EXECUTIONS TIMES:
F00:1611       *     A-REG  B-REG
F00:1612       *      +      +           268 AVERAGE
F00:1613       *      +      -           283 AVERAGE
F00:1614       *      -      +           283 AVERAGE
F00:1615       *      -      -           286 AVERAGE
F00:1616       *
F00:1617       *
F00:1618       *************************
F00:1619       *
F00:1620       SMUL   DES             CARVE OUT A PLACE ON THE STACK F...
               S01:FFFFFFFFFFFFFFA7:  34
F00:1621              TSX             GET POINTER TO THAT PLACE
               S01:FFFFFFFFFFFFFFA8:  30
F00:1622              CLR    0,X      CLEAR FLAG
               S01:FFFFFFFFFFFFFFA9:  6F 00
F00:1623              TSTA            CHECK MULTIPLIER
               S01:FFFFFFFFFFFFFFAB:  4D
F00:1624              BPL    SML1     POSITIVE, NO COMP. NEEDED
               S01:FFFFFFFFFFFFFFAC:  2A 03
F00:1625              NEGA            2s COMP. ARGUMENT
               S01:FFFFFFFFFFFFFFAE:  40
F00:1626              INC    0,X      INCR FLAG
               S01:FFFFFFFFFFFFFFAF:  6C 00
F00:1627       SML1   TSTB            TEST OTHER ARG
               S01:FFFFFFFFFFFFFFB1:  5D
F00:1628              BPL    SML2     NO COMP NEEDED
               S01:FFFFFFFFFFFFFFB2:  2A 03
F00:1629              NEGB
               S01:FFFFFFFFFFFFFFB4:  50
F00:1630              INC    0,X      INCR FLAG
               S01:FFFFFFFFFFFFFFB5:  6C 00
F00:1631       SML2   BSR    MUL      GO DO UNSIGNED MULTIPLY
               S01:FFFFFFFFFFFFFFB7:  8D D9
F00:1632              TSX             GET BACK PTR TO FLAG
               S01:FFFFFFFFFFFFFFB9:  30
F00:1633              ROR    0,X      SEE IF FLAG IS EVEN OR ODD
               S01:FFFFFFFFFFFFFFBA:  66 00
F00:1634              BCC    SML3     EVEN ANSWER IS OKAY 'CAUSE ITS F...
               S01:FFFFFFFFFFFFFFBC:  24 04
F00:1635              NEGA            DBL PRECISION 2'S COMP
               S01:FFFFFFFFFFFFFFBE:  40
F00:1636              NEGB
               S01:FFFFFFFFFFFFFFBF:  50
F00:1637              SBCA   #0
               S01:FFFFFFFFFFFFFFC0:  82 00
F00:1638       SML3   INS             CLEANUP STACK
               S01:FFFFFFFFFFFFFFC2:  31
F00:1639              RTS             RETURN TO CALLER
               S01:FFFFFFFFFFFFFFC3:  39
F00:1640       *
F00:1641       *********************
F00:1642       *
F00:1643       * POSTIVE DIVIDE -----
F00:1644       *
F00:1645       *   THIS ROUTINE DIVIDES THE 16 BIT POSITIVE DIVIDEND
F00:1646       *   IN THE A:B REGISTERS (A IS THE MSB) BY AN 8
F00:1647       *   BIT POSITIVE  DIVISOR POINTED TO BY THE X-REGISTER.
F00:1648       *   THE QUOTIENT IS IN B ON EXIT AND THE REMAINDER
F00:1649       *   IS IN THE A-REGISTER. THE X-REGISTER IS
F00:1650       *   DESTROYED.
F00:1651       *   IF DIVISION BY ZERO WAS ATTEMPTED OR THE
F00:1652       *   QUOTIENT WILL NOT FIT IN 8 BITS THE OVERFLOW
F00:1653       *   BIT IS SET ON EXIT. ALSO V IS SET IF EITHER
F00:1654       *   THE DIVIDEND OR THE DIVISOR IS NEGATIVE ON CALL.
F00:1655       *   OTHERWISE V IS CLEARED.
F00:1656       *
F00:1657       *
F00:1658       *   THE ROUTING IS PURE,RE-ENTRANT AND POSITION INDEPENDENT.
F00:1659       *
F00:1660       *   DURING EXECUTION THE STACK CONTAINS
F00:1661       *   0,X  =  LOOP COUNTER
F00:1662       *   1,X  =  DIVISOR
F00:1663       *   2,X  =  DIVIDEND MSB (ONLY USED FOR TEMP STORE)
F00:1664       *
F00:1665       *   THE METHOD USED IS NON RESTORING DIVIDE WHERE THE
F00:1666       *   DIVIDEND AND DIVISOR AND KNOWN TO BE POSITIVE. THIS
F00:1667       *   METHOD PROVED FASTEST SINCE IT CAN BE CARRIED OUT
F00:1668       *   ESSENTIALLY IN THE ACCUMULATORS. THE ALGORITHM TRIES
F00:1669       *   TO GET THE REMAINDER AS NEAR ZERO AS POSSIBLE
F00:1670       *   AND SOMETIMES ADDS THE DIVISOR AND SOMETIMES
F00:1671       *   SUBTRACTS IT DEPENDING ON WHICH SIDE OF ZERO THE
F00:1672       *   PARTIAL REMAINDER RESIDES AT ANY TIME. FOR MORE
F00:1673       *   INFO READ: 'AN ALGORITHM FOR NON RESTORING DIVISION'
F00:1674       *   S. SANYAL ; 'COMPUTER DESIGN' / MAY 1997.
F00:1675       *
F00:1676       *   EXECUTION TIME AVERAGE (NO OVERFLOWS): 289 CYCLES
F00:1677       *     THIS TIME IS RELATIVELY INDEPENDENT OF THE
F00:1678       *     CALLING VALUES.
F00:1679       *
F00:1680       *
F00:1681       *********************
F00:1682       *
F00:1683       DIV    PSHA            SAVE DIVIDEND MSB A SECOND
               S01:FFFFFFFFFFFFFFC4:  36
F00:1684              LDAA   0,X      FETCH THE DIVISOR
               S01:FFFFFFFFFFFFFFC5:  A6 00
F00:1685              BMI    DIVOV2   NEGATIVE DIVISOR IS A NO-NO
               S01:FFFFFFFFFFFFFFC7:  2B 29
F00:1686              PSHA            PUSH IT
               S01:FFFFFFFFFFFFFFC9:  36
F00:1687              LDAA   #8       PUSH LOOP CTR
               S01:FFFFFFFFFFFFFFCA:  86 08
F00:1688              PSHA
               S01:FFFFFFFFFFFFFFCC:  36
F00:1689              TSX             POINT X TO STACK
               S01:FFFFFFFFFFFFFFCD:  30
F00:1690              LDAA   2,X      RESTORE ORIGINAL DIVIDEND MSB
               S01:FFFFFFFFFFFFFFCE:  A6 02
F00:1691              CMPA   1,X      WILL QUOTIENT OVERFLOW? (ALS D!
               S01:FFFFFFFFFFFFFFD0:  A1 01
F00:1692              BCC    DIVOVF   YES,GO SET V AND EXIT
               S01:FFFFFFFFFFFFFFD2:  24 1C
F00:1693       DLOOP  ASLB            SHIFT DIVIDEND-ANSWER LEFT
               S01:FFFFFFFFFFFFFFD4:  58
F00:1694              ROLA
               S01:FFFFFFFFFFFFFFD5:  49
F00:1695              BCC    DL2      IS DIVIDEND MS BIT SET?
               S01:FFFFFFFFFFFFFFD6:  24 04
F00:1696              ADDA   1,X      YES,ADD DIVISOR TO MSB
               S01:FFFFFFFFFFFFFFD8:  AB 01
F00:1697              BRA    DL3
               S01:FFFFFFFFFFFFFFDA:  20 03
F00:1698       DL2    SUBA   1,X      NO,SUB DIVISOR FROM MSB
               S01:FFFFFFFFFFFFFFDC:  A0 01
F00:1699              INCB            SET BIT IN RESULT
               S01:FFFFFFFFFFFFFFDE:  5C
F00:1700       DL3    DEC    0,X      DONE?
               S01:FFFFFFFFFFFFFFDF:  6A 00
F00:1701              BNE    DLOOP    NO
               S01:FFFFFFFFFFFFFFE1:  26 F1
F00:1702              SEC             SHIFT A 1 IN LS BIT OF QUOTIENT
               S01:FFFFFFFFFFFFFFE3:  0D
F00:1703              ROLB            CASE THATS OKAY, CORRECT LATTER
               S01:FFFFFFFFFFFFFFE4:  59
F00:1704              TSTA            IS REMAINDER NEGATIVE?
               S01:FFFFFFFFFFFFFFE5:  4D
F00:1705              BPL    DL4      NO,EVERYTHING'S OKAY
               S01:FFFFFFFFFFFFFFE6:  2A 04
F00:1706              DECB            RESET QUOTIENT LS BIT
               S01:FFFFFFFFFFFFFFE8:  5A
F00:1707              ADDA   1,X      ADD DIVISOR  TO GET + REMAINDER
               S01:FFFFFFFFFFFFFFE9:  AB 01
F00:1708              CLV             INSURE V IS CLEARED
               S01:FFFFFFFFFFFFFFEB:  0A
F00:1709       DL4    INS             CLEAN UP THE STACK
               S01:FFFFFFFFFFFFFFEC:  31
F00:1710              INS
               S01:FFFFFFFFFFFFFFED:  31
F00:1711              INS
               S01:FFFFFFFFFFFFFFEE:  31
F00:1712              RTS             RETURN
               S01:FFFFFFFFFFFFFFEF:  39
F00:1713       *
F00:1714       DIVOVF INS             CLEAN UP STACK
               S01:FFFFFFFFFFFFFFF0:  31
F00:1715              INS
               S01:FFFFFFFFFFFFFFF1:  31
F00:1716       DIVOV2 INS
               S01:FFFFFFFFFFFFFFF2:  31
F00:1717              SEV             SET THE OVERFLOW FLAG
               S01:FFFFFFFFFFFFFFF3:  0B
F00:1718              RTS
               S01:FFFFFFFFFFFFFFF4:  39
F00:1719       *
F00:1720       * INTERRUPT VECTORS
F00:1721       *
F00:1722              ORG    BASORG+$7F8
F00:1723              dc.w    IO
               S02:FFFFFFFFFFFFFFF8:  F8 00
F00:1724              dc.w    SFEI
               S02:FFFFFFFFFFFFFFFA:  F8 0A
F00:1725              dc.w    POWDWN
               S02:FFFFFFFFFFFFFFFC:  F8 05
F00:1726              dc.w   START
               S02:FFFFFFFFFFFFFFFE:  F9 7B
F00:1727       *
F00:1728       *
F00:1729       * RAM - LOCATIONS DEVOTED TO VARIABLE INFORMATION
F00:1730       *
F00:1731       *
F00:1732              ORG    $A000    START OF RAM .
F00:1733       NBRBPT EQU    8        # OF BREAKPOINTS SUPPORTED
F00:1734       *
F00:1735       * THE FOLLOWING ARE INITIALIZED AT START
F00:1736       *
F00:1737       IOV    ds    2        I/O INTERRUPT POINTER
F00:1738       BEGA   ds    2        BEGIN ADDRESS PRINT/PUNCH
F00:1739       ENDA   ds    2        END ADDRESS PRINT/PUNCH
F00:1740       NIO    ds    2        NMI INTERRUPT POINTER
F00:1741       SP     ds    2        USER STACK POINTER
F00:1742       SWI1   ds    2        LEVEL 1 SWI VECTOR
F00:1743       SWI2   ds    2        LEVEL 2 SWI VECTOR
F00:1744       BRINS  ds    8        STORAGE FOR CONDITIONAL BRANCH
F00:1745       *                            ROUTINE
F00:1746       BRANEN EQU    *        END OF BRANCH ROUTINE + 1
F00:1747       *
F00:1748       * THE FOLLOWING ARE INITIALIZED TO ZERO AT START
F00:1749       *
F00:1750       *
F00:1751       OUTSW  ds    1        OUTPUT SWITCH
F00:1752       *                       (ZERO => ECHO INPUT)
F00:1753       TRCADR ds    2        TRACE ADDRESS
F00:1754       TRCINS ds    1        OP CODE REPLACED BY SWI
F00:1755       NTRACE ds    2        NO. OF INSTRUCTIONS TO TRACE
F00:1756       *
F00:1757       BRKADR ds    NBRBPT*2 BREAKPOINT ADDRESS TABLE
F00:1758       BRKINS ds    NBRBPT*2 OP CODES FOR BREAK REPLACEMENT
F00:1759       *                            (UPPER BYTE OF EACH
F00:1760       *                             PAIR USED ONLY)
F00:1761       CKSM   EQU    *        CHECKSUM
F00:1762       ASAVE  EQU    *        A REG SAVE
F00:1763       TEMP   EQU    *        CHAR COUNT(INADD)
F00:1764              DS    1
F00:1765       *
F00:1766       *
F00:1767       BYTECT EQU    *        BYTE COUNT
F00:1768       MCONT  EQU    *        TMP
F00:1769              DS    1
F00:1770       *
F00:1771       *
F00:1772       XHI    DS    1        X REG HIGH (TEMP)
F00:1773       XLOW   DS    1        X REG LOW
F00:1774       *
F00:1775       *
F00:1776       SSAVE  EQU    *        S REG SAVE
F00:1777       TW     EQU    *        TEMP DOUBLE BYTE
F00:1778              DS    2
F00:1779       *
F00:1780       *
F00:1781       BRKSIN DS    1        1=>BREAKS ARE IN USER PROGRAM
F00:1782       *
F00:1783       BRKTRC DS    1	       1=>P-COUNTER IS AT BREAKPOINT
F00:1784       *                      AND USER WANTS TO CONTINUE-
F00:1785       *                      ONE TRACE WILL BE DONE AND
F00:1786       *                      BREAKPOINT RESTORED
F00:1787       ENDIN0 EQU    $A080    END OF VAR'S INTZ'D to 0
F00:1788       *
