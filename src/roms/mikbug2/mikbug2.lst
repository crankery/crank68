                        	  1255: ; fall into getload 
                        	  1256: ; 
                        	  1257: ; getload searches for the desired file, 
                        	  1258: ; then loads it into ram 
                        	  1259: ; 
                        	  1260: ; ram: q, r, s, h, l (scratch) 
                        	  1261: ; totcnt, fidh, fidl (perm) 
                        	  1262: ; 
02:E69A BDE872          	  1263: getloa:     jsr lsetup                  ; set up pia
02:E69D 8D5E            	  1264:             bsr getfil                  ; search for correct file
02:E69F 2722            	  1265:             beq get4                    ; out iff escaped
02:E6A1 8D54            	  1266: get2:       bsr startv                  ; get the next record-type
02:E6A3 271E            	  1267:             beq get4                    ; out if escape
02:E6A5 C120            	  1268:             cmpb #0x20                  ; trailerecord?
02:E6A7 270A            	  1269:             beq get1
02:E6A9 C110            	  1270:             cmpb #0x10                  ; dumpagerecord?
02:E6AB 26F4            	  1271:             bne get2
02:E6AD 8D15            	  1272:             bsr dumpr                   ; bring it in!
02:E6AF 2712            	  1273:             beq get4                    ; out iff escape
02:E6B1 20EE            	  1274:             bra get2
02:E6B3 7D0353          	  1275: get1:       tst v                       ; check page count
02:E6B6 270B            	  1276:             beq get4
02:E6B8 2B04            	  1277:             bmi get3
02:E6BA 862D            	  1278:             ldaa #'-'                   ;  '-'  for missing page(s)
02:E6BC 2002            	  1279:             bra get5
02:E6BE 862B            	  1280: get3:       ldaa #'+'                   ;  '+'  for extra page(s)
02:E6C0 BDE175          	  1281: get5:       jsr outch                   ; print it!
02:E6C3 39              	  1282: get4:       rts                         ; return
                        	  1283: ; 
                        	  1284: ; dumpr brings in a dumpage record 
                        	  1285: ; 
                        	  1286: ; ram: h, l (scratch) 
                        	  1287: ; regs: acca, accb (scratch); ix (perm) 
                        	  1288: ; exit: falls into crck 
                        	  1289: ; 
02:E6C4 8D2E            	  1290: dumpr:      bsr ldv                     ; get page number
02:E6C6 F7034E          	  1291:             stab h                      ; )
02:E6C9 7F034F          	  1292:             clr l                       ; ) load ix!
02:E6CC FE034E          	  1293:             ldx h                       ; )
02:E6CF 8D23            	  1294: dum1:       bsr ldv
02:E6D1 2749            	  1295:             beq g2                      ; out iff escape
02:E6D3 BD034B          	  1296:             jsr cl                      ; check, or load
02:E6D6 08              	  1297:             inx                         ; storage ptr
02:E6D7 7C034F          	  1298:             inc l                       ; byte count
02:E6DA 26F3            	  1299:             bne dum1
02:E6DC 7A0353          	  1300:             dec v                       ; page count
                        	  1301: ; fall into crck 
                        	  1302: ; 
                        	  1303: ; crck shecks the crc and print a char 
                        	  1304: ; 
                        	  1305: ; ram: q, r, s, totcnt (from loadbyte) 
                        	  1306: ; regs: acca (scratch, accb (from loadbyte) 
                        	  1307: ; 
02:E6DF 8D13            	  1308: crck:       bsr ldv                     ; ) input crc chars
02:E6E1 8D11            	  1309:             bsr ldv                     ; )
02:E6E3 B60351          	  1310:             ldaa r                      ; check crc registers
02:E6E6 BA0352          	  1311:             oraa s
02:E6E9 2604            	  1312:             bne crck1
02:E6EB 8647            	  1313:             ldaa #'G'                   ;  print g for good crc
02:E6ED 2002            	  1314:             bra crck2
02:E6EF 8642            	  1315: crck1:      ldaa #'B'                   ;  print b for bad crc
02:E6F1 7EE86F          	  1316: crck2:      jmp ttyo1                   ; print it!
02:E6F4 7EE866          	  1317: ldv:        jmp loadbv                  ; get a tape byte in accb
02:E6F7 2024            	  1318: startv:     bra startf
                        	  1319: ; 
                        	  1320: ; getfile looks for: 
                        	  1321: ; 1) a start sequence 
                        	  1322: ; 2) a headerecord type 
                        	  1323: ; 3) a file id match with fidh, fidl 
                        	  1324: ; and returns when found, or escaped 
                        	  1325: ; 
                        	  1326: ; regs: acca, accb (scratch only) 
                        	  1327: ; 
02:E6F9 8658            	  1328: g1:         ldaa #'X'                   ;  indicate wrong file found
02:E6FB 8DF4            	  1329:             bsr crck2                   ; send char to tty
02:E6FD 8D1E            	  1330: getfil:     bsr startf
02:E6FF 271B            	  1331:             beq g2                      ; out iff escape
02:E701 C108            	  1332:             cmpb #0x08                  ; headerecord-type?
02:E703 26F8            	  1333:             bne getfil                  ; branch if not
02:E705 8DED            	  1334:             bsr ldv                     ; get byte in accb
02:E707 F10345          	  1335:             cmpb fidh                   ; good file id(h)?
02:E70A 26ED            	  1336:             bne g1
02:E70C 8DE6            	  1337:             bsr ldv
02:E70E F10346          	  1338:             cmpb fidl                   ; good file id(l)?
02:E711 26E6            	  1339:             bne g1
02:E713 8648            	  1340:             ldaa #'H'                   ;  indicate header found
02:E715 8DDA            	  1341:             bsr crck2
02:E717 8DDB            	  1342:             bsr ldv
02:E719 F70353          	  1343:             stab v                      ; store page count
02:E71C 39              	  1344: g2:         rts
                        	  1345: ; 
                        	  1346: ; startfind looks for the 16-bit start sequence 89af 
                        	  1347: ; returns with the next byte, the record type, 
                        	  1348: ; in q and accb. 
                        	  1349: ; 
                        	  1350: ; ram: q, r, s, totcnt (perm), h (scratch) 
                        	  1351: ; regs: acca, accb (scratch only) 
                        	  1352: ; exit: falls into loadbyte, which 
                        	  1353: ; falls into loadbit, which 
                        	  1354: ; falls into crc 
                        	  1355: ; escape: esc in command port gets out 
                        	  1356: ; (test done in crc) 
                        	  1357: ; 
02:E71D 7F034E          	  1358: startf:     clr h                       ; accumulates 16 bits
02:E720 7F0350          	  1359:             clr q
02:E723 780350          	  1360: sta1:       asl q                       ; shift the 16-bit register
02:E726 79034E          	  1361:             rol h
02:E729 8D24            	  1362:             bsr loadb1
02:E72B 27EF            	  1363:             beq g2                      ; out iff escaped
02:E72D B6034E          	  1364:             ldaa h
02:E730 F60350          	  1365:             ldab q
02:E733 8189            	  1366:             cmpa #0x89                  ; start sequence
02:E735 26EC            	  1367:             bne sta1
02:E737 C1AF            	  1368:             cmpb #0xaf
02:E739 26E8            	  1369:             bne sta1
02:E73B 7F0351          	  1370: sta2:       clr r                       ; clear the crc register
02:E73E 7F0352          	  1371:             clr s
                        	  1372: ; fall into loadbyte to return a byte 
                        	  1373: ; 
                        	  1374: ; loadbyte recovers of data in q and accb, and does crc 
                        	  1375: ; 
                        	  1376: ; ram: q, r, s, totcnt (perm) 
                        	  1377: ; regs: acca, accb (scratch only) 
                        	  1378: ; exit: falls into loadbit, which 
                        	  1379: ; falls into crc 
                        	  1380: ; 
02:E741 C602            	  1381: loadby:     ldab #0x02                  ; set stop
02:E743 F70350          	  1382:             stab q
02:E746 8D07            	  1383: load1:      bsr loadb1
02:E748 27D2            	  1384:             beq g2                      ; out iff escape
02:E74A 780350          	  1385:             asl q                       ; stop into carry?
02:E74D 24F7            	  1386:             bcc load1                   ; branch if no
                        	  1387: ; fall into loadbit for last bit 
                        	  1388: ; 
                        	  1389: ; loadbit recovers one bit of data in q and accb, 
                        	  1390: ; and does crc in r and s 
                        	  1391: ; 
                        	  1392: ; ram: q, r, s, totcnt (perm) 
                        	  1393: ; regs: acca, accb (scratch only) 
                        	  1394: ; exit: branches or falls into crc routine 
                        	  1395: ; data bit goes into q lsb 
                        	  1396: ; 
02:E74F 5F              	  1397: loadb1:     clrb
02:E750 5A              	  1398: loadb6:     decb
02:E751 271F            	  1399:             beq loadb5
02:E753 8D43            	  1400:             bsr tain1v                  ; get tape data in carry
02:E755 25F9            	  1401:             bcs loadb6                  ; wait for low
02:E757 5A              	  1402: loadb2:     decb
02:E758 2718            	  1403:             beq loadb5
02:E75A 8D3C            	  1404:             bsr tain1v                  ; wait for high
02:E75C 24F9            	  1405:             bcc loadb2                  ; ) (front of sync el)
02:E75E F60349          	  1406:             ldab totcnt                 ; 3.5 els delay
02:E761 5A              	  1407: loadb3:     decb
02:E762 270E            	  1408:             beq loadb5
02:E764 8D32            	  1409:             bsr tain1v                  ; ) wait for low
02:E766 25F9            	  1410:             bcs loadb3                  ; ) (end of sync el)
02:E768 5A              	  1411: loadb4:     decb
02:E769 2707            	  1412:             beq loadb5                  ; done yet?
02:E76B 8D2B            	  1413:             bsr tain1v
02:E76D 24F9            	  1414:             bcc loadb4
02:E76F 7C0350          	  1415:             inc q                       ; store a '1'  bit
02:E772 B60350          	  1416: loadb5:     ldaa q                      ; get data for crc
                        	  1417: ; fall into crc1 
                        	  1418: ; 
                        	  1419: ; crc enters a bit into crc registers r and s 
                        	  1420: ; uses crc polynomial: x16 + x15 + x2 + x0 
                        	  1421: ; 
                        	  1422: ; entry: acca holds new bit 
                        	  1423: ; ram: r, s (perm) 
                        	  1424: ; regs: acca, accb (scratch) 
                        	  1425: ; exit: accb = q, z = 1 iff esc 
                        	  1426: ; 
02:E775 46              	  1427: crc1:       rora                        ; lsb into carry
02:E776 46              	  1428:             rora                        ; carry into msb
02:E777 8480            	  1429: crc2:       anda #0x80                  ; mask msb (data bit)
02:E779 B80351          	  1430:             eora r                      ; enter data bit
02:E77C F60352          	  1431:             ldab s
02:E77F 58              	  1432:             aslb                        ; shift 16 bits left
02:E780 49              	  1433:             rola
02:E781 2404            	  1434:             bcc crc3                    ; if b16 high. . .
02:E783 8880            	  1435:             eora #0x80                  ; enter crc polynomial
02:E785 C805            	  1436:             eorb #0x05
02:E787 B70351          	  1437: crc3:       staa r
02:E78A F70352          	  1438:             stab s
02:E78D F60350          	  1439:             ldab q
02:E790 BDE86C          	  1440:             jsr ttyin1                  ; check for escape
02:E793 847F            	  1441:             anda #0x7f                  ; mask parity
02:E795 811B            	  1442:             cmpa #esc
02:E797 39              	  1443:             rts
02:E798 7EE860          	  1444: tain1v:     jmp tain1
                        	  1445: ; 
                        	  1446: ; byteout sends byte in acca to tape 
                        	  1447: ; 
                        	  1448: ; ram: r, s (changed in crc) 
                        	  1449: ; regs: acca, accb (destroyed) 
                        	  1450: ; exit: acca = 0, accb undefined 
                        	  1451: ; 
                        	  1452: ; acca = data byte (shifted) 
                        	  1453: ; accb = recording pattern (one bit) 
                        	  1454: ; 
02:E79B 36              	  1455: byteou:     psha                        ; save the data byte
02:E79C 8DD9            	  1456:             bsr crc2                    ; ) do the crc first
02:E79E 32              	  1457:             pula                        ; recover the data byte
02:E79F 0D              	  1458:             sec                         ; set stop
02:E7A0 49              	  1459:             rola                        ; data bit into carry
02:E7A1 2006            	  1460:             bra by2
02:E7A3 32              	  1461: by1:        pula                        ; recover from done test
02:E7A4 36              	  1462:             psha                        ; save shifting byte
02:E7A5 8DD0            	  1463:             bsr crc2
02:E7A7 32              	  1464:             pula                        ; recover shifting byte
02:E7A8 48              	  1465:             asla                        ; data bit into carry
02:E7A9 C60A            	  1466: by2:        ldab #0x0a                  ; recording pattern
02:E7AB BDE863          	  1467: by3:        jsr taou1                   ; send accb to tape
02:E7AE 37              	  1468:             pshb                        ; save pattern
02:E7AF F6034A          	  1469:             ldab patdel                 ; element delay
02:E7B2 5A              	  1470: by4:        decb
02:E7B3 26FD            	  1471:             bne by4                     ; branch if element not done
02:E7B5 33              	  1472:             pulb                        ; recover pattern
02:E7B6 59              	  1473:             rolb                        ; next element (data from carry)
02:E7B7 24F2            	  1474:             bcc by3                     ; branch if pattern not done
02:E7B9 36              	  1475:             psha                        ; save data byte before test
02:E7BA 48              	  1476:             asla                        ; test acca
02:E7BB 26E6            	  1477:             bne by1                     ; branch if byte not done
02:E7BD 31              	  1478: by5:        ins                         ; restore stack
02:E7BE 39              	  1479:             rts
                        	  1480: ; 
                        	  1481: ; preamble sends out alc bits, and the start sequence, 
                        	  1482: ; then inits the crc registers 
                        	  1483: ; 
                        	  1484: ; ram: r, s (changed) 
                        	  1485: ; regs: acca, accb (destroyed) 
                        	  1486: ; exit: acca = 0, accb undefined 
                        	  1487: ; 
02:E7BF 8D2E            	  1488: preamb:     bsr bytov1                  ; alc bits
02:E7C1 8D2C            	  1489:             bsr bytov1
