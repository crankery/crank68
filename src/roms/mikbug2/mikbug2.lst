02:E803 8DEA            	  1537:             bsr bytov1
02:E805 7F0351          	  1538:             clr l                       ; do entire page
02:E808 FE0350          	  1539:             ldx h                       ; point at the data
02:E80B A600            	  1540: dump1:      ldaa 0,x
02:E80D 8DE0            	  1541:             bsr bytov1                  ; send data
02:E80F 08              	  1542:             inx
02:E810 7C0351          	  1543:             inc l                       ; byte ctr
02:E813 26F6            	  1544:             bne dump1
02:E815 8D07            	  1545:             bsr sencrc
