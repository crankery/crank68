               S01:FFFFFFFFFFFFFBFF:  26 FC
F00:0818              BRA    BRG2     IF DONE, GO RETURN TO USER PROG
               S01:FFFFFFFFFFFFFC01:  20 EA
F00:0819       *
F00:0820       * SUBROUTINE TO INCREMENT X BY CONTENTS OF A
F00:0821       *
F00:0822       INCX   TSTA            IS A = 0?
               S01:FFFFFFFFFFFFFC03:  4D
F00:0823              BEQ    INCXR    IF SO, INC DONE
               S01:FFFFFFFFFFFFFC04:  27 04
F00:0824       INXLP  INX             ELSE INCREMENT X
               S01:FFFFFFFFFFFFFC06:  08
F00:0825              DECA            DECREMENT COUNT
               S01:FFFFFFFFFFFFFC07:  4A
F00:0826              BNE    INXLP    IF COUNT NOT YET 0, LOOP
               S01:FFFFFFFFFFFFFC08:  26 FC
F00:0827       INCXR  RTS             RETURN FROM THIS SUBROUTINE
               S01:FFFFFFFFFFFFFC0A:  39
F00:0828       *
F00:0829       * INSTRUCTION TO BE TRACED IS NOT A BRANCH
F00:0830       *
