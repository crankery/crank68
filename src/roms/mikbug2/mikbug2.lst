               S01:FFFFFFFFFFFFFBED:  FF A0 2E
F00:0805       *                            INSTR TO STOP ON
F00:0806              LDAA   0,X      GET INSTRUCTION TO BE REPLACED
               S01:FFFFFFFFFFFFFBF0:  A6 00
F00:0807              STAA   TRCINS   SAVE
               S01:FFFFFFFFFFFFFBF2:  B7 A0 32
F00:0808              LDAA   #SWI     GET SWI OP CODE
