02:E819 8D54            	  1547:             bsr ttyo1
02:E81B 4F              	  1548:             clra
02:E81C 20D1            	  1549:             bra bytov1                  ; extra bits
                        	  1550: ; 
                        	  1551: ; sencrc sends the crc registers to tape 
                        	  1552: ; 
                        	  1553: ; 
                        	  1554: ; ram: r, s (freed after this); l (scratch) 
                        	  1555: ; regs: acca, accb (destroyed) 
                        	  1556: ; 
02:E81E B60355          	  1557: sencrc:     ldaa s
02:E821 B70351          	  1558:             staa l                      ; temporary crc(l) storage
02:E824 B60354          	  1559:             ldaa r
02:E827 8DC6            	  1560:             bsr bytov1                  ; send crc(h)
02:E829 B60351          	  1561:             ldaa l
02:E82C 20C1            	  1562:             bra bytov1                  ; send crc(l)
                        	  1563: ; 
                        	  1564: ; masterdump sends a complete file to tape: 
                        	  1565: ; headerecore, dumpagerecords (1-256), trailerecord 
                        	  1566: ; 
                        	  1567: ; ram: startp, stoppg (unmodified) 
                        	  1568: ; h, l (temp) 
