                        	   132: ; i/o interrupt sequence 
                        	   133: ; 
02:E100 FE0300          	   134: io:         ldx iov
02:E103 6E00            	   135:             jmp 0,x
                        	   136: ; 
                        	   137: ; nmi sequence 
                        	   138: ; 
02:E105 FE0306          	   139: powdwn:     ldx nio                     ; get nmi vector
02:E108 6E00            	   140:             jmp 0,x
                        	   141: ; 
                        	   142: ; swi interrupt sequence 
                        	   143: ; 
02:E10A FE030A          	   144: sfei:       ldx swi1
02:E10D 6E00            	   145:             jmp 0,x
