F00:0870              LDX    12,X     GET P-COUNTER FROM STACK
               S01:FFFFFFFFFFFFFC3A:  EE 0C
F00:0871              BRA    BRG2     GO TRACE NEXT INSTR.
               S01:FFFFFFFFFFFFFC3C:  20 AF
F00:0872       *
F00:0873       * RTS ENCOUNTERED
F00:0874       *
F00:0875       RTSSIM TSX
               S01:FFFFFFFFFFFFFC3E:  30
F00:0876              LDX    7,X      GET RETURN P-REG FROM STACK
               S01:FFFFFFFFFFFFFC3F:  EE 07
F00:0877              BRA    BRG2     GO TRACE NEXT INSTR
               S01:FFFFFFFFFFFFFC41:  20 AA
F00:0878       *************************
F00:0879       *
F00:0880       * OPBCYT
F00:0881       *
F00:0882       * THIS ROUTINE DETERMINES THE # OF BYTES IN AN INSTRUCTION
F00:0883       * GIVEN ITS OP CODE.
F00:0884       *
F00:0885       * INPUT: A HOLDS THE OP CODE
F00:0886       *
F00:0887       * OUTPUT: X HOLDS THE INDEX OF TABLE ELEMENT
F00:0888       * B NOT RESTORED
F00:0889       * A HOLDS # BYTES IN INSTRUCTION
F00:0890       * EXCEPT FOR BRANCHES IN WHICH CASE IS NEGATIVE
F00:0891       *
F00:0892       ************************
F00:0893       *
F00:0894       OPCBYT EQU    *
F00:0895              TAB             B:= OP CODE
               S01:FFFFFFFFFFFFFC43:  16
F00:0896              LSRA
               S01:FFFFFFFFFFFFFC44:  44
F00:0897              LSRA
               S01:FFFFFFFFFFFFFC45:  44
F00:0898              LSRA            PUT 4 UPPER BITS OF OP CODE IN
               S01:FFFFFFFFFFFFFC46:  44
F00:0899              LSRA            LOWER 4 BITS OF A
               S01:FFFFFFFFFFFFFC47:  44
F00:0900       *
F00:0901              LDX    #OPBTTB  X:= ADDRESS OF TABLE
               S01:FFFFFFFFFFFFFC48:  CE FC 61
F00:0902              BSR    INCX     INCREMENT X TO POINT TO CORRECT
               S01:FFFFFFFFFFFFFC4B:  8D B6
F00:0903       *
F00:0904              LDAA    0,X     GET TABLE ENTRY
               S01:FFFFFFFFFFFFFC4D:  A6 00
F00:0905              BNE    OPBTRT   IF NOT 0 THEN NO FURTHER
               S01:FFFFFFFFFFFFFC4F:  26 0F
F00:0906       *                            PROCESSING NEEDED
F00:0907       *
F00:0908       * IF TOP 4 BITS = 8 OR C, THEN THERE ARE TWO CLASSES
F00:0909       * OF INSTRUCTIONS: 2 BYTE INSTRUCTIONS AND
F00:0910       * CE, 8C AND 8E WHICH ARE 3 BYTE INSTRUCTIONS
F00:0911       *
F00:0912              LDAA   #2       # BYTES IN MOST OF 8# INSTRUCTIONS
               S01:FFFFFFFFFFFFFC51:  86 02
F00:0913              CMPB   #$8C     3 BYTE INSTRUCTION?
               S01:FFFFFFFFFFFFFC53:  C1 8C
F00:0914              BEQ    OPBT3    YES, UPDATE A
               S01:FFFFFFFFFFFFFC55:  27 08
F00:0915              CMPB   #$CE     3 BYTE INSTR?
               S01:FFFFFFFFFFFFFC57:  C1 CE
F00:0916              BEQ    OPBT3    YES, UPDATE A
               S01:FFFFFFFFFFFFFC59:  27 04
F00:0917              CMPB   #$8E     3 BYTE INSTRUCTION?
               S01:FFFFFFFFFFFFFC5B:  C1 8E
F00:0918              BNE    OPBTRT   NO, RETURN
               S01:FFFFFFFFFFFFFC5D:  26 01
F00:0919       *
F00:0920       OPBT3  INCA            # BYTES IN INSTRUCTION:=3
               S01:FFFFFFFFFFFFFC5F:  4C
F00:0921       *
F00:0922       OPBTRT RTS             RETURN TO CALLER
               S01:FFFFFFFFFFFFFC60:  39
F00:0923       *
F00:0924       * OP CODE TO NUMBER OF BYTES CONVERSION TABLE
F00:0925       *
F00:0926       *           # BYTES  TOP 4 BITS OF OPCODE
F00:0927       *           -------  --------------------
F00:0928       *
F00:0929       OPBTTB EQU    *
F00:0930              dc.b    1        0
               S01:FFFFFFFFFFFFFC61:  01
F00:0931              DC.B    1        1
               S01:FFFFFFFFFFFFFC62:  01
F00:0932              DC.B    2+%10000000 2 ( MINUS=> BRANCHES )
               S01:FFFFFFFFFFFFFC63:  82
F00:0933              DC.B    1        3
               S01:FFFFFFFFFFFFFC64:  01
F00:0934              DC.B    1        4
               S01:FFFFFFFFFFFFFC65:  01
F00:0935              DC.B    1        5
               S01:FFFFFFFFFFFFFC66:  01
F00:0936              DC.B    2        6
               S01:FFFFFFFFFFFFFC67:  02
F00:0937              DC.B    3        7
               S01:FFFFFFFFFFFFFC68:  03
