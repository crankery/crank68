02:E808 FE034E          	  1545:             ldx h                       ; point at the data
02:E80B A600            	  1546: dump1:      ldaa 0,x
02:E80D 8DE0            	  1547:             bsr bytov1                  ; send data
02:E80F 08              	  1548:             inx
