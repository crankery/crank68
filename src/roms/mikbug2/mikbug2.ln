MEMORY {
    STACK: ORIGIN = 0x0100, LEN = 0x100
    RAM: ORIGIN = 0x0300, LEN = 0x100
    ROM: ORIGIN = 0xE000, LEN = 0x2000
}

SECTIONS {
    .stack(NOLOAD) : {  *(.stack) } >STACK

    .ram(NOLOAD)  : { *(.ram) } >RAM

    .mmio : { *(.mmio) } > ROM

    .rom : { *(.rom) } > ROM

    .vectors : { *(.vectors) } > ROM
}