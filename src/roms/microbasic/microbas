; constants 

	.equ backsp, 0x8
	.equ delcod, 0x18
	.equ prmptc, 0x21

; place the code at 0x400

	.org 0x0400

; main program 

start:	jmp micbas	; jmp to begin
restrt:	jmp filbuf

; external i-o routines 

outeee:	jmp 0xe175 ; don't have this label, must be the same as mikbug outch?
inch:	jsr 0xe178 ; mikbug inch
break:	jmp fakebrk ; should be intbrk
memend:	.word 0xbfff
fakebrk:	rts		; just return.

; keyword and jump table 

keytbl:
    .byte "PRI"
