.macro ALLOC name, size
    .equ \name, RAM_PTR
    .equ RAM_PTR, RAM_PTR + \size
.endm

; equates 
	.equ stack, 0x02ff
	.equ piaadr, 0xe208
	.equ pfilbg, 0x2000 ; start of loaded file
	.equ pfilen, 0x8000 ; end of loaded file
	; .equ extern, 0x1f00 ; switched this to just the end of code
	.equ monitr, 0xe0e3 ; ??
	.equ monpc, 0xa048 ; ??
	.equ stkbot, 0x0200

; temporary storage 
    .equ RAM_PTR, 0x0000
ALLOC rndm,   4
ALLOC bufpnt, 2
ALLOC forstk, 2
ALLOC dimpnt, 2
ALLOC xtemp3, 2
ALLOC datast, 2
ALLOC datapt, 2
ALLOC tryval, 2
